# =============================================
# FiberHelp Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file to source control
# =============================================

# Online database connection string (SQL Server)
FIBERHELP_ONLINE_CONNECTION=Data Source=YOUR_SERVER;User ID=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=True;Application Name="FiberHelpApp"

# Local database connection string (optional - defaults to LocalDB)
FIBERHELP_LOCAL_CONNECTION=Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=FiberhelpDB;Integrated Security=True;Encrypt=True;Trust Server Certificate=True

# Admin seed credentials (required for first-time setup)
FIBERHELP_ADMIN_EMAIL=admin@fiberhelp.com
FIBERHELP_ADMIN_PASSWORD=YourSecurePassword123!

# AES-256 encryption key for sensitive data at rest (optional - auto-derived if not set)
FIBERHELP_AES_KEY=YourStrongEncryptionKeyHere
