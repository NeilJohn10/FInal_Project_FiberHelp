using System;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;
using FiberHelp.Data;
using FiberHelp.Data.context;
using FiberHelp.Models;
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.DependencyInjection;

namespace FiberHelp.Services
{
    // Persists writes to local outbox only. Background worker pushes outbox to cloud when online.
    public class DualWriteService
    {
        private readonly IServiceScopeFactory _scopeFactory;

        public DualWriteService(IServiceScopeFactory scopeFactory)
        {
            _scopeFactory = scopeFactory;
        }

        public async Task EnqueueAsync<T>(string operation, T entity, string? key = null) where T : class
        {
            using var scope = _scopeFactory.CreateScope();
            // Always use local SQLite for outbox to avoid touching cloud schema
            var local = scope.ServiceProvider.GetRequiredService<localContext>();
            await EnsureOutboxTableAsync(local);
            var json = JsonSerializer.Serialize(entity);
            local.Outbox.Add(new OutboxMessage
            {
                EntityName = typeof(T).Name,
                Operation = operation,
                Payload = json,
                Key = key,
                CreatedAt = DateTime.UtcNow
            });
            await local.SaveChangesAsync();
        }

        // Mirror a single entity change directly into local SQLite (used when primary write was to cloud)
        public async Task MirrorLocalAsync<T>(string operation, T entity) where T : class
        {
            using var scope = _scopeFactory.CreateScope();
            var local = scope.ServiceProvider.GetRequiredService<localContext>();
            try
            {
                await local.Database.MigrateAsync();

                switch (operation)
                {
                    case "Create":
                        local.Set<T>().Add(entity);
                        break;
                    case "Update":
                        local.Set<T>().Update(entity);
                        break;
                    case "Delete":
                        local.Set<T>().Remove(entity);
                        break;
                    default:
                        return;
                }

                await local.SaveChangesAsync();
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"MirrorLocalAsync error: {ex.Message}");
            }
        }

        // Exposed so startup/processor can guarantee table exists on old SQLite files
        public static async Task EnsureOutboxTableAsync(DbContext local)
        {
            try
            {
                if (local.Database.ProviderName?.Contains("Sqlite", StringComparison.OrdinalIgnoreCase) == true)
                {
                    // Create table if it doesn't exist. Works even if DB already exists without the table.
                    await local.Database.ExecuteSqlRawAsync(
                        "CREATE TABLE IF NOT EXISTS OutboxMessages (\n" +
                        " Id INTEGER PRIMARY KEY AUTOINCREMENT,\n" +
                        " EntityName TEXT NOT NULL,\n" +
                        " Operation TEXT NOT NULL,\n" +
                        " Payload TEXT NOT NULL,\n" +
                        " Key TEXT NULL,\n" +
                        " CreatedAt TEXT NOT NULL,\n" +
                        " ProcessedAt TEXT NULL\n" +
                        ")");
                }
                else
                {
                    await local.Database.EnsureCreatedAsync();
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"EnsureOutboxTableAsync error: {ex.Message}");
            }
        }
    }

    public class OutboxProcessor
    {
        private readonly IServiceScopeFactory _scopeFactory;
        private static readonly TimeSpan Interval = TimeSpan.FromSeconds(10);
        private CancellationTokenSource? _cts;

        public OutboxProcessor(IServiceScopeFactory scopeFactory)
        {
            _scopeFactory = scopeFactory;
        }

        public void Start()
        {
            _cts = new CancellationTokenSource();
            _ = Task.Run(() => RunAsync(_cts.Token));
        }

        public void Stop()
        {
            _cts?.Cancel();
        }

        private async Task RunAsync(CancellationToken token)
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    using var scope = _scopeFactory.CreateScope();
                    var online = scope.ServiceProvider.GetRequiredService<onlineContext>();
                    var local = scope.ServiceProvider.GetRequiredService<localContext>();

                    // If cloud is unreachable, skip this cycle
                    try { if (!online.Database.CanConnect()) goto Sleep; } catch { goto Sleep; }

                    await DualWriteService.EnsureOutboxTableAsync(local);

                    // Process up to N messages per cycle from local outbox
                    var batch = await local.Outbox
                        .OrderBy(o => o.Id)
                        .Where(o => o.ProcessedAt == null)
                        .Take(50)
                        .ToListAsync(token);

                    if (batch.Count == 0) goto Sleep;

                    foreach (var msg in batch)
                    {
                        switch (msg.EntityName)
                        {
                            case nameof(Ticket):
                                await ApplyAsync<Ticket>(online, msg);
                                break;
                            case nameof(Client):
                                await ApplyClientAsync(online, msg);
                                break;
                            case nameof(Account):
                                await ApplyAccountAsync(online, msg);
                                break;
                            case nameof(Invoice):
                                await ApplyAsync<Invoice>(online, msg);
                                break;
                            case nameof(User):
                                await ApplyAsync<User>(online, msg);
                                break;
                            case nameof(Agent):
                                await ApplyAsync<Agent>(online, msg);
                                break;
                            default:
                                msg.ProcessedAt = DateTime.UtcNow; // unknown type: mark processed to avoid blocking
                                break;
                        }
                    }

                    await online.SaveChangesAsync(token);
                    foreach (var m in batch) m.ProcessedAt ??= DateTime.UtcNow;
                    await local.SaveChangesAsync(token);
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"OutboxProcessor cycle error: {ex.Message}");
                }

            Sleep:
                try { await Task.Delay(Interval, token); } catch { }
            }
        }

        private static async Task ApplyAsync<T>(DbContext online, OutboxMessage msg) where T : class
        {
            try
            {
                var entity = System.Text.Json.JsonSerializer.Deserialize<T>(msg.Payload);
                if (entity == null) { msg.ProcessedAt = DateTime.UtcNow; return; }
                switch (msg.Operation)
                {
                    case "Create":
                        online.Set<T>().Add(entity);
                        break;
                    case "Update":
                        online.Set<T>().Update(entity);
                        break;
                    case "Delete":
                        online.Set<T>().Remove(entity);
                        break;
                    default:
                        msg.ProcessedAt = DateTime.UtcNow;
                        break;
                }
            }
            catch
            {
                // keep unprocessed; will retry later
            }
        }

        private static async Task ApplyClientAsync(DbContext online, OutboxMessage msg)
        {
            try
            {
                var entity = System.Text.Json.JsonSerializer.Deserialize<Client>(msg.Payload);
                if (entity == null) { msg.ProcessedAt = DateTime.UtcNow; return; }
                if (string.Equals(msg.Operation, "Delete", StringComparison.OrdinalIgnoreCase))
                {
                    // Safe delete: skip if referenced by tickets
                    var hasTickets = await online.Set<Ticket>().AnyAsync(t => t.ClientId == entity.Id);
                    if (hasTickets)
                    {
                        // Do not delete to avoid FK conflict; mark processed to stop retry loop
                        msg.ProcessedAt = DateTime.UtcNow;
                        return;
                    }
                    online.Set<Client>().Remove(entity);
                }
                else if (string.Equals(msg.Operation, "Create", StringComparison.OrdinalIgnoreCase))
                {
                    online.Set<Client>().Add(entity);
                }
                else if (string.Equals(msg.Operation, "Update", StringComparison.OrdinalIgnoreCase))
                {
                    online.Set<Client>().Update(entity);
                }
            }
            catch { }
        }

        private static async Task ApplyAccountAsync(DbContext online, OutboxMessage msg)
        {
            try
            {
                var entity = System.Text.Json.JsonSerializer.Deserialize<Account>(msg.Payload);
                if (entity == null) { msg.ProcessedAt = DateTime.UtcNow; return; }
                if (string.Equals(msg.Operation, "Delete", StringComparison.OrdinalIgnoreCase))
                {
                    // Safe delete: skip if referenced by clients or tickets
                    var hasClients = await online.Set<Client>().AnyAsync(c => c.AccountId == entity.Id);
                    var hasTickets = await online.Set<Ticket>().AnyAsync(t => t.AccountId == entity.Id);
                    if (hasClients || hasTickets)
                    {
                        msg.ProcessedAt = DateTime.UtcNow;
                        return;
                    }
                    online.Set<Account>().Remove(entity);
                }
                else if (string.Equals(msg.Operation, "Create", StringComparison.OrdinalIgnoreCase))
                {
                    online.Set<Account>().Add(entity);
                }
                else if (string.Equals(msg.Operation, "Update", StringComparison.OrdinalIgnoreCase))
                {
                    online.Set<Account>().Update(entity);
                }
            }
            catch { }
        }
    }
}
