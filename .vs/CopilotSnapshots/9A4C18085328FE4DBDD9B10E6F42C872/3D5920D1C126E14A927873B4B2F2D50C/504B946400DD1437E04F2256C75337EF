@using Microsoft.AspNetCore.Components
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<link href="css/mainlayout.css" rel="stylesheet" />

<div class="app-shell">
    <aside class="sidebar">
   <div class="brand">
   <img src="css/bootstrap/Logo.png" alt="FiberHelp" class="brand-logo" />
            <span>FIBERHELP</span>
        </div>

        <div class="sidebar-group">
            <button class="sidebar-btn" @onclick="@(() => NavigationManager.NavigateTo("/"))">
          <span class="icon">🏠</span>
      <span>Dashboard</span>
    </button>
      <button class="sidebar-btn" @onclick="@(() => NavigationManager.NavigateTo("/tickets"))">
       <span class="icon">🎫</span>
     <span>Tickets</span>
        </button>
 <button class="sidebar-btn" @onclick="@(() => NavigationManager.NavigateTo("/customers"))">
      <span class="icon">👥</span>
        <span>Customers</span>
      </button>
     <button class="sidebar-btn" @onclick="@(() => NavigationManager.NavigateTo("/billing"))">
        <span class="icon">💳</span>
          <span>Billing</span>
       </button>
            <button class="sidebar-btn" @onclick="@(() => NavigationManager.NavigateTo("/reports"))">
   <span class="icon">📊</span>
    <span>Reports</span>
            </button>
        </div>

        <div class="sidebar-group muted">
            <button class="sidebar-btn" @onclick="@(() => NavigationManager.NavigateTo("/settings"))">
              <span class="icon">⚙️</span>
       <span>Settings</span>
            </button>
   <button class="sidebar-btn danger" @onclick="@(() => NavigationManager.NavigateTo("/logout"))">
      <span class="icon">↩️</span>
         <span>Logout</span>
         </button>
        </div>
    </aside>

    <main class="main">
        <div class="main-inner">
            @Body
      </div>
    </main>
</div>