private static string HashPassword(string password)
{
 using var sha = SHA256.Create();
 var bytes = Encoding.UTF8.GetBytes(password ?? string.Empty);
 var hash = sha.ComputeHash(bytes);
 return Convert.ToHexString(hash);
}

