  private List<DonutSeg> BuildDonut(List<(string label, int count, string color)> items)
  {
    var total = Math.Max(1, items.Sum(i => i.count));
    double acc = 0;
    var list = new List<DonutSeg>();
    foreach (var it in items)
    {
      var percent = (double)it.count / total;
      var dash = percent * Circ;
      var gap = Circ - dash;
      var seg = new DonutSeg(it.label, it.count, it.color,
        Math.Round(percent * 100).ToString(),
        dash.ToString("F2"),
        gap.ToString("F2"),
        acc.ToString("F2"));
      list.Add(seg);
      acc += dash;
    }
    return list;
  }

  private void BuildCustomerGrowth()
  {
    var labels = new List<string>();
    var data = new List<double>();
    for (int i = 5; i >= 0; i--)
    {
      var dt = DateTime.UtcNow.AddMonths(-i);
      labels.Add(dt.ToString("MMM"));
      var monthStart = new DateTime(dt.Year, dt.Month, 1, 0, 0, 0, DateTimeKind.Utc);
      var monthEnd = monthStart.AddMonths(1);
      var count = customers?.Count(c => c.JoinDate >= monthStart && c.JoinDate < monthEnd) ?? 0;
      data.Add(count);
    }
    Last6Months = labels.ToArray();
    CustomerGrowth = data.ToArray();
  }

  private string BuildLinePath(double[] pts)
  {
    if (pts == null || pts.Length == 0) return string.Empty;
    var max = Math.Max(1.0, pts.Max());
    var step = 600.0 / (pts.Length - 1);
    var d = $"M 0 {180 - (pts[0] / max) * 160}";
    for (int i = 1; i < pts.Length; i++) d += $" L {i * step} {180 - (pts[i] / max) * 160}";
    return d;
  }

