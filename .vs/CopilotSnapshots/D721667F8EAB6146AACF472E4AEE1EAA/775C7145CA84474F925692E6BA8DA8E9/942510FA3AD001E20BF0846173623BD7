public async Task<bool> ArchiveTicketAsync(int ticketId, string? archivedByUserId = null)
{
    try
    {
        LastError = null;
        if (ticketId <= 0) { LastError = "Invalid ticket ID"; return false; }

        var ticket = await _db.Tickets.FindAsync(ticketId);
        if (ticket == null) { LastError = $"Ticket #{ticketId} not found"; return false; }

        if (ticket.IsArchived) { LastError = "Ticket is already archived"; return false; }

        ticket.IsArchived = true;
        ticket.ArchivedAt = DateTime.UtcNow;
        ticket.ArchivedByUserId = archivedByUserId;
        
        // If ticket is resolved but not closed, mark it as closed
        if (ticket.Status == "Resolved" && ticket.ClosedAt == null)
        {
            ticket.Status = "Closed";
            ticket.ClosedAt = DateTime.UtcNow;
        }

        _db.Tickets.Update(ticket);
        var rows = await _db.SaveChangesAsync();

        if (rows > 0)
        {
            await MaybeSyncOrEnqueueAsync("Update", ticket, ticket.Id.ToString());
            return true;
        }

        LastError = "Archive failed";
        return false;
    }
    catch (Exception ex)
    {
        LastError = _errorService.GetContextualMessage(ex, "archive", "ticket");
        System.Diagnostics.Debug.WriteLine($"AdminService.ArchiveTicketAsync error: {ex}");
        return false;
    }
}

public async Task<bool> UnarchiveTicketAsync(int ticketId)
{
    try
    {
        LastError = null;
        if (ticketId <= 0) { LastError = "Invalid ticket ID"; return false; }

        var ticket = await _db.Tickets.FindAsync(ticketId);
        if (ticket == null) { LastError = $"Ticket #{ticketId} not found"; return false; }

        if (!ticket.IsArchived) { LastError = "Ticket is not archived"; return false; }

        ticket.IsArchived = false;
        ticket.ArchivedAt = null;
        ticket.ArchivedByUserId = null;
        
        // If ticket was closed when archived, reopen it
        if (ticket.Status == "Closed")
        {
            ticket.Status = "Resolved";
            ticket.ClosedAt = null;
        }

        _db.Tickets.Update(ticket);
        var rows = await _db.SaveChangesAsync();

        if (rows > 0)
        {
            await MaybeSyncOrEnqueueAsync("Update", ticket, ticket.Id.ToString());
            return true;
        }

        LastError = "Unarchive failed";
        return false;
    }
    catch (Exception ex)
