      count = tickets?.Count(t => string.Equals(t.Status, s.key, StringComparison.OrdinalIgnoreCase)) ?? 0
    }).ToList();

    TicketDonut = BuildDonut(counts.Select(c => (c.label, c.count, c.color)).ToList());
  }

  private void BuildInvoiceDonut()
