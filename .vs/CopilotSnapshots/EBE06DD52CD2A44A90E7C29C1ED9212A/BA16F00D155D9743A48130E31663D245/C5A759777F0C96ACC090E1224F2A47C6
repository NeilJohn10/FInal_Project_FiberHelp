@page "/admin/agents"
@using FiberHelp.Models
@inject FiberHelp.Services.AdminService AdminService
@inject FiberHelp.Services.AuthService AuthService

<link href="css/dashboard.css" rel="stylesheet" />
<style>
/* Password Requirements */
.req-list{font-size:12px;margin:8px 0 0;display:flex;flex-wrap:wrap;gap:6px}
.req{padding:6px 10px;border:1px solid #e2e8f0;border-radius:6px;background:#f8fafc;display:flex;align-items:center;gap:6px;font-weight:600;transition:all .2s ease}
.req.ok{border-color:#16a34a;background:#ecfdf5;color:#065f46}
.req.bad{border-color:#dc2626;background:#fef2f2;color:#991b1b}

/* Enhanced Modal Styling */
.agents-modal-bg {
 position: fixed;
 inset: 0;
 background: rgba(15, 23, 42, 0.6);
 backdrop-filter: blur(4px);
 display: flex;
 align-items: center;
 justify-content: center;
 z-index: 9999;
 padding: 40px 20px;
 overflow: auto;
 animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
 from { opacity: 0; }
 to { opacity: 1; }
}

.agents-modal-card {
 width: 100%;
 max-width: 620px;
 background: #ffffff;
 border-radius: 16px;
padding: 0;
 box-shadow: 0 24px 48px -10px rgba(0, 0, 0, 0.25), 0 6px 16px rgba(0, 0, 0, 0.08);
 border: 1px solid #e2e8f0;
 position: relative;
 animation: slideUp 0.3s ease;
 overflow: hidden;
}

@keyframes slideUp {
 from { opacity: 0; transform: translateY(20px); }
 to { opacity: 1; transform: translateY(0); }
}

/* Modal Header */
.agents-modal-header {
 padding: 28px 32px 24px;
 border-bottom: 1px solid #e2e8f0;
 background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
}

.agents-modal-card h3 {
 margin: 0 0 8px;
 font-size: 24px;
font-weight: 800;
 letter-spacing: -0.01em;
 color: #1e293b;
}

.agents-modal-desc {
 font-size: 13.5px;
 color: #64748b;
 margin: 0;
 line-height: 1.5;
}

/* Modal Body */
.agents-modal-body {
 padding: 28px 32px;
 max-height: calc(100vh - 300px);
 overflow-y: auto;
}

/* Error Message */
.agents-error-message {
 background: #fef2f2;
 border: 1px solid #fecaca;
 border-left: 4px solid #dc2626;
 color: #991b1b;
 padding: 12px 16px;
 border-radius: 8px;
 margin-bottom: 20px;
 font-weight: 600;
 font-size: 13px;
}

.agents-error-message::before {
 content: "⚠ ";
 font-size: 14px;
}

/* Form Layout */
.agents-form-grid {
 display: grid;
 grid-template-columns: 1fr 1fr;
 gap: 20px;
}

.agents-form-span-2 {
 grid-column: 1 / span 2;
}

.agents-form-group {
 display: flex;
 flex-direction: column;
 gap: 8px;
}

.agents-form-group label {
 color: #1e293b;
 font-weight: 600;
 font-size: 13.5px;
}

.agents-label-hint {
 font-weight: 400;
 color: #94a3b8;
 font-size: 12.5px;
 margin-left: 4px;
}

.agents-form-input {
 width: 100%;
 padding: 11px 14px;
 border: 1.5px solid #e2e8f0;
 border-radius: 8px;
 font-size: 14px;
 transition: all 0.2s ease;
 background: #ffffff;
 font-family: inherit;
}

.agents-form-input:hover {
 border-color: #cbd5e1;
}

.agents-form-input:focus {
 outline: none;
 border-color: #2563eb;
 background: #ffffff;
 box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.agents-form-input::placeholder {
 color: #94a3b8;
}

/* Checkbox Group */
.agents-checkbox-group {
 display: flex;
 align-items: center;
 gap: 10px;
 padding: 12px 0;
}

.agents-checkbox-group input[type="checkbox"] {
 width: 20px;
 height: 20px;
 cursor: pointer;
 accent-color: #2563eb;
}

.agents-checkbox-group label {
 margin: 0;
 font-weight: 600;
 font-size: 14px;
 cursor: pointer;
 color: #1e293b;
}

/* Modal Footer/Actions */
.agents-modal-actions {
 background: #f9fafb;
 border-top: 1px solid #e2e8f0;
 padding: 20px 32px;
 display: flex;
 justify-content: flex-end;
 gap: 12px;
}

.agents-modal-actions .btn {
 min-width: 130px;
 padding: 11px 20px;
 border-radius: 8px;
 font-size: 14px;
 font-weight: 600;
 cursor: pointer;
 transition: all 0.2s ease;
 border: 1px solid transparent;
}

.agents-modal-actions .btn:not(.primary) {
 background: #ffffff;
 color: #475569;
 border-color: #cbd5e1;
}

.agents-modal-actions .btn:not(.primary):hover {
 background: #f8fafc;
 border-color: #94a3b8;
}

.agents-modal-actions .btn.primary {
 background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
 color: #fff;
 border-color: #1d4ed8;
 box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
}

.agents-modal-actions .btn.primary:hover:not(:disabled) {
 transform: translateY(-2px);
 box-shadow: 0 6px 16px rgba(37, 99, 235, 0.35);
}

.agents-modal-actions .btn.primary:disabled {
 background: linear-gradient(135deg, #94a3b8 0%, #64748b 100%);
 border-color: #64748b;
 cursor: not-allowed;
 opacity: 0.7;
 box-shadow: none;
}

/* Responsive */
@@media (max-width: 640px) {
 .agents-modal-card { max-width: 100%; border-radius: 12px; }
 .agents-modal-header, .agents-modal-body, .agents-modal-actions { padding-left: 20px; padding-right: 20px; }
 .agents-form-grid { grid-template-columns: 1fr; }
 .agents-form-span-2 { grid-column: auto; }
}
</style>

@if(!AuthService.IsAuthenticated || !string.Equals(AuthService.Role,"Administrator",StringComparison.OrdinalIgnoreCase))
{
 <div class="panel"><strong>Access denied.</strong></div>
}
else
{
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN</p>
 <h1 class="page-title">Agents</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary" @onclick="OpenModal">+ Register Agent</button>
 </div>
 </header>

 <section class="panel">
 <table class="data-table">
 <thead>
 <tr>
 <th>Email</th>
 <th>Name</th>
 <th>Dept</th>
 <th>Phone</th>
 <th>Active</th>
 </tr>
 </thead>
 <tbody>
 @if(agentRecords?.Count>0)
 {
 @foreach(var a in agentRecords)
 {
 <tr>
 <td>@a.Email</td>
 <td>@a.FullName</td>
 <td>@a.Department</td>
 <td>@a.Phone</td>
 <td>@(a.IsActive?"Yes":"No")</td>
 </tr>
 }
 }
 else
 {
 <tr><td colspan="5">No agents found.</td></tr>
 }
 </tbody>
 </table>
 </section>

 @if(!string.IsNullOrEmpty(notification))
 {
 <div class="panel" style="margin-top:12px;background:#ecfdf5;color:#065f46;border-color:#16a34a">✓ @notification</div>
 }

 @if(showModal)
 {
 <div class="agents-modal-bg" @onclick="CloseModal">
 <div class="agents-modal-card" @onclick:stopPropagation>
 <div class="agents-modal-header">
 <h3>Register Agent</h3>
 <p class="agents-modal-desc">Create a new support agent account. Password rules apply after typing.</p>
 </div>
 
 <div class="agents-modal-body">
 @if(!string.IsNullOrEmpty(errorMessage))
 {
 <div class="agents-error-message">@errorMessage</div>
 }
 
 <div class="agents-form-grid">
 <div class="agents-form-group agents-form-span-2">
 <label>
 Email
 <span class="agents-label-hint">(work address)</span>
 </label>
 <input type="email" class="agents-form-input" @bind="newEmail" placeholder="agent@domain.com" />
 </div>
 
 <div class="agents-form-group agents-form-span-2">
 <label>Full Name</label>
 <input class="agents-form-input" @bind="newFullName" placeholder="John Doe" />
 </div>
 
 <div class="agents-form-group">
 <label>Department</label>
 <input class="agents-form-input" @bind="newDept" placeholder="e.g. Support" />
 </div>
 
 <div class="agents-form-group">
 <label>Phone</label>
 <input type="tel" class="agents-form-input" @bind="newPhone" placeholder="+639123456789" />
 </div>
 
 <div class="agents-form-group agents-form-span-2">
 <div class="agents-checkbox-group">
 <input type="checkbox" id="activeCheck" @bind="newActive" />
 <label for="activeCheck">Active</label>
 </div>
 </div>
 
 <div class="agents-form-group agents-form-span-2">
 <label>
 Password
 <span class="agents-label-hint">(initial)</span>
 </label>
 <input type="password" class="agents-form-input" @bind="newPassword" @bind:event="oninput" placeholder="Enter initial password" />
 @if(attempted && !IsValidPassword())
 {
 <div class="req-list">
 <div class="req @(LenOk?"ok":"bad")">@(LenOk?"✓":"✕") 12+ characters</div>
 <div class="req @(UpperOk?"ok":"bad")">@(UpperOk?"✓":"✕") Uppercase letter</div>
 <div class="req @(DigitOk?"ok":"bad")">@(DigitOk?"✓":"✕") Number</div>
 <div class="req @(SpecialOk?"ok":"bad")">@(SpecialOk?"✓":"✕") Special character</div>
 </div>
 }
 </div>
 </div>
 </div>
 
 <div class="agents-modal-actions">
 <button class="btn" @onclick="CloseModal">Cancel</button>
 <button class="btn primary" @onclick="CreateAgent" disabled="@(!IsValidPassword())">Create Agent</button>
 </div>
 </div>
 </div>
 }
}

@code {
 List<Agent>? agentRecords;
 bool showModal=false;
 string newEmail=""; string newFullName=""; string newPassword="";
 string errorMessage=""; string notification=""; bool attempted=false;
 string newDept=""; string newPhone=""; bool newActive=true;
 
 bool LenOk=>newPassword.Length>=12;
 bool UpperOk=>newPassword.Any(char.IsUpper);
 bool DigitOk=>newPassword.Any(char.IsDigit);
 bool SpecialOk=>newPassword.Any(c=>!char.IsLetterOrDigit(c));
 
 bool IsValidPassword()=>LenOk&&UpperOk&&DigitOk&&SpecialOk&& !string.IsNullOrWhiteSpace(newEmail) && !string.IsNullOrWhiteSpace(newFullName);
 
 protected override async Task OnInitializedAsync()
 {
 if(!AuthService.IsAuthenticated || !string.Equals(AuthService.Role,"Administrator",StringComparison.OrdinalIgnoreCase))
 return;
 
 agentRecords=await AdminService.GetAgentRecordsAsync();
 }
 
 void OpenModal()
 {
 showModal=true;
 errorMessage="";
 notification="";
 newEmail=newFullName=newPassword=newDept=newPhone="";
 newActive=true;
 attempted=false;
 }
 
 void CloseModal()
 {
 showModal=false;
 errorMessage="";
 newEmail=newFullName=newPassword=newDept=newPhone="";
 attempted=false;
 }
 
 async Task CreateAgent()
 {
 attempted=true;
 errorMessage="";
 notification="";
 
 if(!IsValidPassword())
 {
 errorMessage="Fill required fields & meet password rules.";
 return;
 }
 
 var a=new Agent
 {
 Email=newEmail.Trim().ToLowerInvariant(),
 FullName=newFullName,
 Department=newDept,
 Phone=newPhone,
 IsActive=newActive
 };
 
 var ok=await AdminService.CreateAgentRecordAsync(a,newPassword);
 
 if(ok)
 {
 notification="Agent created successfully!";
 agentRecords=await AdminService.GetAgentRecordsAsync();
 CloseModal();
 }
 else
 {
 errorMessage=AdminService.LastError??"Create failed.";
 }
 }
}
