public async Task<bool> CreateTechnicianAsync(Technician tech)
{
    try
    {
        LastError = null;
        if (tech == null) { LastError = "Technician data is required"; return false; }
        if (string.IsNullOrWhiteSpace(tech.Name)) { LastError = "Name is required"; return false; }
        if (string.IsNullOrWhiteSpace(tech.Email)) { LastError = "Email is required"; return false; }
        
        var lower = tech.Email.Trim().ToLowerInvariant();
        if (await _db.Technicians.AnyAsync(t => t.Email.ToLower() == lower))
        {
            LastError = "Email already exists";
            return false;
        }
        
        if (string.IsNullOrWhiteSpace(tech.Id)) tech.Id = Guid.NewGuid().ToString();
        if (tech.CreatedAt == default) tech.CreatedAt = DateTime.UtcNow;
        if (tech.HireDate == default) tech.HireDate = DateTime.UtcNow;
        if (string.IsNullOrWhiteSpace(tech.Status)) tech.Status = "Available";
        
        _db.Technicians.Add(tech);
        var rows = await _db.SaveChangesAsync();
        
        if (rows > 0)
        {
            await MaybeSyncOrEnqueueAsync("Create", tech, tech.Id);
            return true;
        }
        
        LastError = "Failed to create technician";
        return false;
    }
    catch (Exception ex)
    {
        LastError = _errorService.GetContextualMessage(ex, "create", "technician");
        System.Diagnostics.Debug.WriteLine($"AdminService.CreateTechnicianAsync error: {ex}");
        return false;
    }
}

public async Task<bool> UpdateTechnicianAsync(Technician tech)
{
    try
    {
        LastError = null;
        if (tech == null || string.IsNullOrWhiteSpace(tech.Id))
        {
            LastError = "Invalid technician data";
            return false;
        }
        
        var existing = await _db.Technicians.FindAsync(tech.Id);
        if (existing == null)
        {
            LastError = "Technician not found";
            return false;
        }
        
        if (!string.Equals(existing.Email, tech.Email, StringComparison.OrdinalIgnoreCase))
        {
            var lower = tech.Email?.Trim().ToLowerInvariant() ?? string.Empty;
            if (await _db.Technicians.AnyAsync(t => t.Email.ToLower() == lower && t.Id != tech.Id))
            {
                LastError = "Email already exists";
                return false;
            }
            existing.Email = tech.Email ?? existing.Email;
        }
        
        existing.Name = tech.Name ?? existing.Name;
        existing.Phone = tech.Phone ?? existing.Phone;
        existing.Specialty = tech.Specialty ?? existing.Specialty;
        existing.Status = tech.Status ?? existing.Status;
        existing.Zone = tech.Zone ?? existing.Zone;
        existing.IsActive = tech.IsActive;
        existing.UpdatedAt = DateTime.UtcNow;
        
        _db.Technicians.Update(existing);
        var rows = await _db.SaveChangesAsync();
        
        if (rows > 0)
        {
            await MaybeSyncOrEnqueueAsync("Update", existing, existing.Id);
            return true;
        }
        
        LastError = "Update failed";
        return false;
    }
    catch (Exception ex)
    {
        LastError = _errorService.GetContextualMessage(ex, "update", "technician");
        System.Diagnostics.Debug.WriteLine($"AdminService.UpdateTechnicianAsync error: {ex}");
        return false;
    }
}

