@page "/billing"
@inject FiberHelp.Services.AuthService AuthService
@inject NavigationManager Navigation
@inject FiberHelp.Services.BillingService

@* Using global admin-theme.css; removed page-specific CSS *@

<style>
  .billing-header{display:flex;align-items:center;justify-content:space-between;padding-bottom:20px;margin-bottom:22px;border-bottom:1px solid #e5e7eb}
  .billing-header .page-title{font-size:42px;line-height:1.1;margin:0 0 4px}
  .billing-controls{display:flex;gap:14px;align-items:center}
  .billing-search{width:340px;padding:12px 18px;border-radius:14px;border:1px solid #e5e7eb;background:#fff;box-shadow:0 8px 22px rgba(2,6,23,0.08);font-size:15px}
  .billing-controls .btn.subtle{background:#fff;color:#0f172a;border:1px solid #e5e7eb;border-radius:14px;padding:10px 22px;box-shadow:0 4px 10px rgba(2,6,23,0.04)}
  .billing-controls .btn.primary{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border:none;border-radius:14px;padding:10px 26px;box-shadow:0 14px 32px rgba(29,78,216,0.30);font-weight:600}
  .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:16px;margin-bottom:24px}
  .kpi-card{background:#fff;padding:18px 20px;border-radius:16px;box-shadow:0 12px 28px rgba(2,6,23,0.08)}
  .kpi-val{font-size:32px;font-weight:700;line-height:1;margin-bottom:6px}
  .kpi-label{font-size:12px;letter-spacing:.05em;font-weight:600;color:#64748b;text-transform:uppercase}
  .invoice-table{width:100%;border-collapse:separate;border-spacing:0 10px}
  .invoice-table thead th{font-size:13px;font-weight:700;padding:10px 12px;color:#475569;text-align:left;border-bottom:1px solid #e5e7eb}
  .invoice-table tbody td{background:#f9fafb;padding:14px 12px;font-size:14px;border-top:1px solid #edf2f7;border-bottom:1px solid #edf2f7}
  .invoice-table tbody tr td:first-child{border-left:1px solid #edf2f7;border-top-left-radius:12px;border-bottom-left-radius:12px}
  .invoice-table tbody tr td:last-child{border-right:1px solid #edf2f7;border-top-right-radius:12px;border-bottom-right-radius:12px}
  .status-badge{display:inline-block;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:700}
  .status-paid{background:#dcfce7;color:#065f46;border:1px solid #bbf7d0}
  .status-unpaid{background:#fef9c3;color:#92400e;border:1px solid #fde68a}
  .action-btn{border:none;background:transparent;padding:6px 8px;border-radius:10px;cursor:pointer}
  .action-btn:hover{background:#eef2ff}
</style>
<div>
  <header class="billing-header">
    <div>
      <p class="eyebrow">FIBERHELP · @GetRoleLabel()</p>
      <h1 class="page-title">Billing</h1>
    </div>
    <div class="billing-controls">
      <input class="billing-search" placeholder="Search invoices" @bind="searchTerm" @oninput="async _ => await OnSearchChanged(searchTerm)" />
      <button class="btn subtle" @onclick="ExportInvoices">Export</button>
      @if (!(AuthService.Role ?? "").Equals("Agent", StringComparison.OrdinalIgnoreCase))
      {
        <button class="btn primary" @onclick="NewInvoice">+ New Invoice</button>
      }
    </div>
  </header>
  <div class="kpi-grid">
    <div class="kpi-card"><div class="kpi-val">@totalInvoices</div><div class="kpi-label">Total Invoices</div></div>
    <div class="kpi-card"><div class="kpi-val">@paidInvoices</div><div class="kpi-label">Paid</div></div>
    <div class="kpi-card"><div class="kpi-val">@unpaidInvoices</div><div class="kpi-label">Unpaid</div></div>
  </div>
  <section class="panel" style="padding:20px 20px 10px;">
    <h3 style="margin:0 0 14px">Invoices</h3>
    @if (!string.IsNullOrEmpty(pageError))
    {
      <div class="error-message" style="color:#b91c1c;margin-bottom:12px;">Error: @pageError</div>
    }
    <table class="invoice-table">
      <thead>
        <tr><th style="width:90px">Invoice #</th><th style="width:120px">Account</th><th style="width:160px">Amount</th><th style="width:160px">Issue Date</th><th style="width:120px">Status</th><th style="text-align:right;width:140px">Actions</th></tr>
      </thead>
      <tbody>
        @if (invoices != null && invoices.Any())
        {
          foreach (var inv in invoices)
          {
            <tr>
              <td>@inv.Id</td>
              <td>@(inv.AccountId?.ToString() ?? "-")</td>
              <td>@inv.AmountDue.ToString("C")</td>
              <td>@inv.IssueDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
              <td><span class="status-badge @(string.Equals(inv.Status,"Paid",StringComparison.OrdinalIgnoreCase)?"status-paid":"status-unpaid")">@inv.Status</span></td>
              <td style="text-align:right">
                @if (!string.Equals(inv.Status, "Paid", StringComparison.OrdinalIgnoreCase) && !(AuthService.Role ?? "").Equals("Agent", StringComparison.OrdinalIgnoreCase))
                {
                  <button class="action-btn edit" title="Mark Paid" @onclick="() => MarkPaid(inv.Id)">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M9 12l2 2 4-4" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                      <circle cx="12" cy="12" r="9" stroke="#2563eb" stroke-width="1.2" />
                    </svg>
                  </button>
                }
              </td>
            </tr>
          }
        }
        else
        {
          <tr><td colspan="6" class="muted-text">No invoices available.</td></tr>
        }
      </tbody>
    </table>
  </section>
  <Toast Message="@toast" />
</div>

@code {
  private List<FiberHelp.Models.Invoice>? invoices;
  private string pageError = string.Empty;
  private string searchTerm = string.Empty;
  @inject Microsoft.JSInterop.IJSRuntime JS
  private string toast = string.Empty;
  private int totalInvoices=0;
  private int paidInvoices=0;
  private int unpaidInvoices=0;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      if (!AuthService.IsAuthenticated) { Navigation.NavigateTo("/login", true); return; }
      invoices = await BillingService.GetInvoicesAsync();
      if (!string.IsNullOrEmpty(BillingService.LastError)) pageError = BillingService.LastError!;
      RecalcCounts();
    }
    catch (Exception ex)
    {
      pageError = ex.Message;
      System.Diagnostics.Debug.WriteLine($"Billing page initialization error: {ex}");
    }
  }

  private async Task MarkPaid(int id)
  {
    try
    {
      var ok = await BillingService.MarkPaidAsync(id);
      if (!ok) pageError = BillingService.LastError ?? "Failed to mark invoice paid";
      invoices = await BillingService.GetInvoicesAsync();
      RecalcCounts();
      await ReloadFiltered();
    }
    catch (Exception ex)
    {
      pageError = ex.Message;
      System.Diagnostics.Debug.WriteLine($"Billing.MarkPaid error: {ex}");
    }
    StateHasChanged();
  }

  private async Task OnSearchChanged(string val)
  {
    searchTerm = val;
    await ReloadFiltered();
  }

  private async Task ReloadFiltered()
  {
    var all = await BillingService.GetInvoicesAsync();
    if (!string.IsNullOrEmpty(BillingService.LastError)) pageError = BillingService.LastError!;
    invoices = string.IsNullOrWhiteSpace(searchTerm) ? all : all.Where(i => (i.Id.ToString()).Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || (i.AccountId?.ToString() ?? string.Empty).Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || i.Status.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
    RecalcCounts();
    StateHasChanged();
  }

  private async void ExportInvoices()
  {
    var rows = invoices ?? new List<FiberHelp.Models.Invoice>();
    var csv = new System.Text.StringBuilder();
    csv.AppendLine("Id,AccountId,AmountDue,IssueDate,Status");
    foreach(var i in rows)
      csv.AppendLine($"{i.Id},{i.AccountId},{i.AmountDue},{i.IssueDate:yyyy-MM-dd},{i.Status}");
    await JS.InvokeAsync<bool>("FiberExport.saveFile", "invoices.csv", csv.ToString());
    toast = "Invoices exported"; StateHasChanged(); await Task.Delay(2000); toast = string.Empty; StateHasChanged();
  }
  private void NewInvoice() { /* placeholder for modal */ }

  private string GetRoleLabel()
  {
    var role = AuthService?.Role;
    if (string.IsNullOrWhiteSpace(role)) return "GUEST";
    return role.ToUpperInvariant();
  }

  private string GetAvatarLetters()
  {
    var name = AuthService?.Email ?? "";
    if (string.IsNullOrWhiteSpace(name)) return "FH";
    var parts = name.Split('@');
    var left = parts[0];
    if (left.Length >=2) return left.Substring(0,2).ToUpperInvariant();
    return left.ToUpperInvariant();
  }

  private void RecalcCounts()
  {
    var list = invoices ?? new List<FiberHelp.Models.Invoice>();
    totalInvoices = list.Count;
    paidInvoices = list.Count(i => string.Equals(i.Status,"Paid",StringComparison.OrdinalIgnoreCase));
    unpaidInvoices = totalInvoices - paidInvoices;
  }
}