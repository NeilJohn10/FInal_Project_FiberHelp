@inherits LayoutComponentBase
@implements IDisposable
@using System
@inject FiberHelp.Services.AuthService AuthService
@inject NavigationManager Navigation

<div class="main-layout">
    @if (AuthService.IsAuthenticated)
    {
        <header class="top-bar">
            <div class="brand">FIBERHELP</div>
            <div class="top-actions">@* place for global actions/avatar *@</div>
        </header>
        <main class="body-content">
            @Body
        </main>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.AuthenticationStateChanged += OnAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (!AuthService.IsAuthenticated)
            {
                // Navigate to login without forcing a hard reload
                Navigation.NavigateTo("/login");
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnAuthChanged()
    {
        // When auth state changes, update UI and navigate appropriately
        InvokeAsync(() =>
        {
            if (!AuthService.IsAuthenticated)
            {
                Navigation.NavigateTo("/login");
            }
            else
            {
                // If user became authenticated and currently on login page, go to home
                if (Navigation.Uri.EndsWith("/login", StringComparison.OrdinalIgnoreCase))
                {
                    Navigation.NavigateTo("/");
                }
            }

            StateHasChanged();
        });
    }

    public void Dispose()
    {
        AuthService.AuthenticationStateChanged -= OnAuthChanged;
    }
}

<style>
    .main-layout { min-height:100vh; display:flex; flex-direction:column; }
    .top-bar { height:64px; display:flex; align-items:center; justify-content:space-between; padding:020px; background:transparent; }
    .body-content { flex:1; }
</style>