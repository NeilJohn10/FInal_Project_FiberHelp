@* Login.razor *@
@page "/login"
@layout FiberHelp.Components.Layout.EmptyLayout
@inject NavigationManager NavigationManager
@inject FiberHelp.Services.AuthService AuthService
@using System.Linq

<PageTitle>Login - FiberHelp</PageTitle>
<link href="css/login.css" rel="stylesheet" />

<div class="login-wrapper">
  <div class="login-split">
     <div class="hero-panel">
 <div class="hero-logo">
  <img src="css/bootstrap/Logo.png" alt="FiberHelp" />
      </div>
      <h2 class="hero-brand">FIBERHELP</h2>
       <p class="hero-tagline">YOUR CONNECTION. OUR PRIORITY</p>
 <h1 class="hero-heading">Connect with</h1>
<h1 class="hero-accent">Confidence</h1>
 <p class="hero-text">Your trusted partner in reliable fiber internet service</p>
    <p class="hero-description">Experience exceptional support with our modern facilities, expert team, and personalized solutions designed just for you.</p>
 <div class="stat-row">
         <div class="stat-box">
          <h3>500+</h3>
     <p>Happy Customers</p>
     </div>
       <div class="stat-box">
       <h3>15+</h3>
  <p>Years Experience</p>
       </div>
            </div>
        </div>

        <div class="login-container">
        <div class="login-card show">
     <div class="login-header">
 <h1>Welcome Back</h1>
    <p>Sign in to your account</p>
       </div>

      @if(!string.IsNullOrEmpty(errorMessage))
   {
     <div class="error-message">@errorMessage</div>
       }

 <div class="login-form">
  <div class="form-group">
   <label for="email">Email Address</label>
    <div class="input-wrapper">
 <span class="input-icon">✉</span>
     <input type="email" id="email" class="form-input" placeholder="your.email@example.com" @bind="email" required />
  </div>
 </div>

 <div class="form-group">
     <label for="password">Password</label>
  <div class="input-wrapper">
  <span class="input-icon">🔒</span>
          <input type="password" id="password" class="form-input" placeholder="Enter your password" @bind="Password" @bind:event="oninput" required />
   <button type="button" class="toggle-password">👁</button>
    </div>
  </div>

  @if(attemptedSignIn && !IsPasswordValid())
        {
     <div class="pw-requirements">
      <div class="@ReqClass(hasMinLength)"><span>@CheckMark(hasMinLength)</span><span>12+ characters</span></div>
  <div class="@ReqClass(hasUpper)"><span>@CheckMark(hasUpper)</span><span>Uppercase letter</span></div>
 <div class="@ReqClass(hasDigit)"><span>@CheckMark(hasDigit)</span><span>Number</span></div>
  <div class="@ReqClass(hasSpecial)"><span>@CheckMark(hasSpecial)</span><span>Special character</span></div>
   </div>
   }

   <div class="form-options">
       <label class="checkbox-label">
   <input type="checkbox" @bind="rememberMe" />
       <span>Remember me</span>
   </label>
         <a href="#" class="forgot-password">Forgot Password?</a>
      </div>

   <button type="button" class="btn-login" disabled="@(isLoading || string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(_password))" @onclick="HandleLogin">
         @if(isLoading)
  {
   <span>Logging in...</span>
       }
          else
        {
   <span class="btn-icon">🕐</span>
     <span>Access My Portal</span>
   }
   </button>

      <div class="divider">Or continue with</div>

    <button type="button" class="btn-google" @onclick="()=>{}">
       <svg class="google-icon" viewBox="0 0 24 24">
     <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
       <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
     </svg>
     <span>Continue with Google</span>
     </button>

     <div class="register-link">
     <p>Don't have an account? <a href="#">Sign Up</a></p>
   </div>
       
<div class="admin-link">
       <a href="#">
 <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
 </svg> 
         Staff / Admin Login
      </a>
           </div>
 </div>
   </div>
        </div>
    </div>
</div>

@code {
    private string email="";
    private string _password=string.Empty;
    private bool rememberMe=false;
    private bool isLoading=false;
private string errorMessage="";
    private bool hasMinLength=false;
    private bool hasUpper=false;
    private bool hasDigit=false;
    private bool hasSpecial=false;
    private bool attemptedSignIn=false;
    
    private string Password
    {
        get=>_password;
      set
        {
    _password=value??string.Empty;
    hasMinLength=_password.Length>=12;
            hasUpper=_password.Any(char.IsUpper);
hasDigit=_password.Any(char.IsDigit);
   hasSpecial=_password.Any(c=>!char.IsLetterOrDigit(c));
   }
    }
    
private bool IsPasswordValid()=>hasMinLength&&hasUpper&&hasDigit&&hasSpecial;
    private string ReqClass(bool ok)=>ok?"req valid":"req invalid";
    private string CheckMark(bool ok)=>ok?"✔":"✖";
    
    private async Task HandleLogin()
    {
     attemptedSignIn=true;
      errorMessage=string.Empty;
        StateHasChanged();
    
  if(string.IsNullOrWhiteSpace(email)||string.IsNullOrWhiteSpace(_password))
 {
    errorMessage="Email and password required.";
         return;
        }
     
      if(!IsPasswordValid())
 {
     errorMessage="Password doesn't meet requirements.";
            return;
        }
   
    isLoading=true;
        StateHasChanged();
     
    var ok=await AuthService.SignInAsync(email.Trim(),_password);
        isLoading=false;
   
  if(ok)
        {
     NavigationManager.NavigateTo("/");
 return;
        }
    
      errorMessage="Invalid credentials.";
        _password="";
      hasMinLength=hasUpper=hasDigit=hasSpecial=false;
   attemptedSignIn=false;
     StateHasChanged();
    }
}
