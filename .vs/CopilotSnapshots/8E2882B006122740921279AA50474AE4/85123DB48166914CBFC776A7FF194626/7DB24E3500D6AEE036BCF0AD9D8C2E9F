@page "/admin/agents"
@using FiberHelp.Models
@inject FiberHelp.Services.AdminService AdminService
@inject FiberHelp.Services.AuthService AuthService
@inject NavigationManager Nav

<link href="css/dashboard.css" rel="stylesheet" />

@if (!AuthService.IsAuthenticated || !string.Equals(AuthService.Role, "Administrator", StringComparison.OrdinalIgnoreCase))
{
 <div class="panel"><strong>Access denied.</strong></div>
}
else
{
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN</p>
 <h1 class="page-title">Agents</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary" @onclick="OpenModal">+ Register Agent</button>
 </div>
 </header>

 <section class="panel">
 <table class="data-table">
 <thead>
 <tr><th>Email</th><th>Name</th><th>Role</th><th>Active</th><th></th></tr>
 </thead>
 <tbody>
 @if (agents?.Count >0)
 {
 @foreach (var a in agents!)
 {
 <tr>
 <td>@a.Email</td>
 <td>@a.FullName</td>
 <td>@a.Role</td>
 <td>@(a.IsActive ? "Yes" : "No")</td>
 <td><button class="btn danger" @onclick="() => DeleteAgent(a.Id)">Delete</button></td>
 </tr>
 }
 }
 else
 {
 <tr><td colspan="5">No agents found.</td></tr>
 }
 </tbody>
 </table>
 </section>

 @if (!string.IsNullOrEmpty(notification))
 {
 <div class="panel" style="margin-top:12px;">@notification</div>
 }

 @if (showModal)
 {
 <div class="modal-backdrop" @onclick="CloseModal">
 <div class="modal" @onclick:stopPropagation>
 <h3>Register Agent</h3>
 @if (!string.IsNullOrEmpty(errorMessage))
 {
 <div class="error-message">@errorMessage</div>
 }
 <div class="form-group">
 <label>Email</label>
 <input class="form-input" @bind="newEmail" />
 </div>
 <div class="form-group">
 <label>Full Name</label>
 <input class="form-input" @bind="newFullName" />
 </div>
 <div class="form-group">
 <label>Password</label>
 <input type="password" class="form-input" @bind="newPassword" @bind:event="oninput" />
 </div>
 <div style="font-size:12px; margin-bottom:10px;">
 <div>@(PwdLenOk ? "✔" : "✖") Min12 chars</div>
 <div>@(PwdUpperOk ? "✔" : "✖") Uppercase</div>
 <div>@(PwdDigitOk ? "✔" : "✖") Digit</div>
 <div>@(PwdAtOk ? "✔" : "✖") Contains @("@")</div>
 </div>
 <div style="display:flex;justify-content:flex-end;gap:8px;">
 <button class="btn" @onclick="CloseModal">Cancel</button>
 <button class="btn primary" @onclick="CreateAgent" disabled="@(!FormValid())">Create</button>
 </div>
 </div>
 </div>
 }
}

@code {
 List<User>? agents;
 bool showModal;
 string newEmail = string.Empty;
 string newFullName = string.Empty;
 string newPassword = string.Empty;
 string errorMessage = string.Empty;
 string notification = string.Empty;

 bool PwdLenOk => newPassword.Length >=12;
 bool PwdUpperOk => newPassword.Any(char.IsUpper);
 bool PwdDigitOk => newPassword.Any(char.IsDigit);
 bool PwdAtOk => newPassword.Contains('@');

 protected override async Task OnInitializedAsync()
 {
 if (!AuthService.IsAuthenticated || !string.Equals(AuthService.Role, "Administrator", StringComparison.OrdinalIgnoreCase)) return;
 agents = await AdminService.GetAgentsAsync();
 }

 void OpenModal()
 {
 showModal = true;
 errorMessage = string.Empty;
 notification = string.Empty;
 newEmail = string.Empty;
 newFullName = string.Empty;
 newPassword = string.Empty;
 }

 void CloseModal()
 {
 showModal = false;
 errorMessage = string.Empty;
 newEmail = string.Empty;
 newFullName = string.Empty;
 newPassword = string.Empty;
 }

 bool FormValid() => !string.IsNullOrWhiteSpace(newEmail) && PwdLenOk && PwdUpperOk && PwdDigitOk && PwdAtOk;

 async Task CreateAgent()
 {
 errorMessage = string.Empty;
 notification = string.Empty;
 if (!FormValid())
 {
 errorMessage = "Fill all fields & meet password rules.";
 return;
 }
 var user = new User { Email = newEmail.Trim().ToLowerInvariant(), FullName = newFullName, Role = "Agent", IsActive = true };
 var ok = await AdminService.CreateAgentAsync(user, newPassword);
 if (ok)
 {
 notification = "Agent created";
 agents = await AdminService.GetAgentsAsync();
 CloseModal();
 }
 else
 {
 errorMessage = AdminService.LastError ?? "Create failed";
 }
 }

 async Task DeleteAgent(string id)
 {
 if (string.IsNullOrEmpty(id)) return;
 if (await AdminService.DeleteUserAsync(id))
 {
 notification = "Agent deleted";
 agents = await AdminService.GetAgentsAsync();
 }
 }
}
