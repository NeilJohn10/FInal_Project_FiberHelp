@page "/"
@using FiberHelp.Models
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.AdminService AdminService
@inject FiberHelp.Services.BillingService BillingService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<link href="css/dashboard.css" rel="stylesheet" />
<link href="css/analytics.css" rel="stylesheet" />
<style>
/* Clean-room styles inspired by modern admin dashboards */
.kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:20px;margin-bottom:18px;align-items:stretch}
.kpi-card{padding:20px;border-radius:14px;color:#fff;display:flex;flex-direction:column;justify-content:space-between;min-height:180px;box-shadow:0 8px 20px rgba(2,6,23,0.06)}
.kpi-icon{width:44px;height:44px;border-radius:10px;background:rgba(255,255,255,0.12);display:grid;place-items:center}
.kpi-content .kpi-header{font-weight:700;margin-bottom:8px;color:rgba(255,255,255,0.95)}
.kpi-content h2{font-size:32px;margin:0 0 6px 0;font-weight:900}
.kpi-content .kpi-sub{opacity:0.95}
.kpi-trend .trend-badge{display:inline-block;padding:6px 10px;border-radius:999px;background:rgba(255,255,255,0.12);font-weight:700}
.card-gradient-red{background:linear-gradient(135deg,#f87171,#ef4444)}
.card-gradient-blue{background:linear-gradient(135deg,#60a5fa,#3b82f6)}
.card-gradient-purple{background:linear-gradient(135deg,#a78bfa,#8b5cf6)}
.card-gradient-green{background:linear-gradient(135deg,#34d399,#10b981)}

/* Interactions */
.clickable{cursor:pointer;position:relative}
.kpi-card.clickable:hover{transform:translateY(-6px) scale(1.01);box-shadow:0 18px 40px rgba(2,6,23,0.18)}
.chart-card.clickable:hover{box-shadow:0 16px 36px rgba(2,6,23,0.14)}
.kpi-card:focus-within{outline:3px solid rgba(255,255,255,0.45)}

/* keep existing rules below */
.toolbar {display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px}
.toolbar-left{display:flex;gap:8px;align-items:center}
.chip{border:1px solid #e5e7eb;border-radius:999px;padding:6px 10px;font-size:12.5px;color:#334155;background:#fff;cursor:pointer;transition:all 0.2s}
.chip:hover{background:#f8fafc;border-color:#cbd5e1}
.chip.primary{border-color:#c7d2fe;color:#4338ca;background:#eef2ff}
.chip .dot{width:8px;height:8px;border-radius:999px;background:#6366f1;margin-right:6px;display:inline-block}

.grid-2{display:grid;grid-template-columns:2fr 1.3fr;gap:16px;margin-bottom:16px}
.card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:14px}
.card h4{margin:0 0 6px 0;font-weight:800;color:#0f172a}
.muted{color:#64748b;font-size:12.5px}

/* Collapsible Analytics Section */
.analytics-section{background:#f8fafc;border:1px solid #e5e7eb;border-radius:12px;padding:20px;margin-bottom:20px;transition:all 0.3s}
.analytics-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;cursor:pointer;user-select:none}
.analytics-header:hover h3{color:#3b82f6}
.analytics-header h3{display:flex;align-items:center;gap:10px;margin:0;font-size:20px;font-weight:800;color:#0f172a;transition:color 0.2s}
.analytics-toggle{display:flex;align-items:center;gap:8px;color:#64748b;font-size:14px;font-weight:600;transition:all 0.2s}
.analytics-toggle svg{transition:transform 0.3s}
.analytics-toggle.expanded svg{transform:rotate(180deg)}
.analytics-body{max-height:0;overflow:hidden;transition:max-height 0.4s ease-out}
.analytics-body.expanded{max-height:5000px;transition:max-height 0.6s ease-in}
.mini-charts-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-top:16px}

/* Responsive: 2 columns on medium, 1 on small */
@@media (max-width:1200px) {
  .kpi-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
  .mini-charts-grid { grid-template-columns: 1fr; }
}
@@media (max-width:640px) {
  .kpi-grid { grid-template-columns: repeat(1, minmax(0,1fr)); }
  .kpi-content h2 { font-size:28px; }
}
</style>

<div class="dashboard-root">
  <header class="topbar">
    <div class="topbar-left">
      <p class="eyebrow">FIBERHELP · @GetRoleLabel()</p>
      <h1 class="page-title">Dashboard</h1>
      <p class="welcome-text">Welcome back, @(AuthService.FullName ?? "User")! Here's what's happening today.</p>
    </div>
    <div class="top-actions">
      @if (!IsAgent)
      {
        <button class="btn-icon" @onclick="() => {}">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        </button>
        <button class="btn subtle" @onclick="ExportData">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Export
        </button>
      }
      <UserPill />
    </div>
  </header>

  <div class="toolbar">
    <div class="toolbar-left">
      <span class="chip primary"><span class="dot"></span> Overview</span>
      @if (!IsAgent)
      {
        <span class="chip" @onclick="ToggleAnalytics">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display: inline-block; vertical-align: middle; margin-right: 4px;">
            <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
          </svg>
          @(showAnalytics ? "Hide" : "Show") Analytics
        </span>
      }
    </div>
    <div class="toolbar-right">
      <span class="chip">Last Month</span>
    </div>
  </div>

  @if (IsAgent)
  {
    <!-- Agent: tickets-only KPIs -->
    <section class="kpi-grid">
      <article class="kpi-card card-gradient-red" role="button" tabindex="0" @onclick='() => NavigateRoleAware("/tickets")' @onkeydown='(e=>OnCardKey(e, () => NavigateRoleAware("/tickets")))'>
        <div class="kpi-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="12" cy="12" r="2"/>
            <path d="M12 8V6M12 18v-2M16 12h2M6 12h2"/>
          </svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-header">Open Tickets</div>
          <h2>@OpenTickets</h2>
          <p class="kpi-sub">Need attention</p>
        </div>
      </article>

      <article class="kpi-card card-gradient-blue" role="button" tabindex="0" @onclick='() => NavigateRoleAware("/tickets")' @onkeydown='(e=>OnCardKey(e, () => NavigateRoleAware("/tickets")))'>
        <div class="kpi-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10" />
          </svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-header">Total Tickets</div>
          <h2>@TotalTickets</h2>
          <p class="kpi-sub">Visible to you</p>
        </div>
      </article>
    </section>
  }
  else
  {
    <!-- Admin: full KPI set with enhanced metrics -->
    <section class="kpi-grid">
      <article class="kpi-card card-gradient-red clickable" role="button" tabindex="0" @onclick='() => NavigateRoleAware("/tickets")' @onkeydown='(e=>OnCardKey(e, () => NavigateRoleAware("/tickets")))'>
        <div class="kpi-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="12" cy="12" r="2"/>
            <path d="M12 8V6M12 18v-2M16 12h2M6 12h2"/>
          </svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-header">Open Tickets</div>
          <h2>@OpenTickets</h2>
          <p class="kpi-sub">Need attention</p>
        </div>
      </article>

      <article class="kpi-card card-gradient-green clickable" role="button" tabindex="0">
        <div class="kpi-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-header">Total Revenue</div>
          <h2>@totalRevenue.ToString("C0")</h2>
          <p class="kpi-sub">Last 30 days</p>
        </div>
      </article>

      <article class="kpi-card card-gradient-purple clickable" role="button" tabindex="0" @onclick='() => NavigateRoleAware("/reports")'>
        <div class="kpi-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/>
          </svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-header">Resolution Rate</div>
          <h2>@ticketResolutionRate.ToString("F1")%</h2>
          <p class="kpi-sub">Of all tickets</p>
        </div>
      </article>

      <article class="kpi-card card-gradient-blue clickable" role="button" tabindex="0">
        <div class="kpi-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
          </svg>
        </div>
        <div class="kpi-content">
          <div class="kpi-header">Client Growth</div>
          <h2>@clientGrowth.ToString("F1")%</h2>
          <p class="kpi-sub">This period</p>
        </div>
      </article>
    </section>

    <!-- COLLAPSIBLE ANALYTICS SECTION -->
    @if (!IsAgent)
    {
      <section class="analytics-section">
        <div class="analytics-header" @onclick="ToggleAnalytics">
          <h3>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display: inline-block;">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/>
            </svg>
            Advanced Analytics & Insights
          </h3>
          <div class="analytics-toggle @(showAnalytics ? "expanded" : "")">
            <span>@(showAnalytics ? "Hide Details" : "Show Details")</span>
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
        </div>

        <div class="analytics-body @(showAnalytics ? "expanded" : "")">
          <!-- Mini Charts Grid -->
          <div class="mini-charts-grid">
            <!-- Ticket Trends Chart -->
            <div class="chart-container">
              <div class="chart-header">
                <div>
                  <h3>Ticket Trends</h3>
                  <p class="chart-subtitle">Last 30 days</p>
                </div>
              </div>
              <div class="chart-body">
                <canvas id="miniTicketTrendsChart" style="max-height: 250px;"></canvas>
              </div>
            </div>

            <!-- Revenue vs Expenses -->
            <div class="chart-container">
              <div class="chart-header">
                <div>
                  <h3>Revenue vs Expenses</h3>
                  <p class="chart-subtitle">Monthly comparison</p>
                </div>
              </div>
              <div class="chart-body">
                <canvas id="miniRevenueExpensesChart" style="max-height: 250px;"></canvas>
              </div>
            </div>

            <!-- Priority Distribution -->
            <div class="chart-container">
              <div class="chart-header">
                <div>
                  <h3>Priority Distribution</h3>
                  <p class="chart-subtitle">Current breakdown</p>
                </div>
              </div>
              <div class="chart-body">
                <canvas id="miniPriorityChart" style="max-height: 250px;"></canvas>
              </div>
            </div>

            <!-- Client Growth -->
            <div class="chart-container">
              <div class="chart-header">
                <div>
                  <h3>Client Growth</h3>
                  <p class="chart-subtitle">New clients monthly</p>
                </div>
              </div>
              <div class="chart-body">
                <canvas id="miniClientGrowthChart" style="max-height: 250px;"></canvas>
              </div>
            </div>
          </div>
        </div>
      </section>
    }
  }

  <!-- LATEST TICKETS TABLE (both roles) -->
  <section class="tickets-section">
    <div class="panel modern-panel">
      <div class="panel-head">
        <div>
          <h2>@(IsAgent ? "Your Latest Tickets" : "Latest Tickets")</h2>
          <p class="muted-text">Most recent customer issues</p>
        </div>
        <div class="panel-actions">
          <div class="filter-pill">This week</div>
          <button class="btn-text" @onclick="NavigateToTickets">View all ?</button>
        </div>
      </div>

      <div class="table-wrapper">
        <table class="data-table modern-table">
          <thead>
            <tr>
              <th>Ticket #</th>
              <th>Client</th>
              <th>Subject</th>
              <th>Status</th>
              <th>Priority</th>
              <th>Created</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            @if (tickets != null && tickets.Any())
            {
              foreach (var t in tickets.Take(5))
              {
                <tr>
                  <td><span class="ticket-id">#@t.Id</span></td>
                  <td>
                    <div class="customer-cell">
                      <div class="customer-avatar">@GetInitials(t.ClientName ?? t.ClientId ?? "")</div>
                      <span>@(t.ClientName ?? t.ClientId)</span>
                    </div>
                  </td>
                  <td><span class="ticket-subject">@t.Title</span></td>
                  <td><span class="status-pill @GetStatusClass(t.Status)">@t.Status</span></td>
                  <td><span class="priority-badge @GetPriorityClass(t.Priority)">@t.Priority</span></td>
                  <td><span class="time-ago">@GetTimeAgo(t.Created)</span></td>
                  <td>
                    <button class="btn-action" @onclick="NavigateToTickets">
                      <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </button>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr>
                <td colspan="7" class="no-data">
                  <svg width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                  </svg>
                  <p>No tickets available</p>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>
</div>

@code {
  private List<Ticket>? tickets;
  private List<Client>? customers;
  private List<Invoice>? invoices;
  private List<Expense>? expenses;

  // Analytics toggle
  private bool showAnalytics = false;

  // Enhanced metrics
  private decimal totalRevenue;
  private double ticketResolutionRate;
  private double avgResponseTime;
  private double clientGrowth;
  private double revenueTrend;
  private double resolutionTrend;
  private double responseTrend;
  private double clientGrowthTrend;

  // KPI computed properties (tickets-focused)
  private int OpenTickets { get; set; }
  private int TotalTickets { get; set; }
  private string AvgResponseLabel { get; set; } = "0 hrs";
  private int ResolvedThisWeek { get; set; }
  private string OpenTrend { get; set; } = "+0%";
  private string TotalTrend { get; set; } = "0";
  private string AvgTrend { get; set; } = "-";
  private string ResolvedTrend { get; set; } = "+0%";

  // Donut data structures
  private const double DonutRadius = 70.0;
  private double Circ => 2 * Math.PI * DonutRadius;
  private record DonutSeg(string Label, int Count, string Color, string Percent, string Dash, string Gap, string Offset);
  private List<DonutSeg> TicketDonut = new();
  private List<DonutSeg> InvoiceDonut = new();
  private int TotalInvoices => invoices?.Count ?? 0;

  // Customer growth line (last 6 months)
  private double[] CustomerGrowth = Array.Empty<double>();
  private string[] Last6Months = Array.Empty<string>();
  private string CustomerLinePath => BuildLinePath(CustomerGrowth);

  protected override async Task OnInitializedAsync()
  {
    AuthService.AuthenticationStateChanged += OnAuthChanged;
    if (!AuthService.IsAuthenticated)
    {
      Navigation.NavigateTo("/login", true);
      return;
    }

    // Redirect Technicians to their dedicated dashboard
    if (AuthService.IsTechnician)
    {
      Navigation.NavigateTo("/technician/dashboard", true);
      return;
    }

    await LoadDataAsync();
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender && showAnalytics)
    {
      await RenderMiniCharts();
    }
  }

  private async void OnAuthChanged()
  {
    if (AuthService.IsAuthenticated)
    {
      await LoadDataAsync();
    }
    else
    {
      Navigation.NavigateTo("/login", true);
    }
    StateHasChanged();
  }

  private async Task LoadDataAsync()
  {
    tickets = await AdminService.GetTicketsAsync();
    customers = await AdminService.GetCustomersAsync();
    invoices = await BillingService.GetInvoicesAsync();
    expenses = await BillingService.GetExpensesAsync();
    ComputeKpis();
    ComputeAnalyticsMetrics();
    BuildTicketDonut();
    BuildInvoiceDonut();
    BuildCustomerGrowth();
    StateHasChanged();
  }

  private void ComputeKpis()
  {
    TotalTickets = tickets?.Count ?? 0;
    OpenTickets = tickets?.Count(t => string.Equals(t.Status, "Open", StringComparison.OrdinalIgnoreCase)) ?? 0;

    if (tickets != null && tickets.Count > 0)
    {
      var avgHours = tickets.Average(t => (DateTime.UtcNow - t.Created).TotalHours);
      AvgResponseLabel = $"~{Math.Round(avgHours)} hrs";
    }
    else AvgResponseLabel = "0 hrs";

    var weekAgo = DateTime.UtcNow.AddDays(-7);
    ResolvedThisWeek = tickets?.Count(t => (string.Equals(t.Status, "Resolved", StringComparison.OrdinalIgnoreCase) || string.Equals(t.Status, "Closed", StringComparison.OrdinalIgnoreCase)) && t.Created >= weekAgo) ?? 0;

    OpenTrend = TotalTickets > 0 ? $"+{Math.Round((double)OpenTickets / Math.Max(1, TotalTickets) * 100)}%" : "+0%";
    TotalTrend = "Same";
    AvgTrend = "-5%";
    ResolvedTrend = ResolvedThisWeek > 0 ? $"+{ResolvedThisWeek}%" : "+0%";
  }

  private void ComputeAnalyticsMetrics()
  {
    var now = DateTime.UtcNow;
    var periodStart = now.AddDays(-30);
    var previousPeriodStart = periodStart.AddDays(-30);

    // Revenue calculation with proper null handling
    var currentRevenue = invoices?.Where(i => 
      string.Equals(i.Status, "Paid", StringComparison.OrdinalIgnoreCase) && 
      i.PaidDate.HasValue && 
      i.PaidDate.Value >= periodStart
    ).Sum(i => i.AmountDue) ?? 0m;
    
    var previousRevenue = invoices?.Where(i => 
      string.Equals(i.Status, "Paid", StringComparison.OrdinalIgnoreCase) && 
      i.PaidDate.HasValue && 
      i.PaidDate.Value >= previousPeriodStart && 
      i.PaidDate.Value < periodStart
    ).Sum(i => i.AmountDue) ?? 0m;
    
    totalRevenue = currentRevenue;
    
    // Calculate trend with proper handling of zero division
    if (previousRevenue > 0)
    {
      revenueTrend = ((double)(currentRevenue - previousRevenue) / (double)previousRevenue * 100);
    }
    else if (currentRevenue > 0)
    {
      revenueTrend = 100; // 100% growth if we had no revenue before but have some now
    }
    else
    {
      revenueTrend = 0; // No change if both are zero
    }

    // Ticket Resolution Rate
    var allTickets = tickets?.ToList() ?? new();
    var currentTickets = allTickets.Where(t => t.Created >= periodStart).ToList();
    
    if (currentTickets.Any())
    {
      var resolvedCurrent = currentTickets.Count(t => 
        string.Equals(t.Status, "Resolved", StringComparison.OrdinalIgnoreCase) || 
        string.Equals(t.Status, "Closed", StringComparison.OrdinalIgnoreCase)
      );
      ticketResolutionRate = (double)resolvedCurrent / currentTickets.Count * 100;
    }
    else
    {
      // Calculate based on all tickets if no tickets in current period
      if (allTickets.Any())
      {
        var resolvedAll = allTickets.Count(t => 
          string.Equals(t.Status, "Resolved", StringComparison.OrdinalIgnoreCase) || 
          string.Equals(t.Status, "Closed", StringComparison.OrdinalIgnoreCase)
        );
        ticketResolutionRate = (double)resolvedAll / allTickets.Count * 100;
      }
      else
      {
        ticketResolutionRate = 0;
      }
    }
    
    // Resolution trend
    var previousTickets = allTickets.Where(t => t.Created >= previousPeriodStart && t.Created < periodStart).ToList();
    if (previousTickets.Any())
    {
      var resolvedPrevious = previousTickets.Count(t => 
        string.Equals(t.Status, "Resolved", StringComparison.OrdinalIgnoreCase) || 
        string.Equals(t.Status, "Closed", StringComparison.OrdinalIgnoreCase)
      );
      var previousResolutionRate = (double)resolvedPrevious / previousTickets.Count * 100;
      
      if (previousResolutionRate > 0)
      {
        resolutionTrend = (ticketResolutionRate - previousResolutionRate) / previousResolutionRate * 100;
      }
      else if (ticketResolutionRate > 0)
      {
        resolutionTrend = 100;
      }
      else
      {
        resolutionTrend = 0;
      }
    }
    else
    {
      resolutionTrend = 0;
    }

    // Client Growth
    var allClients = customers?.ToList() ?? new();
    var currentClients = allClients.Count(c => c.JoinDate >= periodStart);
    var previousClients = allClients.Count(c => c.JoinDate >= previousPeriodStart && c.JoinDate < periodStart);
    
    if (previousClients > 0)
    {
      clientGrowth = (double)(currentClients - previousClients) / previousClients * 100;
    }
    else if (currentClients > 0)
    {
      clientGrowth = 100;
    }
    else
    {
      clientGrowth = 0;
    }
    
    clientGrowthTrend = clientGrowth;
  }

  private void BuildTicketDonut()
  {
    var statusGroups = new (string key, string label, string color)[] {
      ("Open", "Open", "#3b82f6"),
      ("In Progress", "In Progress", "#f59e0b"),
      ("Resolved", "Resolved", "#10b981"),
      ("Closed", "Closed", "#94a3b8")
    };

    var counts = statusGroups.Select(s => new {
