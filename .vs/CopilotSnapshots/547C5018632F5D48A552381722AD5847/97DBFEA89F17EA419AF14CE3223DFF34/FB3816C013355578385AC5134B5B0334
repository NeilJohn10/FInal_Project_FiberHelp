 box-shadow:04px14px rgba(15,23,42,0.04);
 }

 .btn.primary {
 background: #2563eb;
 color: #fff;
 box-shadow:08px22px rgba(37,99,235,0.14);
 }

 .user-pill {
 display: flex;
 gap: .6rem;
 align-items: center;
 background: #fff;
 border-radius:999px;
 padding: .25rem .7rem .25rem .25rem;
 box-shadow:06px20px rgba(15,23,42,0.06);
 }

 .avatar {
 width:2rem;
 height:2rem;
 background: #0f172a;
 color: #fff;
 border-radius:999px;
 display: grid;
 place-items: center;
