-- Migration script to add archive columns to Agents, Technicians, Accounts, Clients, and Tickets tables
-- Run this script against your database to add archive functionality

-- ============================================
-- AGENTS TABLE - Add Archive Columns
-- ============================================
IF NOT EXISTS (SELECT 1 FROM sys.columns WHERE object_id = OBJECT_ID('Agents') AND name = 'IsArchived')
BEGIN
    ALTER TABLE Agents ADD IsArchived BIT NOT NULL DEFAULT 0;
    PRINT 'Added IsArchived to Agents table';
END
GO

IF NOT EXISTS (SELECT 1 FROM sys.columns WHERE object_id = OBJECT_ID('Agents') AND name = 'ArchivedAt')
BEGIN
    ALTER TABLE Agents ADD ArchivedAt DATETIME2 NULL;
    PRINT 'Added ArchivedAt to Agents table';
END
GO

IF NOT EXISTS (SELECT 1 FROM sys.columns WHERE object_id = OBJECT_ID('Agents') AND name = 'ArchivedBy')
BEGIN
    ALTER TABLE Agents ADD ArchivedBy NVARCHAR(100) NULL;
    PRINT 'Added ArchivedBy to Agents table';
END
GO

