/* Login Design - FiberHelp Style - Optimized for Desktop */

:root {
    --primary-blue: #2563eb;
    --primary-blue-dark: #1d4ed8;
    --light-blue: #93c5fd;
    --accent-cyan: #06b6d4;
    --success: #10b981;
    --danger: #ef4444;
    --bg-gray: #f8fafc;
    --card-white: #ffffff;
  --text-dark: #0f172a;
    --text-muted: #64748b;
    --border-gray: #e2e8f0;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
height: 100%;
    width: 100%;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
    background: var(--bg-gray);
    overflow: hidden;
}

body {
    display: flex;
}

#app {
    flex: 1;
    display: flex;
}

.login-wrapper {
    flex: 1;
    display: flex;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
}

.login-split {
    flex: 1;
    display: flex;
    height: 100vh;
}

/* Left Hero Panel - Modern Blue Gradient matching Dashboard */
.hero-panel {
    flex: 0 0 60%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 60px;
    background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
    color: #fff;
    position: relative;
    overflow-y: auto;
}

.hero-logo {
    height: 120px;
    width: 120px;
    background: #fff;
    border-radius: 28px;
    display: flex;
  align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
}

.hero-logo img {
    max-width: 70%;
    height: auto;
}

.hero-brand {
    font-size: 42px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-align: center;
    margin: 0 0 6px 0;
    line-height: 1.1;
}

.hero-tagline {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-align: center;
    margin-bottom: 36px;
    opacity: 0.95;
}

.hero-heading {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.1;
    text-align: center;
    margin: 0;
    color: #fff;
}

.hero-accent {
    font-size: 48px;
    font-weight: 800;
    line-height: 1.2;
    background: linear-gradient(90deg, #93c5fd, #60a5fa, #dbeafe);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    margin: 0 0 16px 0;
 text-align: center;
}

.hero-text {
    font-size: 17px;
    line-height: 1.5;
    font-weight: 600;
    max-width: 520px;
    text-align: center;
    margin: 0 auto 6px;
    opacity: 1;
}

.hero-description {
    font-size: 14px;
    line-height: 1.6;
    max-width: 520px;
    text-align: center;
    margin: 0 auto 32px;
    opacity: 0.95;
}

.stat-row {
    display: flex;
    gap: 24px;
    justify-content: center;
    margin-top: 12px;
}

.stat-box {
    flex: 0 0 180px;
    background: rgba(255, 255, 255, 0.15);
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    padding: 24px 18px 20px;
    text-align: center;
    transition: all 0.3s ease;
}

.stat-box:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
}

.stat-box h3 {
    margin: 0;
    font-size: 38px;
    font-weight: 800;
    line-height: 1;
}

.stat-box p {
    margin: 6px 0 0;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    opacity: 0.95;
}

/* Right Card Panel - 40% Width */
.login-container {
    flex: 0 0 40%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 30px;
    background: var(--bg-gray);
    overflow-y: auto;
}

.login-card {
    width: 100%;
    max-width: 440px;
    background: var(--card-white);
    border-radius: 20px;
    padding: 32px 30px 28px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    position: relative;
    animation: slideIn 0.4s ease;
}

.login-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 3px;
    border-radius: 3px 3px 0 0;
    background: linear-gradient(90deg, #2563eb, #3b82f6, #60a5fa);
}

.login-header {
    text-align: center;
    margin-bottom: 24px;
}

.login-header h1 {
    font-size: 28px;
    font-weight: 800;
    color: var(--text-dark);
    margin: 0 0 6px;
}

.login-header p {
    font-size: 13px;
    color: var(--text-muted);
}

.error-message {
  background: #fef2f2;
    color: #991b1b;
    padding: 10px 14px;
    border-radius: 10px;
  margin-bottom: 16px;
    font-size: 12.5px;
  border-left: 3px solid var(--danger);
    display: flex;
  align-items: center;
    gap: 8px;
}

.login-form {
    margin: 0;
}

.form-group {
 margin-bottom: 16px;
}

.form-group label {
    display: block;
    font-weight: 600;
    font-size: 13px;
    color: var(--text-dark);
    margin-bottom: 6px;
}

.input-wrapper {
    position: relative;
}

.input-icon {
    position: absolute;
    left: 12px;
 top: 50%;
    transform: translateY(-50%);
    font-size: 15px;
    color: var(--text-muted);
    pointer-events: none;
}

.form-input {
    width: 100%;
    padding: 11px 14px 11px 38px;
    border: 1.5px solid var(--border-gray);
    border-radius: 10px;
  font-size: 13px;
    background: #fff;
    transition: border 0.2s, box-shadow 0.2s;
    color: var(--text-dark);
}

.form-input:hover {
    border-color: #cbd5e1;
}

.form-input:focus {
    outline: none;
    border-color: var(--primary-blue);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.form-input::placeholder {
    color: var(--text-muted);
    font-size: 12.5px;
}

.toggle-password {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
border: none;
    cursor: pointer;
    font-size: 15px;
    padding: 4px;
    color: var(--text-muted);
 transition: color 0.2s ease;
}

.toggle-password:hover {
    color: var(--text-dark);
}

.form-options {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin: 6px 0 16px;
    font-size: 12px;
}

.checkbox-label {
    display: flex;
    align-items: center;
 gap: 6px;
    cursor: pointer;
    color: var(--text-dark);
}

.checkbox-label input {
    width: 16px;
    height: 16px;
    accent-color: var(--primary-blue);
    cursor: pointer;
}

.forgot-password {
    color: var(--primary-blue);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s ease;
}

.forgot-password:hover {
    opacity: 0.8;
}

.btn-login {
    width: 100%;
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-dark) 100%);
    color: #fff;
    border: none;
  padding: 12px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.btn-login:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(37, 99, 235, 0.4);
}

.btn-login:active:not(:disabled) {
    transform: translateY(0);
}

.btn-login:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
}

.btn-icon {
    font-size: 16px;
}

.divider {
    margin: 18px 0;
text-align: center;
    font-size: 11px;
    color: var(--text-muted);
    position: relative;
}

.divider::before,
.divider::after {
 content: "";
    position: absolute;
    top: 50%;
    width: calc(50% - 65px);
    height: 1px;
    background: var(--border-gray);
}

.divider::before {
    left: 0;
}

.divider::after {
    right: 0;
}

.btn-google {
    width: 100%;
    background: #fff;
    color: var(--text-dark);
    border: 1.5px solid var(--border-gray);
    padding: 10px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s ease;
    margin-bottom: 16px;
}

.btn-google:hover {
    background: var(--bg-gray);
    border-color: #cbd5e1;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.google-icon {
    width: 16px;
    height: 16px;
}

.register-link {
  text-align: center;
    margin-top: 14px;
    font-size: 12px;
}

.register-link p {
    color: var(--text-muted);
    margin: 0;
}

.register-link a {
    color: var(--primary-blue);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s ease;
}

.register-link a:hover {
opacity: 0.8;
}

.admin-link {
    text-align: center;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--border-gray);
}

.admin-link a {
    color: var(--text-muted);
    text-decoration: none;
  font-size: 11.5px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: color 0.2s ease;
}

.admin-link a:hover {
    color: var(--text-dark);
}

.pw-requirements {
    display: flex;
    flex-direction: column;
 gap: 5px;
    margin: -4px 0 14px;
    font-size: 11px;
}

.req {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    border-radius: 7px;
    background: #f8fafc;
    color: var(--text-muted);
    border: 1px solid #f0f3f5;
    font-weight: 600;
 transition: all 0.2s ease;
}

.req.valid {
    color: var(--success);
    background: #ecfdf5;
  border-color: rgba(16, 185, 129, 0.2);
}

.req.invalid {
    color: var(--danger);
    background: #fff6f6;
    border-color: rgba(239, 68, 68, 0.2);
}

@keyframes slideIn {
    from {
        opacity: 0;
   transform: translateY(15px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Desktop Optimization - Wide Screens */
@media (min-width: 1400px) {
    .hero-panel {
     padding: 50px 80px;
    }
    
    .hero-brand {
        font-size: 48px;
    }
    
    .hero-heading,
    .hero-accent {
font-size: 54px;
    }
    
    .login-container {
        padding: 40px;
    }
    
    .login-card {
   max-width: 480px;
    padding: 36px 34px 32px;
    }
}

/* Laptop/Standard Desktop */
@media (max-width: 1399px) and (min-width: 1200px) {
    .hero-brand {
        font-size: 38px;
    }
    
    .hero-heading,
    .hero-accent {
        font-size: 44px;
    }
}

/* Smaller Desktop/Tablet Landscape */
@media (max-width: 1199px) {
    .login-split {
        flex-direction: column;
    }
    
    .hero-panel {
 flex: 0 0 auto;
        min-height: 50vh;
        padding: 40px 30px;
    }
    
    .login-container {
        flex: 0 0 auto;
        min-height: 50vh;
        width: 100%;
    }
    
    .hero-logo {
        height: 100px;
      width: 100px;
    }
    
    .hero-brand {
 font-size: 32px;
    }
    
    .hero-heading,
    .hero-accent {
        font-size: 38px;
    }
}

/* Tablet Portrait */
@media (max-width: 768px) {
    .hero-panel {
        padding: 30px 24px;
    }
    
    .hero-brand {
        font-size: 28px;
    }
    
    .hero-heading,
    .hero-accent {
        font-size: 32px;
    }
    
    .login-card {
        padding: 28px 24px;
    }
    
    .stat-row {
   flex-direction: column;
        gap: 16px;
    }
    
    .stat-box {
        width: 100%;
        max-width: 240px;
    }
}

/* Mobile */
@media (max-width: 480px) {
    .hero-logo {
        height: 80px;
        width: 80px;
    }
    
    .hero-brand {
        font-size: 24px;
    }
    
    .hero-tagline {
        font-size: 9px;
    }
    
    .hero-heading,
  .hero-accent {
        font-size: 28px;
    }
    
    .login-card {
        padding: 24px 20px;
    }
    
    .login-header h1 {
        font-size: 24px;
    }
}