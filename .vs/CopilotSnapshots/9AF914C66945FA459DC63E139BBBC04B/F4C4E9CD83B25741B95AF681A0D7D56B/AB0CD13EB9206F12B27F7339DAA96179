using System;
using System.Threading.Tasks;
using FiberHelp.Data;
using Microsoft.EntityFrameworkCore;
using System.Security.Cryptography;
using System.Text;
using Microsoft.Extensions.DependencyInjection;
using FiberHelp.Data.context;
using System.Linq;

namespace FiberHelp.Services
{
    public class AuthService
    {
        private readonly IServiceProvider _serviceProvider;
     
        public AuthService(IServiceProvider serviceProvider) 
    { 
         _serviceProvider = serviceProvider; 
        }

        public bool IsAuthenticated { get; private set; }
        public string? Email { get; private set; }
        public string? Role { get; private set; }
        public string? FullName { get; private set; }

        public event Action? AuthenticationStateChanged;

        private static string HashPassword(string password)
        {
            using var sha = SHA256.Create();
            var bytes = Encoding.UTF8.GetBytes(password ?? string.Empty);
            var hash = sha.ComputeHash(bytes);
            return Convert.ToHexString(hash);
        }

        public async Task<bool> SignInAsync(string email, string password)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
                {
                    return false;
                }

                using var scope = _serviceProvider.CreateScope();
                var _db = scope.ServiceProvider.GetRequiredService<localContext>();

                // Ensure defaults exist locally
                try { DbInitializer.Initialize(_db); } catch { }

                var lowered = email.Trim().ToLowerInvariant();
                var hashed = HashPassword(password);

                // Try DB-side lookup (SQLite-safe)
                var user = await _db.Users.AsNoTracking()
                    .FirstOrDefaultAsync(u => EF.Functions.Like(u.Email, lowered));

                // Fallback: in-memory case-insensitive match if provider/translation behaves unexpectedly
                if (user == null)
                {
                    user = await _db.Users.AsNoTracking().ToListAsync()
                        .ContinueWith(t => t.Result.FirstOrDefault(u => string.Equals(u.Email, email.Trim(), StringComparison.OrdinalIgnoreCase)));
                }

                if (user != null)
                {
                    if (!string.Equals(user.PasswordHash, hashed, StringComparison.Ordinal))
                    {
                        return false;
                    }

                    IsAuthenticated = true;
                    Email = user.Email;
                    Role = user.Role;
                    FullName = user.FullName;
                    AuthenticationStateChanged?.Invoke();
                    return true;
                }

                // Agents lookup
                var agent = await _db.Agents
                    .FirstOrDefaultAsync(a => EF.Functions.Like(a.Email, lowered));

                if (agent == null)
                {
                    agent = await _db.Agents.ToListAsync()
                        .ContinueWith(t => t.Result.FirstOrDefault(a => string.Equals(a.Email, email.Trim(), StringComparison.OrdinalIgnoreCase))).ConfigureAwait(false);
                }

                if (agent != null)
                {
                    if (!agent.IsActive || agent.IsLocked)
                    {
                        return false;
                    }

                    if (!string.Equals(agent.PasswordHash, hashed, StringComparison.Ordinal))
                    {
                        agent.FailedLoginCount++;
                        if (agent.FailedLoginCount >= 5) agent.IsLocked = true;
                        await _db.SaveChangesAsync();
                        return false;
                    }

                    agent.FailedLoginCount = 0;
                    agent.LastLoginAt = DateTime.UtcNow;
                    await _db.SaveChangesAsync();

                    IsAuthenticated = true;
                    Email = agent.Email;
                    Role = "Agent";
                    FullName = agent.FullName;
                    AuthenticationStateChanged?.Invoke();
                    return true;
                }

                return false;
            }
            catch
            {
                return false;
            }
        }

        public void SignOut()
        {
            IsAuthenticated = false;
            Email = null;
            Role = null;
            FullName = null;
            AuthenticationStateChanged?.Invoke();
        }
    }
}
