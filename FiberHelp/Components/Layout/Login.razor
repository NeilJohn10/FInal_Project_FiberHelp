@* Login.razor *@
@page "/login"
@layout FiberHelp.Components.Layout.EmptyLayout
@implements IDisposable
@inject NavigationManager NavigationManager
@inject FiberHelp.Services.AuthService AuthService
@using System.Linq

<PageTitle>Login - FiberHelp</PageTitle>
<link href="css/login.css" rel="stylesheet" />

<div class="login-wrapper">
  <div class="login-split">
     <div class="hero-panel">
 <div class="hero-logo">
  <img src="css/bootstrap/Logo.png" alt="FiberHelp" />
      </div>
      <h2 class="hero-brand">FIBERHELP</h2>
       <p class="hero-tagline">YOUR CONNECTION. OUR PRIORITY</p>
 <h1 class="hero-heading">Connect with</h1>
<h1 class="hero-accent">Confidence</h1>
 <p class="hero-text">Your trusted partner in reliable fiber internet service</p>
    <p class="hero-description">Experience exceptional support with our modern facilities, expert team, and personalized solutions designed just for you.</p>
 <div class="stat-row">
         <div class="stat-box">
          <h3>500+</h3>
     <p>Happy Customers</p>
     </div>
       <div class="stat-box">
       <h3>15+</h3>
  <p>Years Experience</p>
       </div>
            </div>
        </div>

        <div class="login-container">
        <div class="login-card show">
     <div class="login-header">
 <h1>Welcome Back</h1>
    <p>Sign in to your account</p>
       </div>

      @if(!string.IsNullOrEmpty(errorMessage))
   {
     <div class="error-message">
       @errorMessage
       @if (lockoutCountdown != null && isLockedOut)
       {
         <div style="margin-top:8px;font-weight:700;font-size:16px;color:#7f1d1d;text-align:center">
           &#9203; @lockoutCountdown
         </div>
       }
     </div>
   }

 @if (!showForgotPassword)
 {
 <div class="login-form">
  <div class="form-group">
   <label for="email">Email Address</label>
    <div class="input-wrapper">
 <span class="input-icon">
   <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
     <rect x="3" y="5" width="18" height="14" rx="2" />
     <path d="M3 7l9 6 9-6" />
   </svg>
 </span>
     <input type="email" id="email" class="form-input" placeholder="your.email@example.com" @bind="Email" @bind:event="oninput" required />
  </div>
 </div>

 <div class="form-group">
     <label for="password">Password</label>
  <div class="input-wrapper">
  <span class="input-icon">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="3" y="11" width="18" height="10" rx="2" />
      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </svg>
  </span>
          <input type="@(showPassword ? "text" : "password")" id="password" class="form-input" placeholder="Enter your password" @bind="Password" @bind:event="oninput" required />
   <button type="button" class="toggle-password" aria-label="Toggle password visibility" @onclick="ToggleShowPassword">
     @if(showPassword)
     {
       <!-- eye-off icon -->
       <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
         <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-7 0-11-7-11-7a20.6 20.6 0 0 1 5.06-5.94" />
         <path d="M1 1l22 22" />
       </svg>
     }
     else
     {
       <!-- eye icon -->
       <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
         <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z" />
         <circle cx="12" cy="12" r="3" />
       </svg>
     }
   </button>
     </div>
  </div>

    @if(attemptedSignIn && !IsPasswordValid())
         {
      <div class="pw-requirements">
       <div class="@ReqClass(hasMinLength)"><span>@CheckMark(hasMinLength)</span><span>8+ characters</span></div>
   <div class="@ReqClass(hasUpper)"><span>@CheckMark(hasUpper)</span><span>Uppercase letter</span></div>
  <div class="@ReqClass(hasDigit)"><span>@CheckMark(hasDigit)</span><span>Number</span></div>
   <div class="@ReqClass(hasSpecial)"><span>@CheckMark(hasSpecial)</span><span>Special character</span></div>
    </div>
    }

    <div class="form-group captcha-group">
        <div class="recaptcha-box @(captchaVerified ? "verified" : "") @(showCaptchaError ? "error" : "")">
            <div class="recaptcha-left">
                <div class="recaptcha-checkbox-wrap" @onclick="HandleCaptchaClick">
                    @if (captchaVerifying)
                    {
                        <div class="recaptcha-spinner"></div>
                    }
                    else if (captchaVerified)
                    {
                        <div class="recaptcha-checkmark">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00a854" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                        </div>
                    }
                    else
                    {
                        <div class="recaptcha-unchecked"></div>
                    }
                </div>
                <span class="recaptcha-label">I'm not a robot</span>
            </div>
            <div class="recaptcha-right">
                <div class="recaptcha-logo">
                    <svg width="26" height="26" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                        <path d="M32 2L4 17v15c0 16.6 11.9 32.1 28 35 16.1-2.9 28-18.4 28-35V17L32 2z" fill="#4285f4" opacity="0.2"/>
                        <path d="M32 8L10 20v12c0 13.8 9.4 26.7 22 29 12.6-2.3 22-15.2 22-29V20L32 8z" fill="#4285f4" opacity="0.3"/>
                        <path d="M27 34l-7-7 3-3 4 4 10-10 3 3-13 13z" fill="#4285f4"/>
                    </svg>
                </div>
                <div class="recaptcha-brand">
                    <span class="recaptcha-title">reCAPTCHA</span>
                    <span class="recaptcha-terms">Privacy - Terms</span>
                </div>
            </div>
        </div>
        @if (showCaptchaError)
        {
            <div class="captcha-error">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;">
                    <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
                </svg>
                Please verify that you are not a robot.
            </div>
        }
    </div>

    <div class="form-options">
       <label class="checkbox-label">
   <input type="checkbox" @bind="rememberMe" />
       <span>Remember me</span>
   </label>
          <a href="#" class="forgot-password" @onclick:preventDefault="true" @onclick="ShowForgotPassword">Forgot Password?</a>
      </div>

   <button type="button" class="btn-login" disabled="@(isLoading || isLockedOut || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))" @onclick="HandleLogin">
         @if(isLoading)
  {
   <span>Logging in...</span>
       }
          else
        {
   <span class="btn-icon">
     <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
       <circle cx="12" cy="12" r="9" />
       <path d="M12 7v5l3 2" />
     </svg>
   </span>
     <span>Access My Portal</span>
   }
   </button>

      <div class="admin-link">
       <a href="#">
 <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
 </svg> 
         Staff / Admin Login
      </a>
  </div>
    </div>
 }
 else
 {
   <div class="login-form">
     @if (!string.IsNullOrWhiteSpace(forgotMessage))
     {
       <div class="error-message" style="background:#ecfdf3;border-color:#86efac;color:#166534;">@forgotMessage</div>
     }

     <div class="form-group">
       <label for="reset-email">Email Address</label>
       <div class="input-wrapper">
         <input type="email" id="reset-email" class="form-input" placeholder="your.email@example.com" @bind="resetEmail" @bind:event="oninput" />
       </div>
     </div>

     @if (resetCodeSent)
     {
       <div class="form-group">
         <label for="reset-code">Reset Code</label>
         <div class="input-wrapper">
           <input type="text" id="reset-code" class="form-input" placeholder="Enter 6-digit code" @bind="resetCode" @bind:event="oninput" maxlength="6" />
         </div>
       </div>

       <div class="form-group">
         <label for="reset-new-password">New Password</label>
         <div class="input-wrapper">
           <input type="password" id="reset-new-password" class="form-input" placeholder="Enter new password" @bind="resetNewPassword" @bind:event="oninput" />
         </div>
       </div>

       <div class="form-group">
         <label for="reset-confirm-password">Confirm Password</label>
         <div class="input-wrapper">
           <input type="password" id="reset-confirm-password" class="form-input" placeholder="Confirm new password" @bind="resetConfirmPassword" @bind:event="oninput" />
         </div>
       </div>
     }

     <button type="button" class="btn-login" disabled="@isResetLoading" @onclick="(resetCodeSent ? ResetPassword : SendResetCode)">
       <span>@(isResetLoading ? "Please wait..." : resetCodeSent ? "Reset Password" : "Send Reset Code")</span>
     </button>

     <div class="admin-link" style="margin-top:14px;">
       <a href="#" @onclick:preventDefault="true" @onclick="BackToLogin">Back to Login</a>
     </div>
   </div>
 }
   </div>
        </div>
    </div>
</div>

@code {
    private string _email="";
    private string _password=string.Empty;
    private bool rememberMe=false;
    private bool isLoading=false;
    private string errorMessage="";
    private bool hasMinLength=false;
    private bool hasUpper=false;
    private bool hasDigit=false;
    private bool hasSpecial=false;
    private bool attemptedSignIn=false;
    private bool showPassword = false;
    private bool showForgotPassword = false;
    private bool resetCodeSent = false;
    private bool isResetLoading = false;
    private string resetEmail = string.Empty;
    private string resetCode = string.Empty;
    private string resetNewPassword = string.Empty;
    private string resetConfirmPassword = string.Empty;
    private string forgotMessage = string.Empty;

    // CAPTCHA state
    private bool captchaVerified = false;
    private bool captchaVerifying = false;
    private bool showCaptchaError = false;

    // Lockout countdown — per email
    private string? lockedEmail = null;
    private DateTime? lockoutExpiry = null;
    private string? lockoutCountdown = null;
    private bool isLockedOut => lockedEmail != null 
        && string.Equals(_email.Trim(), lockedEmail, StringComparison.OrdinalIgnoreCase) 
        && lockoutExpiry.HasValue && DateTime.UtcNow < lockoutExpiry.Value;
    private System.Threading.Timer? countdownTimer;

    private string Email
    {
        get => _email;
        set
        {
            _email = value ?? string.Empty;
            // If user changes to a different email, hide lockout UI
            if (lockedEmail != null && !string.Equals(_email.Trim(), lockedEmail, StringComparison.OrdinalIgnoreCase))
            {
                errorMessage = string.Empty;
                lockoutCountdown = null;
            }
        }
    }

    public void Dispose()
    {
        countdownTimer?.Dispose();
    }

    private void StartLockoutCountdown(DateTime expiryUtc, string emailLocked)
    {
        lockedEmail = emailLocked.Trim().ToLowerInvariant();
        lockoutExpiry = expiryUtc;
        countdownTimer?.Dispose();
        countdownTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                if (lockoutExpiry == null) return;
                var remaining = lockoutExpiry.Value - DateTime.UtcNow;
                if (remaining.TotalSeconds <= 0)
                {
                    // Lockout expired
                    lockoutCountdown = null;
                    lockoutExpiry = null;
                    lockedEmail = null;
                    errorMessage = "Suspension expired. You can try logging in again.";
                    countdownTimer?.Dispose();
                    countdownTimer = null;
                }
                else
                {
                    var mins = (int)remaining.TotalMinutes;
                    var secs = remaining.Seconds;
                    lockoutCountdown = $"{mins:D2}:{secs:D2}";
                }
                StateHasChanged();
            });
        }, null, 0, 1000);
    }

    private string Password
    {
        get=>_password;
      set
        {
    _password=value??string.Empty;
    hasMinLength=_password.Length>=8;
            hasUpper=_password.Any(char.IsUpper);
hasDigit=_password.Any(char.IsDigit);
   hasSpecial=_password.Any(c=>!char.IsLetterOrDigit(c));
   }
    }

private bool IsPasswordValid()=>hasMinLength&&hasUpper&&hasDigit&&hasSpecial;
    private string ReqClass(bool ok)=>ok?"req valid":"req invalid";
    private string CheckMark(bool ok)=>ok?"✔":"✖";

    private async Task HandleCaptchaClick()
    {
        if (captchaVerified || captchaVerifying) return;

        showCaptchaError = false;
        captchaVerifying = true;
        StateHasChanged();

        // Simulate verification delay like Google reCAPTCHA
        await Task.Delay(new Random().Next(800, 1800));

        captchaVerifying = false;
        captchaVerified = true;
        StateHasChanged();
    }

    private async Task HandleLogin()
    {
        attemptedSignIn = true;
        errorMessage = string.Empty;
        showCaptchaError = false;
        StateHasChanged();

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            errorMessage = "Email and password required.";
            return;
        }

        // Validate CAPTCHA
        if (!captchaVerified)
        {
            showCaptchaError = true;
            StateHasChanged();
            return;
        }

        if (!IsPasswordValid())
        {
            // soft-warn but continue
        }

        isLoading = true;
        StateHasChanged();

        var ok = await AuthService.SignInAsync(_email.Trim(), _password);
        isLoading = false;

        if (ok)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        // Show specific error from AuthService if available
        errorMessage = !string.IsNullOrEmpty(AuthService.LastLoginError) 
            ? AuthService.LastLoginError 
            : "Invalid credentials.";

        // Start countdown timer if account is locked out
        if (AuthService.LockoutExpiresAt.HasValue && AuthService.LockoutExpiresAt.Value > DateTime.UtcNow)
        {
            StartLockoutCountdown(AuthService.LockoutExpiresAt.Value, _email);
        }

        _password = "";
        hasMinLength = hasUpper = hasDigit = hasSpecial = false;
        attemptedSignIn = false;
        captchaVerified = false; // Reset captcha on failed login
        StateHasChanged();
    }

    private void ToggleShowPassword()
    {
        showPassword = !showPassword;
    }

    private void ShowForgotPassword()
    {
        showForgotPassword = true;
        forgotMessage = string.Empty;
        resetCodeSent = false;
        resetEmail = _email;
        resetCode = string.Empty;
        resetNewPassword = string.Empty;
        resetConfirmPassword = string.Empty;
    }

    private void BackToLogin()
    {
        showForgotPassword = false;
        forgotMessage = string.Empty;
        resetCodeSent = false;
    }

    private async Task SendResetCode()
    {
        forgotMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(resetEmail))
        {
            forgotMessage = "Please enter your email.";
            return;
        }

        isResetLoading = true;
        var result = await AuthService.RequestPasswordResetAsync(resetEmail);
        isResetLoading = false;

        forgotMessage = result.Message;
        if (result.Success)
            resetCodeSent = true;

        StateHasChanged();
    }

    private async Task ResetPassword()
    {
        forgotMessage = string.Empty;
        if (!resetCodeSent)
            return;

        if (!string.Equals(resetNewPassword, resetConfirmPassword, StringComparison.Ordinal))
        {
            forgotMessage = "New password and confirm password do not match.";
            return;
        }

        isResetLoading = true;
        var result = await AuthService.ResetPasswordAsync(resetEmail, resetCode, resetNewPassword);
        isResetLoading = false;

        forgotMessage = result.Message;
        if (result.Success)
        {
            resetCodeSent = false;
            resetCode = string.Empty;
            resetNewPassword = string.Empty;
            resetConfirmPassword = string.Empty;
        }

        StateHasChanged();
    }
}
