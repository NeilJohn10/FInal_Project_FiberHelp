@page "/"
@using FiberHelp.Models
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.AdminService AdminService
@inject NavigationManager Navigation

<PageTitle>Dashboard - FiberHelp</PageTitle>

<link href="css/home.css" rel="stylesheet" />

<div class="app-shell">
 <!-- LEFT SIDEBAR -->
 <aside class="sidebar">
 <div class="brand">
 <img src="css/bootstrap/Logo.png" alt="FiberHelp" class="brand-logo" />
 <span>FIBERHELP</span>
 </div>

 <div class="sidebar-group">
 <button class="sidebar-btn @(currentPage == "dashboard" ? "active" : "")" @onclick="ShowDashboard">
 <span class="icon">🏠</span>
 <span>Dashboard</span>
 </button>
 <button class="sidebar-btn @(currentPage == "tickets" ? "active" : "")" @onclick="ShowTickets">
 <span class="icon">🎫</span>
 <span>Tickets</span>
 </button>
 <button class="sidebar-btn @(currentPage == "customers" ? "active" : "")" @onclick="ShowCustomers">
 <span class="icon">👥</span>
 <span>Customers</span>
 </button>
 <button class="sidebar-btn @(currentPage == "billing" ? "active" : "")" @onclick="ShowBilling">
 <span class="icon">💳</span>
 <span>Billing</span>
 </button>
 <button class="sidebar-btn @(currentPage == "reports" ? "active" : "")" @onclick="ShowReports">
 <span class="icon">📊</span>
 <span>Reports</span>
 </button>
 </div>

 <div class="sidebar-group muted">
 <button class="sidebar-btn @(currentPage == "settings" ? "active" : "")" @onclick="ShowSettings">
 <span class="icon">⚙️</span>
 <span>Settings</span>
 </button>
 <button class="sidebar-btn danger" @onclick="HandleLogout">
 <span class="icon">↩️</span>
 <span>Logout</span>
 </button>
 </div>
 </aside>

 <!-- MAIN CONTENT -->
 <main class="main">
 <div class="main-inner">
 @if (currentPage == "dashboard")
 {
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Dashboard</h1>
 </div>
 <div class="top-actions">
 <button class="btn subtle" @onclick="ExportData">Export</button>
 <button class="btn primary" @onclick="() => ShowNewTicket(true)">+ New Ticket</button>
 <div class="user-pill">
 <div class="avatar">FH</div>
 <div class="user-meta">
 <p class="user-email">@AuthService.Email ?? "(not signed in)"</p>
 <p class="user-role">@AuthService.Role ?? "Guest"</p>
 </div>
 </div>
 </div>
 </header>

 <section class="kpi-grid">
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Total Customers</span>
 <span class="badge success">@((customers?.Count ??0) >0 ? "+" + ((customers.Count/10.0).ToString("0.0")) + "%" : "0%")</span>
 </div>
 <h2>@(customers?.Count ??0)</h2>
 <p class="kpi-sub">sample trend only</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Active Subscriptions</span>
 <span class="badge success">+2.1%</span>
 </div>
 <h2>94</h2>
 <p class="kpi-sub">active this month</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Open Tickets</span>
 <span class="badge warning">@((tickets?.Count(t => t.Status == "Open") ??0) + " high")</span>
 </div>
 <h2>@(tickets?.Count ??0)</h2>
 <p class="kpi-sub">need agent response</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Pending Invoices</span>
 <span class="badge danger">follow up</span>
 </div>
 <h2>₱30,000</h2>
 <p class="kpi-sub">unpaid amount</p>
 </article>
 </section>

 <section class="body-grid">
 <div class="panel">
 <div class="panel-head">
 <div>
 <h2>Latest Tickets</h2>
 <p class="muted-text">Most recent customer issues</p>
 </div>
 <div class="filter-pill">This week</div>
 </div>

 <table class="data-table">
 <thead>
 <tr>
 <th>Ticket #</th>
 <th>Account</th>
 <th>Subject</th>
 <th>Status</th>
 <th>Created</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @if (tickets != null)
 {
 foreach (var t in tickets.Take(4))
 {
 <tr>
 <td>@t.Id</td>
 <td>@t.Customer</td>
 <td>@t.Title</td>
 <td>
 <span class="status-pill @t.Status.ToLower().Replace(" ", "")">@t.Status</span>
 </td>
 <td>@GetTimeAgo(t.Created)</td>
 <td>
 <button class="btn subtle" @onclick="() => EditTicket(t.Id)">Edit</button>
 <button class="btn danger" @onclick="() => DeleteTicket(t.Id)">Delete</button>
 </td>
 </tr>
 }
 }
 </tbody>
 </table>
 </div>

 <div class="panel">
 <div class="panel-head">
 <h2>Today's Activity</h2>
 <p class="muted-text">Recent actions</p>
 </div>
 <ul class="activity-list">
 <li class="activity success">
 <span class="dot"></span>
 Ticket #7004 assigned to <strong>CSR-01</strong>
 <span class="time">10 mins ago</span>
 </li>
 <li class="activity warning">
 <span class="dot"></span>
 New customer registered: <strong>Kisha Tan</strong>
 <span class="time">25 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
 Invoice reminder sent to <strong>Fiber Corp</strong>
 <span class="time">35 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
2 tickets waiting for update
 <span class="time">1 hr ago</span>
 </li>
 </ul>
 </div>
 </section>
 }
 else if (currentPage == "tickets")
 {
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Tickets</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary" @onclick="() => ShowNewTicket(true)">+ New Ticket</button>
 </div>
 </header>
 <section class="panel">
 <table class="data-table">
 <thead>
 <tr>
 <th>Ticket ID</th>
 <th>Title</th>
 <th>Customer</th>
 <th>Priority</th>
 <th>Status</th>
 <th>Created</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @if (tickets != null)
 {
 foreach (var ticket in tickets)
 {
 <tr>
 <td>@ticket.Id</td>
 <td>@ticket.Title</td>
 <td>@ticket.Customer</td>
 <td><span class="status-pill priority">@ticket.Priority</span></td>
 <td><span class="status-pill @ticket.Status.ToLower().Replace(" ", "")">@ticket.Status</span></td>
 <td>@GetTimeAgo(ticket.Created)</td>
 <td>
 <button class="btn subtle" @onclick="() => EditTicket(ticket.Id)">Edit</button>
 <button class="btn danger" @onclick="() => DeleteTicket(ticket.Id)">Delete</button>
 </td>
 </tr>
 }
 }
 </tbody>
 </table>
 </section>
 }
 else if (currentPage == "customers")
 {
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Customers</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary" @onclick="() => ShowNewCustomer(true)">+ Add Customer</button>
 </div>
 </header>
 <section class="panel">
 <table class="data-table">
 <thead>
 <tr>
 <th>Customer ID</th>
 <th>Name</th>
 <th>Email</th>
 <th>Plan</th>
 <th>Status</th>
 <th>Join Date</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @if (customers != null)
 {
 foreach (var customer in customers)
 {
 <tr>
 <td>@customer.Id</td>
 <td>@customer.Name</td>
 <td>@customer.Email</td>
 <td>@customer.Plan</td>
 <td><span class="status-pill @customer.Status.ToLower()">@customer.Status</span></td>
 <td>@customer.JoinDate.ToString("MMM dd, yyyy")</td>
 <td>
 <button class="btn subtle" @onclick="() => EditCustomer(customer.Id)">Edit</button>
 <button class="btn danger" @onclick="() => DeleteCustomer(customer.Id)">Delete</button>
 </td>
 </tr>
 }
 }
 </tbody>
 </table>
 </section>
 }
 else
 {
 <header class="topbar">
 <h1 class="page-title">@currentPage</h1>
 </header>
 <section class="panel">
 <p>Placeholder for @currentPage page.</p>
 </section>
 }
 </div>
 </main>
</div>

<!-- New Ticket Modal -->
@if (showNewTicketModal)
{
 <div class="modal-backdrop">
 <div class="modal">
 <h3>New Ticket</h3>
 <div class="form-group">
 <label>Title</label>
 <input class="form-input" @bind="newTicketTitle" />
 </div>
 <div class="form-group">
 <label>Customer</label>
 <select class="form-input" @bind="newTicketCustomer">
 <option value="">Select customer</option>
 @if (customers != null)
 {
 foreach (var c in customers)
 {
 <option value="@c.Name">@c.Name</option>
 }
 }
 </select>
 </div>
 <div class="form-group">
 <label>Priority</label>
 <select class="form-input" @bind="newTicketPriority">
 <option>Low</option>
 <option>Medium</option>
 <option>High</option>
 </select>
 </div>
 <div class="form-group">
 <label>Status</label>
 <select class="form-input" @bind="newTicketStatus">
 <option>Open</option>
 <option>In-Progress</option>
 <option>Resolved</option>
 <option>Closed</option>
 </select>
 </div>
 <div class="modal-actions">
 <button class="btn" @onclick="() => ShowNewTicket(false)">Cancel</button>
 <button class="btn primary" @onclick="CreateNewTicketAsync">Create</button>
 </div>
 </div>
 </div>
}

<!-- New Customer Modal -->
@if (showNewCustomerModal)
{
 <div class="modal-backdrop">
 <div class="modal">
 <h3>New Customer</h3>
 <div class="form-group">
 <label>Name</label>
 <input class="form-input" @bind="newCustomerName" />
 </div>
 <div class="form-group">
 <label>Email</label>
 <input class="form-input" @bind="newCustomerEmail" />
 </div>
 <div class="form-group">
 <label>Plan</label>
 <input class="form-input" @bind="newCustomerPlan" />
 </div>
 <div class="modal-actions">
 <button class="btn" @onclick="() => ShowNewCustomer(false)">Cancel</button>
 <button class="btn primary" @onclick="CreateNewCustomerAsync">Add</button>
 </div>
 </div>
 </div>
}

@code {
 private string currentPage = "dashboard";

 private List<Ticket>? tickets;
 private List<Customer>? customers;

 // New ticket state
 private bool showNewTicketModal = false;
 private string newTicketTitle = "";
 private string newTicketCustomer = "";
 private string newTicketPriority = "Medium";
 private string newTicketStatus = "Open";

 // New customer state
 private bool showNewCustomerModal = false;
 private string newCustomerName = "";
 private string newCustomerEmail = "";
 private string newCustomerPlan = "";

 protected override async Task OnInitializedAsync()
 {
 await LoadDataAsync();
 }

 private async Task LoadDataAsync()
 {
 tickets = await AdminService.GetTicketsAsync();
 customers = await AdminService.GetCustomersAsync();
 StateHasChanged();
 }

 private void ShowDashboard() => currentPage = "dashboard";
 private void ShowTickets() => currentPage = "tickets";
 private void ShowCustomers() => currentPage = "customers";
 private void ShowBilling() => currentPage = "billing";
 private void ShowReports() => currentPage = "reports";
 private void ShowSettings() => currentPage = "settings";

 private void HandleLogout()
 {
 AuthService.SignOut();
 Navigation.NavigateTo("/login", true);
 }

 private string GetTimeAgo(DateTime date)
 {
 var span = DateTime.Now - date;
 if (span.TotalMinutes <60) return $"{(int)span.TotalMinutes} mins ago";
 if (span.TotalHours <24) return $"{(int)span.TotalHours} hrs ago";
 return $"{(int)span.TotalDays} days ago";
 }

 private void ShowNewTicket(bool show)
 {
 showNewTicketModal = show;
 if (!show) ClearNewTicketForm();
 }

 private void ShowNewCustomer(bool show)
 {
 showNewCustomerModal = show;
 if (!show) ClearNewCustomerForm();
 }

 private void ClearNewTicketForm()
 {
 newTicketTitle = "";
 newTicketCustomer = "";
 newTicketPriority = "Medium";
 newTicketStatus = "Open";
 }

 private void ClearNewCustomerForm()
 {
 newCustomerName = "";
 newCustomerEmail = "";
 newCustomerPlan = "";
 }

 private async Task CreateNewTicketAsync()
 {
 if (string.IsNullOrWhiteSpace(newTicketTitle) || string.IsNullOrWhiteSpace(newTicketCustomer))
 {
 // You could show validation feedback here
 return;
 }

 var t = new Ticket
 {
 Title = newTicketTitle,
 Customer = newTicketCustomer,
 Priority = newTicketPriority,
 Status = newTicketStatus,
 Created = DateTime.UtcNow
 };

 await AdminService.CreateTicketAsync(t);
 await LoadDataAsync();
 ShowNewTicket(false);
 }

 private async Task CreateNewCustomerAsync()
 {
 if (string.IsNullOrWhiteSpace(newCustomerName) || string.IsNullOrWhiteSpace(newCustomerEmail))
 return;

 var c = new Customer
 {
 Name = newCustomerName,
 Email = newCustomerEmail,
 Plan = newCustomerPlan,
 JoinDate = DateTime.UtcNow,
 Status = "Active"
 };

 await AdminService.CreateCustomerAsync(c);
 await LoadDataAsync();
 ShowNewCustomer(false);
 }

 private async Task DeleteTicket(string id)
 {
 if (string.IsNullOrEmpty(id)) return;
 await AdminService.DeleteTicketAsync(id);
 await LoadDataAsync();
 }

 private async Task DeleteCustomer(string id)
 {
 if (string.IsNullOrEmpty(id)) return;
 await AdminService.DeleteCustomerAsync(id);
 await LoadDataAsync();
 }

 private void EditTicket(string id)
 {
 // For minimal implementation redirect to tickets page and open modal or implement full edit page.
 // Here we simply select tickets page and you can extend to open an edit form.
 currentPage = "tickets";
 }

 private void EditCustomer(string id)
 {
 currentPage = "customers";
 }

 private void ExportData()
 {
 // Placeholder export behavior: navigate to a route or implement export logic.
 // For now show customers page as a simple action.
 currentPage = "customers";
 }
}
