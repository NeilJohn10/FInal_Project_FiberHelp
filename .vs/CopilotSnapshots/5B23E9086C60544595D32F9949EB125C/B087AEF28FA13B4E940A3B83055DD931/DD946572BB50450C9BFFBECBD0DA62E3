@page "/"
@using FiberHelp.Models
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.AdminService AdminService
@inject NavigationManager Navigation

<div>
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Dashboard</h1>
 </div>
 <div class="top-actions">
 <button class="btn subtle" @onclick="ExportData">Export</button>
 <button class="btn primary" @onclick="() => ShowNewTicket(true)">+ New Ticket</button>
 <div class="user-pill">
 <div class="avatar">FH</div>
 <div class="user-meta">
 <p class="user-email">@AuthService.Email ?? "(not signed in)"</p>
 <p class="user-role">@AuthService.Role ?? "Guest"</p>
 </div>
 </div>
 </div>
 </header>

 <section class="kpi-grid">
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Total Customers</span>
 <span class="badge success">@((customers?.Count ??0) >0 ? "+" + ((customers.Count/10.0).ToString("0.0")) + "%" : "0%")</span>
 </div>
 <h2>@(customers?.Count ??0)</h2>
 <p class="kpi-sub">sample trend only</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Active Subscriptions</span>
 <span class="badge success">+2.1%</span>
 </div>
 <h2>94</h2>
 <p class="kpi-sub">active this month</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Open Tickets</span>
 <span class="badge warning">@((tickets?.Count(t => t.Status == "Open") ??0) + " high")</span>
 </div>
 <h2>@(tickets?.Count ??0)</h2>
 <p class="kpi-sub">need agent response</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Pending Invoices</span>
 <span class="badge danger">follow up</span>
 </div>
 <h2>₱30,000</h2>
 <p class="kpi-sub">unpaid amount</p>
 </article>
 </section>

 <section class="body-grid">
 <div class="panel">
 <div class="panel-head">
 <div>
 <h2>Latest Tickets</h2>
 <p class="muted-text">Most recent customer issues</p>
 </div>
 <div class="filter-pill">This week</div>
 </div>

 <table class="data-table">
 <thead>
 <tr>
 <th>Ticket #</th>
 <th>Account</th>
 <th>Subject</th>
 <th>Status</th>
 <th>Created</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @if (tickets != null)
 {
 foreach (var t in tickets.Take(4))
 {
 <tr>
 <td>@t.Id</td>
 <td>@t.Customer</td>
 <td>@t.Title</td>
 <td>
 <span class="status-pill @t.Status.ToLower().Replace(" ", "")">@t.Status</span>
 </td>
 <td>@GetTimeAgo(t.Created)</td>
 <td>
 <button class="btn subtle" @onclick="() => EditTicket(t.Id)">Edit</button>
 <button class="btn danger" @onclick="() => DeleteTicket(t.Id)">Delete</button>
 </td>
 </tr>
 }
 }
 </tbody>
 </table>
 </div>

 <div class="panel">
 <div class="panel-head">
 <h2>Today's Activity</h2>
 <p class="muted-text">Recent actions</p>
 </div>
 <ul class="activity-list">
 <li class="activity success">
 <span class="dot"></span>
 Ticket #7004 assigned to <strong>CSR-01</strong>
 <span class="time">10 mins ago</span>
 </li>
 <li class="activity warning">
 <span class="dot"></span>
 New customer registered: <strong>Kisha Tan</strong>
 <span class="time">25 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
 Invoice reminder sent to <strong>Fiber Corp</strong>
 <span class="time">35 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
2 tickets waiting for update
 <span class="time">1 hr ago</span>
 </li>
 </ul>
 </div>
 </section>

<!-- Modal for new ticket inside dashboard for quick debug -->
<div class="modal-backdrop" style="display:@(showNewTicketModal ? "grid" : "none")" @onclick="() => CloseTicketModal()">
 <div class="modal" @onclick:stopPropagation>
 <h3>New Ticket</h3>
 <div class="form-group">
 <label>Title</label>
 <input class="form-input" @bind="newTicketTitle" />
 </div>
 <div class="form-group">
 <label>Customer</label>
 <select class="form-input" @bind="newTicketCustomer">
 <option value="">Select customer</option>
 @if (customers != null)
 {
 foreach (var c in customers)
 {
 <option value="@c.Name">@c.Name</option>
 }
 }
 </select>
 </div>
 <div class="form-group">
 <label>Priority</label>
 <select class="form-input" @bind="newTicketPriority">
 <option>Low</option>
 <option>Medium</option>
 <option>High</option>
 </select>
 </div>
 <div class="form-group">
 <label>Status</label>
 <select class="form-input" @bind="newTicketStatus">
 <option>Open</option>
 <option>In-Progress</option>
 <option>Resolved</option>
 <option>Closed</option>
 </select>
 </div>
 <div class="modal-actions">
 <button class="btn" @onclick="() => CloseTicketModal()">Cancel</button>
 <button class="btn primary" @onclick="CreateNewTicketAsync">Create</button>
 </div>
 </div>
</div>

@code {
 private List<Ticket>? tickets;
 private List<Customer>? customers;

 // new ticket state local to dashboard
 private bool showNewTicketModal = false;
 private string newTicketTitle = string.Empty;
 private string newTicketCustomer = string.Empty;
 private string newTicketPriority = "Medium";
 private string newTicketStatus = "Open";

 protected override async Task OnInitializedAsync()
 {
 if (!AuthService.IsAuthenticated)
 {
 Navigation.NavigateTo("/login", true);
 return;
 }
 await LoadDataAsync();
 }

 private async Task LoadDataAsync()
 {
 tickets = await AdminService.GetTicketsAsync();
 customers = await AdminService.GetCustomersAsync();
 StateHasChanged();
 }

 private string GetTimeAgo(DateTime date)
 {
 var span = DateTime.Now - date;
 if (span.TotalMinutes <60) return $"{(int)span.TotalMinutes} mins ago";
 if (span.TotalHours <24) return $"{(int)span.TotalHours} hrs ago";
 return $"{(int)span.TotalDays} days ago";
 }

 private void ShowNewTicket(bool show)
 {
 showNewTicketModal = show;
 if (!show) ClearNewTicketForm();
 StateHasChanged();
 }

 private void ClearNewTicketForm()
 {
 newTicketTitle = string.Empty;
 newTicketCustomer = string.Empty;
 newTicketPriority = "Medium";
 newTicketStatus = "Open";
 }

 private async Task CreateNewTicketAsync()
 {
 if (string.IsNullOrWhiteSpace(newTicketTitle) || string.IsNullOrWhiteSpace(newTicketCustomer)) return;
 var t = new Ticket { Title = newTicketTitle, Customer = newTicketCustomer, Priority = newTicketPriority, Status = newTicketStatus, Created = DateTime.UtcNow };
 await AdminService.CreateTicketAsync(t);
 await LoadDataAsync();
 ShowNewTicket(false);
 }

 private async Task DeleteTicket(string id)
 {
 if (string.IsNullOrEmpty(id)) return;
 await AdminService.DeleteTicketAsync(id);
 await LoadDataAsync();
 }

 private async Task EditTicket(string id)
 {
 // open tickets page edit for now
 Navigation.NavigateTo("/", true);
 }

 private void CloseTicketModal() => ShowNewTicket(false);

 private void ExportData() => Navigation.NavigateTo("/", true);
}
