                        existing.FullName = entity.FullName;
                        existing.Phone = entity.Phone;
                        existing.ServiceArea = entity.ServiceArea;
                        existing.Department = entity.Department;
                        existing.Specialization = entity.Specialization;
                        existing.IsActive = entity.IsActive;
                        existing.IsLocked = entity.IsLocked;
                        existing.FailedLoginCount = entity.FailedLoginCount;
                        existing.LastLoginAt = entity.LastLoginAt;
                        existing.UpdatedAt = DateTime.UtcNow;
                        existing.PasswordChangedAt = entity.PasswordChangedAt;
