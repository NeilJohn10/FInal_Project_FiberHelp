// ==================== TRANSACTION VALIDATION & PROOF ====================

/// <summary>
/// Resolve a ticket and automatically generate transaction proof for the client.
/// This creates a verified proof of service completion.
/// </summary>
public async Task<(bool Success, int? ProofId)> ResolveTicketWithProofAsync(
    int ticketId, 
    string technicianId, 
    string? technicianName,
    string? resolutionNotes)
{
    try
    {
        LastError = null;
        if (ticketId <= 0) { LastError = "Invalid ticket ID"; return (false, null); }
        if (string.IsNullOrWhiteSpace(technicianId)) { LastError = "Technician ID is required"; return (false, null); }

        var ticket = await _db.Tickets.FindAsync(ticketId);
        if (ticket == null) { LastError = $"Ticket #{ticketId} not found"; return (false, null); }

        // Verify the technician is assigned to this ticket
        if (ticket.AssignedTechnicianId != technicianId)
        {
            LastError = "You are not assigned to this ticket";
            return (false, null);
        }

        // Update ticket status
        ticket.Status = "Resolved";
        ticket.ResolvedByTechnicianId = technicianId;
        ticket.ResolvedAt = DateTime.UtcNow;
        ticket.ResolutionNotes = resolutionNotes;

        _db.Tickets.Update(ticket);
        var rows = await _db.SaveChangesAsync();

        if (rows <= 0)
        {
            LastError = "Resolution failed";
            return (false, null);
        }

        await MaybeSyncOrEnqueueAsync("Update", ticket, ticket.Id.ToString());

        // Generate transaction proof
        try
        {
            var maxId = await _db.TransactionProofs.MaxAsync(p => (int?)p.Id) ?? 0;
            var referenceNumber = TransactionProof.GenerateReferenceNumber(maxId + 1);

            var proof = new TransactionProof
            {
                ReferenceNumber = referenceNumber,
                TransactionType = "TicketResolution",
                TicketId = ticketId,
                ClientId = ticket.ClientId,
                ClientName = ticket.ClientName,
                AccountId = ticket.AccountId,
                Description = $"Service ticket '{ticket.Title}' has been successfully resolved.",
                CompletedById = technicianId,
                CompletedByName = technicianName,
                CompletedAt = ticket.ResolvedAt ?? DateTime.UtcNow,
                Notes = resolutionNotes,
                Status = "Generated",
                VerificationCode = GenerateVerificationCode(referenceNumber, ticketId.ToString())
            };

            _db.TransactionProofs.Add(proof);
            await _db.SaveChangesAsync();
            await MaybeSyncOrEnqueueAsync("Create", proof, proof.Id.ToString());

            System.Diagnostics.Debug.WriteLine($"[AdminService] Generated proof {referenceNumber} for resolved ticket {ticketId}");
            return (true, proof.Id);
        }
        catch (Exception proofEx)
        {
            // Ticket was resolved but proof generation failed - still return success
            System.Diagnostics.Debug.WriteLine($"[AdminService] Proof generation failed: {proofEx.Message}");
            return (true, null);
        }
    }
    catch (Exception ex)
    {
        LastError = _errorService.GetContextualMessage(ex, "resolve", "ticket");
        System.Diagnostics.Debug.WriteLine($"AdminService.ResolveTicketWithProofAsync error: {ex}");
        return (false, null);
    }
}

