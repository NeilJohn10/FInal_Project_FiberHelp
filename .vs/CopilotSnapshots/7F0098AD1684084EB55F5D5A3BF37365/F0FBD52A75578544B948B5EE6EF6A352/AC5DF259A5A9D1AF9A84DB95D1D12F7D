@page "/"
@using FiberHelp.Models
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.AdminService AdminService
@inject NavigationManager Navigation

<link href="css/dashboard.css" rel="stylesheet" />
<style>
/* Clean-room styles inspired by modern admin dashboards */
.kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:20px;margin-bottom:18px;align-items:stretch}
.kpi-card{padding:20px;border-radius:14px;color:#fff;display:flex;flex-direction:column;justify-content:space-between;min-height:180px;box-shadow:0 8px 20px rgba(2,6,23,0.06)}
.kpi-icon{width:44px;height:44px;border-radius:10px;background:rgba(255,255,255,0.12);display:grid;place-items:center}
.kpi-content .kpi-header{font-weight:700;margin-bottom:8px;color:rgba(255,255,255,0.95)}
.kpi-content h2{font-size:32px;margin:0 0 6px 0;font-weight:900}
.kpi-content .kpi-sub{opacity:0.95}
.kpi-trend .trend-badge{display:inline-block;padding:6px 10px;border-radius:999px;background:rgba(255,255,255,0.12);font-weight:700}
.card-gradient-red{background:linear-gradient(135deg,#f87171,#ef4444)}
.card-gradient-blue{background:linear-gradient(135deg,#60a5fa,#3b82f6)}
.card-gradient-purple{background:linear-gradient(135deg,#a78bfa,#8b5cf6)}
.card-gradient-green{background:linear-gradient(135deg,#34d399,#10b981)}

/* keep existing rules below */
.toolbar {display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:12px}
.toolbar-left{display:flex;gap:8px;align-items:center}
.chip{border:1px solid #e5e7eb;border-radius:999px;padding:6px 10px;font-size:12.5px;color:#334155;background:#fff}
.chip.primary{border-color:#c7d2fe;color:#4338ca;background:#eef2ff}
.chip .dot{width:8px;height:8px;border-radius:999px;background:#6366f1;margin-right:6px;display:inline-block}

.grid-2{display:grid;grid-template-columns:2fr 1.3fr;gap:16px;margin-bottom:16px}
.card{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:14px}
.card h4{margin:0 0 6px 0;font-weight:800;color:#0f172a}
.muted{color:#64748b;font-size:12.5px}

/* small KPI row */
.mini-kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:16px}
.mini{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:12px}
.mini .label{font-weight:700;color:#334155;font-size:12.5px;margin-bottom:6px}
.mini .value{font-weight:900;font-size:18px;color:#0f172a}
.mini .sub{font-size:12px;color:#94a3b8}

/* simple charts */
.bars{height:170px;display:flex;align-items:flex-end;gap:10px}
.bar{flex:1;background:linear-gradient(180deg,#c7d2fe,#e0e7ff);border:1px solid #c7d2fe;border-radius:6px}
.months{display:flex;justify-content:space-between;font-size:11.5px;color:#64748b;margin-top:6px}

.gauge-wrap{display:flex;align-items:center;justify-content:center;height:200px}

.line-wrap{height:220px}
.line-canvas{width:100%;height:160px}
.line-legend{display:flex;gap:12px;font-size:12px;color:#64748b;margin-top:6px}
.legend-dot{width:10px;height:10px;border-radius:50%;display:inline-block;margin-right:6px}

/* Responsive: 2 columns on medium, 1 on small */
@media (max-width:1200px) {
  .kpi-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
}
@media (max-width:640px) {
  .kpi-grid { grid-template-columns: repeat(1, minmax(0,1fr)); }
  .kpi-content h2 { font-size:28px; }
}
</style>

<div class="dashboard-root">
  <header class="topbar">
    <div class="topbar-left">
      <p class="eyebrow">FIBERHELP · @GetRoleLabel()</p>
      <h1 class="page-title">Dashboard</h1>
      <p class="welcome-text">Welcome back, @(AuthService.FullName ?? "User")! Here's what's happening today.</p>
    </div>
    <div class="top-actions">
      @if (!(AuthService.Role ?? "").Equals("Agent", StringComparison.OrdinalIgnoreCase))
      {
        <button class="btn-icon" @onclick="() => {}">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        </button>
        <button class="btn subtle" @onclick="ExportData">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          Export
        </button>
      }
      <UserPill />
    </div>
  </header>

  <div class="toolbar">
    <div class="toolbar-left">
      <span class="chip primary"><span class="dot"></span> Overview</span>
      <span class="chip">Sort</span>
      <span class="chip">Filter</span>
    </div>
    <div class="toolbar-right">
      <span class="chip">Last Month ▾</span>
    </div>
  </div>

  <!-- KPI row -->
  <section class="kpi-grid">
    <article class="kpi-card card-gradient-red">
      <div class="kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="kpi-content">
        <div class="kpi-header">Open Tickets</div>
        <h2>@OpenTickets</h2>
        <p class="kpi-sub">Need attention</p>
      </div>
      <div class="kpi-trend"><span class="trend-badge">@OpenTrend</span></div>
    </article>

    <article class="kpi-card card-gradient-blue">
      <div class="kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="kpi-content">
        <div class="kpi-header">Total Tickets</div>
        <h2>@TotalTickets</h2>
        <p class="kpi-sub">Visible in system</p>
      </div>
      <div class="kpi-trend"><span class="trend-badge">@TotalTrend</span></div>
    </article>

    <article class="kpi-card card-gradient-purple">
      <div class="kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 8v4l3 3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="kpi-content">
        <div class="kpi-header">Avg Response</div>
        <h2>@AvgResponseLabel</h2>
        <p class="kpi-sub">Estimated</p>
      </div>
      <div class="kpi-trend"><span class="trend-badge">@AvgTrend</span></div>
    </article>

    <article class="kpi-card card-gradient-green">
      <div class="kpi-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 12l2 2 4-4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
      <div class="kpi-content">
        <div class="kpi-header">Resolved</div>
        <h2>@ResolvedThisWeek</h2>
        <p class="kpi-sub">This week</p>
      </div>
      <div class="kpi-trend"><span class="trend-badge">@ResolvedTrend</span></div>
    </article>
  </section>

  <div class="grid-2">
    <div class="card">
      <h4>Sales Pipeline</h4>
      <div class="muted">Rates increased by ~2% in last 7 days</div>
      <div class="bars">
        @foreach (var h in PipelineHeights)
        {
          <div class="bar" style="height:@h%"></div>
        }
      </div>
      <div class="months">
        @foreach (var m in Months) { <span>@m</span> }
      </div>
    </div>
    <div class="card">
      <h4>Revenue</h4>
      <div class="muted">Rates decreased by 3% in last 7 days</div>
      <div class="gauge-wrap">
        <svg width="260" height="160" viewBox="0 0 260 160" role="img" aria-label="Revenue gauge">
          <defs>
            <linearGradient id="g1" x1="0" x2="0" y1="0" y2="1">
              <stop offset="0%" stop-color="#6366f1" />
              <stop offset="100%" stop-color="#a5b4fc" />
            </linearGradient>
          </defs>
          @foreach (var seg in Gauge)
          {
            <line x1="@seg.X1" y1="@seg.Y1" x2="@seg.X2" y2="@seg.Y2" stroke="@seg.Color" stroke-width="8" stroke-linecap="round"></line>
          }
          <text x="130" y="120" text-anchor="middle" font-size="14" fill="#64748b">vs. Last period</text>
          <text x="130" y="88" text-anchor="middle" font-size="22" font-weight="800" fill="#111827">$@RevenueThisWeek.ToString("N0")</text>
        </svg>
      </div>
    </div>
  </div>

  <div class="mini-kpis">
    <div class="mini"><div class="label">Product Revenue</div><div class="value">$@RevenueThisWeek.ToString("N0")</div><div class="sub">vs. last period</div></div>
    <div class="mini"><div class="label">Active Sales</div><div class="value">@ActiveSales</div><div class="sub">+2.7%</div></div>
    <div class="mini"><div class="label">Total Deals</div><div class="value">@TotalDeals</div><div class="sub">vs. last period</div></div>
    <div class="mini"><div class="label">Reply Rate</div><div class="value">86.5%</div><div class="sub">vs. last period</div></div>
    <div class="mini"><div class="label">Churn</div><div class="value">1.4%</div><div class="sub">last 30 days</div></div>
  </div>

  <div class="card">
    <h4>Average Ticket</h4>
    <div class="muted">Last 6 months</div>
    <div class="line-wrap">
      <svg class="line-canvas" viewBox="0 0 600 180" preserveAspectRatio="none" role="img" aria-label="Average Ticket line">
        <path d="@LinePath1" fill="none" stroke="#3b82f6" stroke-width="3"></path>
        <path d="@LinePath2" fill="none" stroke="#94a3b8" stroke-width="2"></path>
      </svg>
      <div class="line-legend">
        <span><span class="legend-dot" style="background:#3b82f6"></span>Checkout</span>
        <span><span class="legend-dot" style="background:#94a3b8"></span>Viewing</span>
      </div>
    </div>
  </div>

  <!-- LATEST TICKETS TABLE -->
  <section class="tickets-section">
    <div class="panel modern-panel">
      <div class="panel-head">
        <div>
          <h2>Latest Tickets</h2>
          <p class="muted-text">Most recent customer issues</p>
        </div>
        <div class="panel-actions">
          <div class="filter-pill">This week</div>
          <button class="btn-text" @onclick="NavigateToTickets">View all →</button>
        </div>
      </div>

      <div class="table-wrapper">
        <table class="data-table modern-table">
          <thead>
            <tr>
              <th>Ticket #</th>
              <th>Customer</th>
              <th>Subject</th>
              <th>Status</th>
              <th>Priority</th>
              <th>Created</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            @if (tickets != null && tickets.Any())
            {
              foreach (var t in tickets.Take(5)
