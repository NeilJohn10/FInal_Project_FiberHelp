@page "/admin/accounts"
@using FiberHelp.Models
@inject FiberHelp.Services.AdminService AdminService
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.ErrorHandlingService ErrorService
@inject Microsoft.JSInterop.IJSRuntime JS

<style>
/* Accounts page enhancements */
.topbar { padding-bottom:20px; margin-bottom:22px; border-bottom:1px solid #e5e7eb; }
.topbar .page-title { font-size:42px; line-height:1.1; margin:0 0 4px; }
.top-actions { gap:14px; }
.top-actions .agents-search { width:360px; padding:12px 18px; border-radius:14px; border:1px solid #e5e7eb; background:#fff; box-shadow:0 8px 22px rgba(2,6,23,0.08); font-size:15px; }
.top-actions .btn.subtle { background:#fff; color:#0f172a; border:1px solid #e5e7eb; border-radius:14px; padding:10px 22px; box-shadow:0 4px 10px rgba(2,6,23,0.04); }
.top-actions .btn.primary { background:linear-gradient(135deg,#2563eb,#1d4ed8); color:#fff; border:none; border-radius:14px; padding:10px 26px; box-shadow:0 14px 32px rgba(29,78,216,0.30); font-weight:600; }
.top-actions .btn.primary:hover { filter:brightness(1.08); }

.accounts-card { display:block; background:#fff; border-radius:14px; padding:20px 20px 10px; box-shadow:0 12px 28px rgba(2,6,23,0.08); }
.accounts-table { width:100%; border-collapse:separate; border-spacing:0 10px; }
.accounts-table thead th { text-align:left; padding:10px 12px; color:#475569; font-weight:700; border-bottom:1px solid #e5e7eb; font-size:14px; }
.accounts-table tbody td { background:#f9fafb; padding:14px 12px; color:#0f172a; font-size:14px; border-top:1px solid #eef2f7; border-bottom:1px solid #eef2f7; }
.accounts-table tbody tr td:first-child { border-left:1px solid #eef2f7; border-top-left-radius:12px; border-bottom-left-radius:12px; }
.accounts-table tbody tr td:last-child { border-right:1px solid #eef2f7; border-top-right-radius:12px; border-bottom-right-radius:12px; }
.accounts-actions { white-space:nowrap; }
.action-btn { border:none; background:transparent; padding:6px 8px; border-radius:10px; cursor:pointer; }
.action-btn:hover { background:#eef2ff; }
.action-btn.edit { color:#2563eb; }
.action-btn.delete { color:#ef4444; }
.badge { display:inline-block; padding:6px 10px; border-radius:999px; font-size:12px; font-weight:700; }
.badge.on { color:#065f46; background:#ecfdf5; border:1px solid #a7f3d0; }
.badge.off { color:#7f1d1d; background:#fee2e2; border:1px solid #fecaca; }
.acct-customer-cell { display:flex; align-items:center; gap:12px; }
.acct-initial { width:40px; height:40px; border-radius:999px; background:linear-gradient(135deg,#0ea5e9,#6366f1); display:grid; place-items:center; font-weight:800; color:#fff; font-size:14px; box-shadow:0 8px 18px rgba(99,102,241,0.25); }
.acct-name { font-weight:600; }
.acct-plan { font-size:12px; color:#64748b; }

/* Modal visual parity with Agents */
.modal-backdrop { position:fixed; inset:0; background:rgba(2,6,23,0.5); display:grid; place-items:center; z-index:20000; }
.modal-card { width:680px; max-width:94vw; background:#fff; border-radius:16px; padding:22px; box-shadow:0 24px 58px rgba(2,6,23,0.28); }
.modal-head h3 { margin:0; font-size:20px; }
.modal-head p { margin:6px 0 0; color:#64748b; font-size:14px; }
.form-row { display:flex; gap:14px; }
.form-col { flex:1; display:flex; flex-direction:column; gap:6px; }
.form-input { padding:10px 12px; border-radius:10px; border:1px solid #e6edf3; }
.modal-actions { display:flex; gap:10px; justify-content:flex-end; margin-top:18px; }
.btn.primary { background:linear-gradient(135deg,#2563eb,#1d4ed8); color:#fff; box-shadow:0 10px 22px rgba(29,78,216,0.25); }
.btn { border-radius:10px; }
</style>

@if(!AuthService.IsAuthenticated || !string.Equals(AuthService.Role,"Administrator",StringComparison.OrdinalIgnoreCase))
{
    <div class="panel">Access denied.</div>
}
else
{

    <header class="topbar agents-header">
      <div>
        <p class="eyebrow">FIBERHELP · ADMIN</p>
        <h1 class="page-title">Accounts</h1>
      </div>
      <div class="agents-controls top-actions">
        <input class="agents-search" placeholder="Search by number, name or email" list="accountSearchList" @bind="searchTerm" @bind:event="oninput" @bind:after="TryOpenFromSearch" />
        <datalist id="accountSearchList">
            @if(accounts != null)
            {
                foreach(var a in accounts)
                {
                    <option value="@($"{a.Id} - {a.Name} ({a.ContactEmail})")"></option>
                }
            }
        </datalist>
        <button class="btn subtle" @onclick="ExportAccounts">Export</button>
        <button class="btn primary" @onclick="OpenNewAccount">+ Add Account</button>
      </div>
    </header>

    <section class="accounts-card">
        <table class="accounts-table">
            <thead>
                <tr>
                    <th style="width:70px">Account ID</th>
                    <th style="width:220px">Account Number</th>
                    <th style="width:220px">Name</th>
                    <th style="width:140px">Type</th>
                    <th style="width:160px">Plan</th>
                    <th style="width:140px">Status</th>
                    <th style="width:110px">Active</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (accounts != null && accounts.Count>0)
                {
                    @foreach(var a in accounts)
                    {
                        <tr>
                            <td>@a.Id</td>
                            <td style="font-weight:600">@a.Id - @(string.IsNullOrWhiteSpace(a.Name)?"(no name)":a.Name) (@(string.IsNullOrWhiteSpace(a.AccountNumber)?"no number":a.AccountNumber))</td>
                            <td>@(string.IsNullOrWhiteSpace(a.Name)?"—":a.Name)</td>
                            <td>@(string.IsNullOrWhiteSpace(a.Type)?"—":a.Type)</td>
                            <td>@(string.IsNullOrWhiteSpace(a.ServicePlan)?"—":a.ServicePlan)</td>
                            <td>@(string.IsNullOrWhiteSpace(a.ServiceStatus)?"—":a.ServiceStatus)</td>
                            <td><span class="badge @(a.IsActive?"on":"off")">@(a.IsActive?"Active":"Inactive")</span></td>
                            <td class="accounts-actions" style="text-align:right">
                                 <button class="action-btn edit" title="Edit" @onclick="() => EditAccount(a)">
                                     <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                         <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" fill="#2563eb" />
                                         <path d="M20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="#2563eb" />
                                     </svg>
                                 </button>
                                 <button class="action-btn delete" title="Delete" @onclick="() => DeleteAccount(a.Id)">
                                     <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                         <path d="M3 6h18" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
                                         <path d="M8 6v12a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                         <path d="M10 11v6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
                                         <path d="M14 11v6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
                                         <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                     </svg>
                                 </button>
                             </td>
                         </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8">@(!string.IsNullOrEmpty(AdminService.LastError) ? $"Error loading accounts: {AdminService.LastError}" : "No accounts found.")</td></tr>
                }
            </tbody>
        </table>
    </section>

    @if (showModal)
    {
        <div class="modal-backdrop" @onclick="CloseModal">
            <div class="modal-card" @onclick:stopPropagation>
                <div class="modal-head">
                    <div>
                        <h3>@(editingAccount==null?"Create Account":"Edit Account")</h3>
                        <p>Create or update account details. Account numbers are auto-generated.</p>
                    </div>
                    <button class="btn" style="background:#f1f5f9" @onclick="CloseModal">✕</button>
                </div>
                
                @if(!string.IsNullOrEmpty(formMessage))
                {
                    <div style="background:#fee2e2;color:#7f1d1d;border:1px solid #fecaca;padding:10px 12px;border-radius:10px;margin-bottom:10px">
                        @formMessage
                    </div>
                }
                
                <div>
                    <div class="form-row">
                        <div class="form-col">
                            <label>Account Number</label>
                            <input class="form-input" @bind="formAccountNumber" disabled />
                        </div>
                        <div style="min-width:140px; display:flex; flex-direction:column; gap:6px;">
                            <label>Active</label>
                            <input type="checkbox" @bind="formIsActive" />
                        </div>
                    </div>

                    <div class="form-row" style="margin-top:14px;">
                        <div class="form-col">
                            <label>Name <span style="color:#ef4444">*</span></label>
                            <input class="form-input" @bind="formName" placeholder="Account name" />
                        </div>
                        <div class="form-col">
                            <label>Type</label>
                            <select class="form-input" @bind="formType">
                                <option value="">-- select type --</option>
                                <option>Residential</option>
                                <option>Business</option>
                                <option>Government</option>
                                <option>Education</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row" style="margin-top:14px;align-items:center;">
                        <div class="form-col">
                            <label>Service Plan</label>
                            <select class="form-input" @bind="formServicePlan">
                                <option value="">-- select plan --</option>
                                <option>Basic</option>
                                <option>Standard</option>
                                <option>Premium</option>
                                <option>Enterprise</option>
                            </select>
                        </div>
                        <div class="form-col">
                            <label>Service Status</label>
                            <select class="form-input" @bind="formServiceStatus">
                                <option value="Active">Active</option>
                                <option value="Suspended">Suspended</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row" style="margin-top:14px;">
                        <div class="form-col">
                            <label>Contact Name</label>
                            <input class="form-input" @bind="formContactName" placeholder="Contact person" />
                        </div>
                        <div class="form-col">
                            <label>Contact Email</label>
                            <input type="email" class="form-input" @bind="formContactEmail" placeholder="email@example.com" />
                        </div>
                    </div>
                    <div class="form-row" style="margin-top:14px;">
                        <div class="form-col">
                            <label>Contact Phone</label>
                            <input type="tel" class="form-input" @bind="formContactPhone" placeholder="+639123456789" />
                        </div>
                        <div class="form-col">
                            <label>Billing Address</label>
                            <input class="form-input" @bind="formBillingAddress" placeholder="Complete address" />
                        </div>
                    </div>
                    <div class="modal-actions">
                        <button class="btn" @onclick="CloseModal">Cancel</button>
                        <button class="btn primary" @onclick="ShowSaveConfirmation" disabled="@(!CanSave())">
                            @(editingAccount==null?"Create Account":"Save Changes")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Confirmation modal for save *@
    @if(showSaveConfirm)
    {
        <div class="modal-backdrop" @onclick="() => showSaveConfirm=false">
            <div class="modal-card" style="max-width:500px" @onclick:stopPropagation>
                <div class="modal-head">
                    <h3>@(editingAccount==null ? "Confirm Account Creation" : "Confirm Changes")</h3>
                </div>
                <div style="padding:10px 0">
                    @if(editingAccount==null)
                    {
                        <p>You are about to create a new account:</p>
                        <div style="background:#f8fafc;border:1px solid #e5e7eb;border-radius:10px;padding:12px;margin:12px 0">
                            <div style="margin-bottom:8px"><strong>Name:</strong> @formName</div>
                            <div style="margin-bottom:8px"><strong>Type:</strong> @(string.IsNullOrWhiteSpace(formType) ? "(none)" : formType)</div>
                            <div style="margin-bottom:8px"><strong>Plan:</strong> @(string.IsNullOrWhiteSpace(formServicePlan) ? "(none)" : formServicePlan)</div>
                            <div style="margin-bottom:8px"><strong>Contact:</strong> @formContactName (@formContactEmail)</div>
                            <div><strong>Status:</strong> @(formIsActive ? "Active" : "Inactive")</div>
                        </div>
                    }
                    else
                    {
                        <p>Are you sure you want to save changes for <strong>@formName</strong>?</p>
                    }
                </div>
                <div class="modal-actions">
                    <button class="btn" @onclick="() => showSaveConfirm=false">Cancel</button>
                    <button class="btn primary" @onclick="ConfirmSaveAccount">
                        @(editingAccount==null ? "Yes, Create Account" : "Yes, Save Changes")
                    </button>
                </div>
            </div>
        </div>
    }

    @* Confirmation modal for delete *@
    @if(showDeleteConfirm)
    {
        <div class="modal-backdrop" @onclick="() => showDeleteConfirm=false">
            <div class="modal-card" style="max-width:500px" @onclick:stopPropagation>
                <div class="modal-head">
                    <h3>Confirm Deletion</h3>
                </div>
                <div style="padding:10px 0">
                    <p>Are you sure you want to delete account <strong>@deleteTargetName</strong> (ID: @deleteTargetId)?</p>
                    <p style="color:#ef4444;font-size:13px">This action cannot be undone.</p>
                </div>
                <div class="modal-actions">
                    <button class="btn" @onclick="() => showDeleteConfirm=false">Cancel</button>
                    <button class="btn primary" style="background:#ef4444" @onclick="ConfirmDelete">Delete Account</button>
                </div>
            </div>
        </div>
    }

    <Toast Message="@pageToast" />
}

@code{
    private List<Models.Account>? accounts;
    private string searchTerm = string.Empty;
    private bool showModal=false;
    private bool showSaveConfirm=false;
    private bool showDeleteConfirm=false;
    private Models.Account? editingAccount=null;
    private string formAccountNumber="";
    private string formServicePlan="";
    private bool formIsActive = true;
    private string formContactName="";
    private string formContactEmail="";
    private string formContactPhone="";
    private string formBillingAddress="";
    private string formServiceStatus="Active";
    private string formName="";
    private string formType="";
    private string formMessage="";
    private string pageToast="";
    private string notification="";
    private string errorMessage="";
    private int deleteTargetId=0;
    private string deleteTargetName="";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if(!AuthService.IsAuthenticated || !string.Equals(AuthService.Role,"Administrator",StringComparison.OrdinalIgnoreCase))
                return;
                
            await LoadAccountsFromDb();
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetContextualMessage(ex, "load", "accounts");
            System.Diagnostics.Debug.WriteLine($"OnInitializedAsync error: {ex}");
        }
    }

    private async Task LoadAccountsFromDb()
    {
        try
        {
            errorMessage = "";
            var list = await AdminService.GetAccountsAsync();
            
            if (!string.IsNullOrEmpty(AdminService.LastError))
            {
                errorMessage = AdminService.LastError;
                accounts = new List<Models.Account>();
            }
            else
            {
                accounts = string.IsNullOrWhiteSpace(searchTerm) 
                    ? list 
                    : list.Where(a => 
                        (a.AccountNumber ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                        (a.Name ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                        (a.ContactEmail ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                        (a.ServicePlan ?? "").Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                    ).ToList();
            }
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetContextualMessage(ex, "load", "accounts");
            accounts = new List<Models.Account>();
            System.Diagnostics.Debug.WriteLine($"LoadAccountsFromDb error: {ex}");
        }
    }

    private bool CanSave()
    {
        return !string.IsNullOrWhiteSpace(formName);
    }

    private void OpenNewAccount()
    {
        try
        {
            editingAccount=null;
            formAccountNumber = "(auto)";
            formServicePlan="";
            formIsActive=true;
            formContactName="";
            formContactEmail="";
            formContactPhone="";
            formBillingAddress="";
            formServiceStatus="Active";
            formName="";
            formType="";
            formMessage="";
            notification="";
            errorMessage="";
            showModal=true;
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetUserFriendlyMessage(ex);
            System.Diagnostics.Debug.WriteLine($"OpenNewAccount error: {ex}");
        }
    }

    private void EditAccount(Models.Account a)
    {
        try
        {
            if(a==null) 
            {
                errorMessage = "⚠️ Invalid account data";
                return;
            }
            
            editingAccount=a;
            formAccountNumber=a.AccountNumber ?? "(auto)";
            formServicePlan=a.ServicePlan ?? "";
            formIsActive=a.IsActive;
            formContactName=a.ContactName ?? "";
            formContactEmail=a.ContactEmail ?? "";
            formContactPhone=a.ContactPhone ?? "";
            formBillingAddress=a.BillingAddress ?? "";
            formServiceStatus=a.ServiceStatus ?? "Active";
            formName=a.Name ?? "";
            formType=a.Type ?? "";
            formMessage="";
            notification="";
            errorMessage="";
            showModal=true;
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetContextualMessage(ex, "load", "account");
            System.Diagnostics.Debug.WriteLine($"EditAccount error: {ex}");
        }
    }

    private void CloseModal()
    {
        showModal=false;
        editingAccount=null;
        formMessage="";
        showSaveConfirm=false;
    }

    private void ShowSaveConfirmation()
    {
        if (!CanSave())
        {
            formMessage = "📝 Account name is required";
            return;
        }
        
        formMessage = "";
        showSaveConfirm = true;
    }

    private async Task ConfirmSaveAccount()
    {
        showSaveConfirm = false;
        await SaveAccount();
    }

    private async Task SaveAccount()
    {
        try
        {
            errorMessage = "";
            notification = "";
            formMessage = "";
            
            // Validation
            if (string.IsNullOrWhiteSpace(formName))
            {
                formMessage = "📝 Account name is required";
                ToastNotification.ShowError("Account name is required", "Validation Error");
                return;
            }

            // Check for duplicate account number (if editing)
            if(accounts != null && !string.IsNullOrWhiteSpace(formAccountNumber) && 
               formAccountNumber!="(auto)" && 
               accounts.Any(a => (a.AccountNumber ?? "").Equals(formAccountNumber, StringComparison.OrdinalIgnoreCase) && 
                                 a.Id != (editingAccount?.Id ?? 0)))
            {
                formMessage = "⚠️ Account number already exists";
                ToastNotification.ShowError("Account number already exists", "Duplicate Entry");
                return;
            }

            bool ok;
            if(editingAccount == null)
            {
                // Create new account
                var a = new Models.Account {
                    AccountNumber="",
                    Name = formName ?? string.Empty,
                    Type = formType ?? string.Empty,
                    ServicePlan=formServicePlan ?? string.Empty,
                    IsActive=formIsActive,
                    ContactName=formContactName ?? string.Empty,
                    ContactEmail=formContactEmail ?? string.Empty,
                    ContactPhone=formContactPhone ?? string.Empty,
                    BillingAddress=formBillingAddress ?? string.Empty,
                    ServiceStatus=formServiceStatus ?? "Active",
                    CreatedAt = DateTime.UtcNow
                };
                
                ok = await AdminService.CreateAccountAsync(a);
                
                if (ok)
                {
                    notification = "✅ Account created successfully!";
                    ToastNotification.ShowSuccess("Account created successfully!");
                    await LoadAccountsFromDb();
                    CloseModal();
                }
                else
                {
                    var error = AdminService.LastError ?? "Failed to create account";
                    formMessage = error;
                    ToastNotification.ShowError(error, "Create Failed");
                }
            }
            else
            {
                // Update existing account
                editingAccount.Name = formName ?? string.Empty;
                editingAccount.Type = formType ?? string.Empty;
                editingAccount.ServicePlan = formServicePlan ?? string.Empty;
                editingAccount.IsActive = formIsActive;
                editingAccount.ContactName = formContactName ?? string.Empty;
                editingAccount.ContactEmail = formContactEmail ?? string.Empty;
                editingAccount.ContactPhone = formContactPhone ?? string.Empty;
                editingAccount.BillingAddress = formBillingAddress ?? string.Empty;
                editingAccount.ServiceStatus = formServiceStatus ?? "Active";
                
                ok = await AdminService.UpdateAccountAsync(editingAccount);
                
                if (ok)
                {
                    notification = "✅ Account updated successfully!";
                    ToastNotification.ShowSuccess("Account updated successfully!");
                    await LoadAccountsFromDb();
                    CloseModal();
                }
                else
                {
                    var error = AdminService.LastError ?? "Failed to update account";
                    formMessage = error;
                    ToastNotification.ShowError(error, "Update Failed");
                }
            }

            if (ok)
            {
                _ = ClearNotificationAfterDelay();
            }
        }
        catch (Exception ex)
        {
            var operation = editingAccount == null ? "create" : "update";
            formMessage = ErrorService.GetContextualMessage(ex, operation, "account");
            errorMessage = formMessage;
            ToastNotification.ShowException(ex, $"{(editingAccount == null ? "Creating" : "Updating")} Account", ErrorService);
            System.Diagnostics.Debug.WriteLine($"SaveAccount error: {ex}");
        }
    }

    private async Task ClearNotificationAfterDelay()
    {
        await Task.Delay(5000);
        notification = string.Empty;
        errorMessage = string.Empty;
        StateHasChanged();
    }

    private void DeleteAccount(int id)
    {
        try
        {
            var account = accounts?.FirstOrDefault(a => a.Id == id);
            if (account == null)
            {
                errorMessage = $"🔍 Account #{id} not found";
                ToastNotification.ShowError($"Account #{id} not found", "Not Found");
                return;
            }
            
            deleteTargetId = id;
            deleteTargetName = account.Name ?? $"Account {id}";
            showDeleteConfirm = true;
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetUserFriendlyMessage(ex);
            System.Diagnostics.Debug.WriteLine($"DeleteAccount error: {ex}");
        }
    }

    private async Task ConfirmDelete()
    {
        showDeleteConfirm = false;
        
        try
        {
            if (deleteTargetId <= 0)
            {
                errorMessage = "⚠️ Invalid account ID";
                return;
            }

            errorMessage = "";
            notification = "";
            
            var ok = await AdminService.DeleteAccountAsync(deleteTargetId);
            
            if (ok)
            {
                notification = "✅ Account deleted successfully!";
                ToastNotification.ShowSuccess("Account deleted successfully!");
                await LoadAccountsFromDb();
            }
            else
            {
                var error = AdminService.LastError ?? "Failed to delete account";
                errorMessage = error;
                ToastNotification.ShowError(error, "Delete Failed");
            }
            
            deleteTargetId = 0;
            deleteTargetName = "";
            
            if (ok)
            {
                _ = ClearNotificationAfterDelay();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetContextualMessage(ex, "delete", "account");
            ToastNotification.ShowException(ex, "Deleting Account", ErrorService);
            System.Diagnostics.Debug.WriteLine($"ConfirmDelete error: {ex}");
            deleteTargetId = 0;
            deleteTargetName = "";
        }
    }

    private async void ExportAccounts()
    {
        try
        {
            errorMessage = "";
            
            var rows = accounts ?? new List<Models.Account>();
            
            if (rows.Count == 0)
            {
                ToastNotification.ShowWarning("No accounts to export", "Export");
                return;
            }
            
            var csv = new System.Text.StringBuilder();
            csv.AppendLine("Id,AccountNumber,Name,Type,ServicePlan,ServiceStatus,IsActive,ContactName,ContactEmail,ContactPhone");
            
            foreach(var r in rows)
            {
                csv.AppendLine($"{r.Id},{Escape(r.AccountNumber)},{Escape(r.Name)},{Escape(r.Type)},{Escape(r.ServicePlan)},{Escape(r.ServiceStatus)},{(r.IsActive?"Yes":"No")},{Escape(r.ContactName)},{Escape(r.ContactEmail)},{Escape(r.ContactPhone)}");
            }
            
            await JS.InvokeAsync<bool>("FiberExport.saveFile", "accounts.csv", csv.ToString());
            
            notification = $"✅ {rows.Count} account(s) exported successfully!";
            ToastNotification.ShowSuccess($"{rows.Count} accounts exported!", "Export Success");
            _ = ClearNotificationAfterDelay();
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetContextualMessage(ex, "export", "accounts");
            ToastNotification.ShowException(ex, "Exporting Accounts", ErrorService);
            System.Diagnostics.Debug.WriteLine($"ExportAccounts error: {ex}");
        }
    }

    private string Escape(string? s) => string.IsNullOrEmpty(s) ? "" : s!.Replace("\"", "\"\"");

    private async Task OnHeaderSearchChanged(string val)
    {
        try
        {
            searchTerm = val;
            await LoadAccountsFromDb();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetUserFriendlyMessage(ex);
            System.Diagnostics.Debug.WriteLine($"OnHeaderSearchChanged error: {ex}");
        }
    }

    private void TryOpenFromSearch()
    {
        try
        {
            var idPart = (searchTerm ?? "").Split('-').FirstOrDefault()?.Trim();
            if (int.TryParse(idPart, out var id))
            {
                var a = accounts?.FirstOrDefault(x => x.Id == id);
                if (a != null) 
                {
                    EditAccount(a);
                }
                else
                {
                    errorMessage = $"🔍 Account #{id} not found";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ErrorService.GetUserFriendlyMessage(ex);
            System.Diagnostics.Debug.WriteLine($"TryOpenFromSearch error: {ex}");
        }
    }
