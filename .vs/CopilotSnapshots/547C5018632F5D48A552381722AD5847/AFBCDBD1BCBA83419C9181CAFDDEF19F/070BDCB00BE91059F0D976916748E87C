@page "/"
@using System.Linq

<PageTitle>Dashboard - FiberHelp</PageTitle>

<div class="app-shell">
 <!-- LEFT SIDEBAR -->
 <aside class="sidebar">
 <div class="brand">
 <span class="brand-dot"></span>
 <span>FIBERHELP</span>
 </div>

 <div class="sidebar-group">
 <button class="sidebar-btn @(currentPage == "dashboard" ? "active" : "")"
 @onclick="ShowDashboard">
 <span class="icon">🏠</span>
 <span>Dashboard</span>
 </button>
 <button class="sidebar-btn @(currentPage == "tickets" ? "active" : "")"
 @onclick="ShowTickets">
 <span class="icon">🎫</span>
 <span>Tickets</span>
 </button>
 <button class="sidebar-btn @(currentPage == "customers" ? "active" : "")"
 @onclick="ShowCustomers">
 <span class="icon">👥</span>
 <span>Customers</span>
 </button>
 <button class="sidebar-btn @(currentPage == "billing" ? "active" : "")"
 @onclick="ShowBilling">
 <span class="icon">💳</span>
 <span>Billing</span>
 </button>
 <button class="sidebar-btn @(currentPage == "reports" ? "active" : "")"
 @onclick="ShowReports">
 <span class="icon">📊</span>
 <span>Reports</span>
 </button>
 </div>

 <div class="sidebar-group muted">
 <button class="sidebar-btn @(currentPage == "settings" ? "active" : "")"
 @onclick="ShowSettings">
 <span class="icon">⚙️</span>
 <span>Settings</span>
 </button>
 <button class="sidebar-btn danger">
 <span class="icon">↩</span>
 <span>Logout</span>
 </button>
 </div>
 </aside>

 <!-- MAIN CONTENT -->
 <main class="main">
 <div class="main-inner">
 @if (currentPage == "dashboard")
 {
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Dashboard</h1>
 </div>
 <div class="top-actions">
 <button class="btn subtle">Export</button>
 <button class="btn primary">+ New Ticket</button>
 <div class="user-pill">
 <div class="avatar">FH</div>
 <div class="user-meta">
 <p class="user-email">neiljohnadlawan@gmail.com</p>
 <p class="user-role">Admin</p>
 </div>
 </div>
 </div>
 </header>

 <section class="kpi-grid">
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Total Customers</span>
 <span class="badge success">+4.5%</span>
 </div>
 <h2>128</h2>
 <p class="kpi-sub">sample trend only</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Active Subscriptions</span>
 <span class="badge success">+2.1%</span>
 </div>
 <h2>94</h2>
 <p class="kpi-sub">active this month</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Open Tickets</span>
 <span class="badge warning">3 high</span>
 </div>
 <h2>7</h2>
 <p class="kpi-sub">need agent response</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Pending Invoices</span>
 <span class="badge danger">follow up</span>
 </div>
 <h2>₱30,000</h2>
 <p class="kpi-sub">unpaid amount</p>
 </article>
 </section>

 <section class="body-grid">
 <div class="panel">
 <div class="panel-head">
 <div>
 <h2>Latest Tickets</h2>
 <p class="muted-text">Most recent customer issues</p>
 </div>
 <div class="filter-pill">This week</div>
 </div>
 <table class="data-table">
 <thead>
 <tr>
 <th>Ticket #</th>
 <th>Account</th>
 <th>Subject</th>
 <th>Status</th>
 <th>Created</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var t in tickets.Take(4))
 {
 <tr>
 <td>@t.Id</td>
 <td>@t.Customer</td>
 <td>@t.Title</td>
 <td>
 <span class="status-pill @t.Status.ToLower().Replace(" ", "")">
 @t.Status
 </span>
 </td>
 <td>@GetTimeAgo(t.Created)</td>
 </tr>
 }
 </tbody>
 </table>
 </div>

 <div class="panel">
 <div class="panel-head">
 <h2>Today’s Activity</h2>
 <p class="muted-text">Recent actions</p>
 </div>
 <ul class="activity-list">
 <li class="activity success">
 <span class="dot"></span>
 Ticket #7004 assigned to <strong>CSR-01</strong>
 <span class="time">10 mins ago</span>
 </li>
 <li class="activity warning">
 <span class="dot"></span>
 New customer registered: <strong>Kisha Tan</strong>
 <span class="time">25 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
 Invoice reminder sent to <strong>Fiber Corp</strong>
 <span class="time">35 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
2 tickets waiting for update
 <span class="time">1 hr ago</span>
 </li>
 </ul>
 </div>
 </section>
 }
 else if (currentPage == "tickets")
 {
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Tickets</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary">+ New Ticket</button>
 </div>
 </header>
 <section class="panel">
 <table class="data-table">
 <thead>
 <tr>
 <th>Ticket ID</th>
 <th>Title</th>
 <th>Customer</th>
 <th>Priority</th>
 <th>Status</th>
 <th>Created</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var ticket in tickets)
 {
 <tr>
 <td>@ticket.Id</td>
 <td>@ticket.Title</td>
 <td>@ticket.Customer</td>
 <td><span class="status-pill priority">@ticket.Priority</span></td>
 <td><span class="status-pill @ticket.Status.ToLower().Replace(" ", "")">@ticket.Status</span></td>
 <td>@GetTimeAgo(ticket.Created)</td>
 </tr>
 }
 </tbody>
 </table>
 </section>
 }
 else if (currentPage == "customers")
 {
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Customers</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary">+ Add Customer</button>
 </div>
 </header>
 <section class="panel">
 <table class="data-table">
 <thead>
 <tr>
 <th>Customer ID</th>
 <th>Name</th>
 <th>Email</th>
 <th>Plan</th>
 <th>Status</th>
 <th>Join Date</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var customer in customers)
 {
 <tr>
 <td>@customer.Id</td>
 <td>@customer.Name</td>
 <td>@customer.Email</td>
 <td>@customer.Plan</td>
 <td><span class="status-pill @customer.Status.ToLower()">@customer.Status</span></td>
 <td>@customer.JoinDate.ToString("MMM dd, yyyy")</td>
 </tr>
 }
 </tbody>
 </table>
 </section>
 }
 else
 {
 <header class="topbar">
 <h1 class="page-title">@currentPage</h1>
 </header>
 <section class="panel">
 <p>Placeholder for @currentPage page.</p>
 </section>
 }
 </div>
 </main>
</div>

@code {
 private string currentPage = "dashboard";

 private void ShowDashboard() => currentPage = "dashboard";
 private void ShowTickets() => currentPage = "tickets";
 private void ShowCustomers() => currentPage = "customers";
 private void ShowBilling() => currentPage = "billing";
 private void ShowReports() => currentPage = "reports";
 private void ShowSettings() => currentPage = "settings";

 private List<Ticket> tickets = new()
 {
 new Ticket { Id = "7001", Title = "Slow internet", Customer = "Neil Adlawan", Priority = "High", Status = "Open", Created = DateTime.Now.AddMinutes(-10) },
 new Ticket { Id = "7002", Title = "Billing inquiry", Customer = "Jaspher Ondangan", Priority = "Low", Status = "Resolved", Created = DateTime.Now.AddMinutes(-35) },
 new Ticket { Id = "7003", Title = "No connection", Customer = "Fiber Corp", Priority = "Medium", Status = "In-Progress", Created = DateTime.Now.AddHours(-1) },
 new Ticket { Id = "7004", Title = "Account locked", Customer = "Kisha Tan", Priority = "High", Status = "Open", Created = DateTime.Now.AddHours(-2) },
 };

 private List<Customer> customers = new()
 {
 new Customer { Id = "CUST-001", Name = "Neil Adlawan", Email = "neil@email.com", Plan = "Fiber100Mbps", Status = "Active", JoinDate = DateTime.Now.AddMonths(-4) },
 new Customer { Id = "CUST-002", Name = "Jaspher Ondangan", Email = "jaspher@email.com", Plan = "Fiber50Mbps", Status = "Active", JoinDate = DateTime.Now.AddMonths(-7) },
 new Customer { Id = "CUST-003", Name = "Fiber Corp", Email = "support@fibercorp.com", Plan = "Fiber Biz200Mbps", Status = "Active", JoinDate = DateTime.Now.AddMonths(-12) },
 };

 private string GetTimeAgo(DateTime date)
 {
 var span = DateTime.Now - date;
 if (span.TotalMinutes <60) return $"{(int)span.TotalMinutes} mins ago";
 if (span.TotalHours <24) return $"{(int)span.TotalHours} hrs ago";
 return $"{(int)span.TotalDays} days ago";
 }

 private class Ticket
 {
 public string Id { get; set; } = "";
 public string Title { get; set; } = "";
 public string Customer { get; set; } = "";
 public string Priority { get; set; } = "";
 public string Status { get; set; } = "";
 public DateTime Created { get; set; }
 }

 private class Customer
 {
 public string Id { get; set; } = "";
 public string Name { get; set; } = "";
 public string Email { get; set; } = "";
 public string Plan { get; set; } = "";
 public string Status { get; set; } = "";
 public DateTime JoinDate { get; set; }
 }
}

<style>@(new MarkupString(@":root {
 --bg: #eef3fb;
 --panel: #f6f8fb;
 --muted: #6b7280;
 --text: #0f172a;
 --sidebar-start: #4c1d95;
 --sidebar-end: #0b254a;
 --accent: #7c3aed;
 --primary: #2563eb;
 --success: #10b981;
 --warning: #f59e0b;
 --danger: #ef4444;
 --card-shadow:010px30px rgba(15,23,42,0.06);
 --border:1px solid rgba(15,23,42,0.08);
 --radius:12px;
 --base-font:16px;
 --large-font:20px;
 --xlarge-font:26px;
}

/* Make sure page fills viewport and no browser margins */
html, body, #app {
 height:100%;
 width:100%;
 margin:0;
 padding:0;
 font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
 font-size: var(--base-font);
 color: var(--text);
}

.app-shell {
 display: flex;
 min-height:100vh;
 background: var(--bg);
}

/* SIDEBAR - fixed to left and larger */
.sidebar {
 position: fixed;
 left:0;
 top:0;
 bottom:0;
 width:360px;
 min-width:360px;
 background: linear-gradient(180deg, var(--sidebar-start), var(--sidebar-end));
 color: rgba(255,255,255,0.95);
 padding:24px16px;
 display: flex;
 flex-direction: column;
 gap:16px;
 box-shadow:4px18px40px rgba(11,17,34,0.12);
 z-index:20;
}

.brand { display:flex; align-items:center; gap:.6rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase; color:#fff; }
.brand-dot { width:.7rem; height:.7rem; border-radius:999px; background: rgba(255,255,255,0.16); }

.sidebar-group { display:flex; flex-direction:column; gap:8px; }
.sidebar-group.muted { margin-top:auto; }

.sidebar-btn {
 background: transparent;
 border: none;
 color: rgba(255,255,255,0.92);
 padding:12px10px;
 display:flex;
 align-items:center;
 gap:.6rem;
 cursor:pointer;
 font-weight:600;
 font-size: var(--large-font);
 text-align:left;
 border-radius:8px;
}

.sidebar-btn .icon { width:1.6rem; text-align:center; }
.sidebar-btn:hover { background: rgba(255,255,255,0.04); transform: translateX(6px); }
.sidebar-btn.active { background: rgba(255,255,255,0.06); color:#fff; font-weight:800; }
.sidebar-btn.danger { color: rgba(255,200,200,0.95); }

/* MAIN content pushed right to account for fixed sidebar */
.main {
 margin-left:360px;
 flex:1;
 display:flex;
 flex-direction:column;
 padding:28px32px32px32px;
}

.main-inner {
 max-width:1200px;
 margin:24px auto;
 width:100%;
 padding:20px;
}

/* Center page title and make it prominent */
.topbar { display:flex; justify-content:center; align-items:center; padding-bottom:12px; }
.topbar > div { text-align:center; }
.eyebrow { text-transform:uppercase; font-size:.78rem; letter-spacing:.12em; color:var(--muted); margin-bottom:6px; }
.page-title { font-size: var(--xlarge-font); font-weight:900; color:var(--text); margin:0; }

.top-actions { position:absolute; right:48px; top:26px; display:flex; gap:10px; }
.btn { border:none; padding:10px16px; border-radius:10px; font-size:var(--large-font); cursor:pointer; font-weight:700; }
.btn.subtle { background: transparent; border: var(--border); color: var(--text); }
.btn.primary { background:var(--primary); color:#fff; box-shadow:08px22px rgba(37,99,235,0.12); }

.user-pill { display:flex; gap:10px; align-items:center; background:var(--panel); border-radius:999px; padding:8px12px; box-shadow:var(--card-shadow); }
.avatar { width:44px; height:44px; background:var(--accent); color:#fff; border-radius:999px; display:grid; place-items:center; font-weight:800; font-size:var(--large-font); }

/* KPI grid: center text, larger numbers, add stronger border */
.kpi-grid { display:grid; grid-template-columns: repeat(4,1fr); gap:20px; margin-top:18px; }
.kpi-card { background:var(--panel); border-radius:var(--radius); padding:20px; border: var(--border); box-shadow:var(--card-shadow); text-align:center; }
.kpi-header { display:block; color:var(--muted); font-size:.9rem; margin-bottom:8px; }
.kpi-card h2 { font-size:28px; margin:6px04px0; font-weight:900; color:var(--text); }
.kpi-sub { color:#8b95a1; font-size:.9rem; }

.badge { padding:.2rem .5rem; border-radius:999px; font-weight:800; font-size:.78rem; }
.badge.success { background: rgba(16,185,129,0.10); color:var(--success); }
.badge.warning { background: rgba(245,158,11,0.08); color:var(--warning); }
.badge.danger { background: rgba(239,68,68,0.06); color:var(--danger); }

/* Body grid: panels centered, panel heads centered, add border to each panel and table rows */
.body-grid { display:grid; grid-template-columns:1.1fr .55fr; gap:20px; margin-top:22px; }
.panel { background:var(--panel); border-radius:var(--radius); padding:18px; border: var(--border); box-shadow:var(--card-shadow); }
.panel-head { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; margin-bottom:12px; }
.panel-head h2 { margin:0; font-size:18px; font-weight:800; }
.muted-text { color:var(--muted); font-size:.92rem; }
.filter-pill { background:transparent; border:var(--border); padding:8px12px; border-radius:10px; }

.data-table { width:100%; border-collapse: collapse; font-size: .95rem; }
.data-table thead th { text-align:left; padding:12px; color:var(--muted); font-weight:800; border-bottom: var(--border); }
.data-table tbody tr { border-bottom: var(--border); }
.data-table td { padding:12px; color: rgba(15,23,42,0.92); }

.status-pill { display:inline-block; padding:6px10px; border-radius:999px; font-weight:800; font-size:.85rem; background: rgba(96,165,250,0.06); color:#2563eb; }
.status-pill.open { background: rgba(239,68,68,0.06); color:var(--danger); }
.status-pill.resolved { background: rgba(16,185,129,0.08); color:var(--success); }
.status-pill.in-progress, .status-pill.inprogress { background: rgba(245,158,11,0.06); color:var(--warning); }

/* Activity items: center and border */
.activity-list { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:12px; }
.activity { background:var(--panel); border-radius:10px; padding:14px; border: var(--border); display:flex; flex-direction:column; gap:8px; }
.activity .dot { width:10px; height:10px; border-radius:999px; background:var(--accent); display:inline-block; margin-right:10px; }
.activity .time { display:block; color:var(--muted); margin-top:6px; font-size:.88rem; }

/* Emphasize headers */
.panel-head h2, .kpi-card h2, .page-title { text-align:center; }

/* Responsive: collapse columns, move sidebar to top on small screens */
@media (max-width:1080px) {
 .sidebar { position: static; width:100%; min-width:auto; box-shadow:none; }
 .main { margin-left:0; padding:16px; }
 .kpi-grid { grid-template-columns: repeat(2,1fr); }
 .body-grid { grid-template-columns:1fr; }
 .top-actions { position:static; margin-top:10px; }
 .sidebar-btn { font-size:16px; }
}
"))</style>
