@page "/tickets"
@using FiberHelp.Models
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.AdminService AdminService
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JS

@* Using global admin-theme.css; removed page-specific CSS *@

<style>
  .tickets-header{display:flex;align-items:center;justify-content:space-between;padding-bottom:20px;margin-bottom:22px;border-bottom:1px solid #e5e7eb}
  .tickets-header .page-title{font-size:42px;line-height:1.1;margin:0 0 4px}
  .tickets-controls{display:flex;gap:14px;align-items:center}
  .tickets-search{width:360px;padding:12px 18px;border-radius:14px;border:1px solid #e5e7eb;background:#fff;box-shadow:0 8px 22px rgba(2,6,23,0.08);font-size:15px}
  .tickets-controls .btn.subtle{background:#fff;color:#0f172a;border:1px solid #e5e7eb;border-radius:14px;padding:10px 22px;box-shadow:0 4px 10px rgba(2,6,23,0.04)}
  .tickets-controls .btn.primary{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border:none;border-radius:14px;padding:10px 26px;box-shadow:0 14px 32px rgba(29,78,216,0.30);font-weight:600}

  .tickets-table{width:100%;border-collapse:separate;border-spacing:0 10px}
  .tickets-table thead th{font-size:13px;font-weight:700;padding:10px 12px;color:#475569;text-align:left;border-bottom:1px solid #e5e7eb}
  .tickets-table tbody td{background:#f9fafb;padding:14px 12px;font-size:14px;border-top:1px solid #edf2f7;border-bottom:1px solid #edf2f7}
  .tickets-table tbody tr td:first-child{border-left:1px solid #edf2f7;border-top-left-radius:12px;border-bottom-left-radius:12px}
  .tickets-table tbody tr td:last-child{border-right:1px solid #edf2f7;border-top-right-radius:12px;border-bottom-right-radius:12px}

  .cust-cell{display:flex;align-items:center;gap:12px}
  .cust-avatar{width:40px;height:40px;border-radius:999px;background:linear-gradient(135deg,#6366f1,#0ea5e9);display:grid;place-items:center;font-weight:800;color:#fff;font-size:14px;box-shadow:0 8px 18px rgba(99,102,241,0.25)}
  .cust-name{font-weight:600}
  .cust-email{font-size:11px;color:#64748b}

  .badge{display:inline-block;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:700}
  .badge-prio-low{background:#e0f2fe;color:#075985;border:1px solid #bae6fd}
  .badge-prio-medium{background:#fef9c3;color:#92400e;border:1px solid #fde68a}
  .badge-prio-high{background:#fee2e2;color:#7f1d1d;border:1px solid #fecaca}
  .badge-prio-critical{background:#ffe4e6;color:#881337;border:1px solid #fecdd3}

  .badge-status-open{background:#e0f2fe;color:#075985;border:1px solid #bae6fd}
  .badge-status-inprogress{background:#dbeafe;color:#1e3a8a;border:1px solid #bfdbfe}
  .badge-status-resolved{background:#dcfce7;color:#065f46;border:1px solid #bbf7d0}
  .badge-status-closed{background:#e2e8f0;color:#475569;border:1px solid #cbd5e1}

  .action-btn{border:none;background:transparent;padding:6px 8px;border-radius:10px;cursor:pointer}
  .action-btn:hover{background:#eef2ff}

  .dropdown-list { list-style:none; margin:0; padding:0; max-height:180px; overflow:auto; background:#fff; border:1px solid #e5e7eb; box-shadow:0 6px 16px rgba(0,0,0,0.06); border-radius:10px }
  .dropdown-list li { padding:8px 12px; cursor:pointer }
  .dropdown-list li:hover { background:#f1f5f9 }
  .selected-customer { margin-top:8px; font-size:0.9rem; color:#334155; font-weight:600 }

  /* Modal styles */
  .modal-bg { position:fixed; inset:0; background:rgba(2,6,23,0.65); display:grid; place-items:center; z-index:40000; -webkit-backdrop-filter: blur(4px); backdrop-filter: blur(4px); }
  .modal-card { width:640px; max-width:94vw; background:#ffffff; border-radius:14px; padding:22px; box-shadow:0 40px 80px rgba(2,6,23,0.35); position:relative; z-index:40001; max-height:86vh; overflow:auto; border:1px solid rgba(15,23,42,0.04) }
  .modal-header { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:8px }
  .modal-header h3 { margin:0; font-size:22px }
  .modal-desc { margin:6px 0 0; color:#64748b; font-size:0.95rem }
  .modal-close { position:absolute; right:14px; top:12px; border:none; background:transparent; cursor:pointer; font-size:18px; color:#64748b; padding:6px; border-radius:8px }
  .modal-close:hover { background:rgba(2,6,23,0.04); color:#111827 }
  .form-group { display:flex; flex-direction:column; gap:6px; margin-top:10px }
  .form-input { padding:10px 12px; border:1px solid #e6edf3; border-radius:8px; font-size:14px; background:#fff }
  .modal-actions { display:flex; justify-content:flex-end; gap:10px; margin-top:16px }
  .btn.primary { padding:10px 18px; border-radius:10px }

  @@media (max-width:700px){ .modal-card{width:94vw;padding:14px} .modal-header h3{font-size:18px} .dropdown-list{max-height:150px} }
</style>

<div>
 <header class="tickets-header">
   <div>
     <p class="eyebrow">FIBERHELP · @GetRoleLabel()</p>
     <h1 class="page-title">Tickets</h1>
   </div>
   <div class="tickets-controls">
     <input class="tickets-search" placeholder="Search tickets by id, title or customer" @bind="ticketSearch" @oninput="_ => StateHasChanged()" />
     <button class="btn subtle" @onclick="ExportTickets">Export</button>
     <button class="btn primary" @onclick="ShowNewTicketModal">+ New Ticket</button>
   </div>
 </header>

 <section class="panel">
 <table class="tickets-table">
 <thead>
 <tr>
 <th>Ticket ID</th>
 <th>Title</th>
 <th>Customer</th>
 <th>Priority</th>
 <th>Status</th>
 <th>Created</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @if (FilteredTickets != null)
 {
 @foreach (var ticket in FilteredTickets)
 {
 <tr>
   <td>@ticket.Id</td>
   <td style="font-weight:600">@ticket.Title</td>
   <td>
     <div class="cust-cell">
       <div class="cust-avatar">@GetCustomerDisplay(ticket.Customer).Substring(0,1).ToUpper()</div>
       <div>
         <div class="cust-name">@GetCustomerDisplay(ticket.Customer)</div>
         <div class="cust-email">@FormatLocal(ticket.Created)</div>
       </div>
     </div>
   </td>
   <td><span class="badge @(GetPriorityBadge(ticket.Priority))">@ticket.Priority</span></td>
   <td><span class="badge @(GetStatusBadge(ticket.Status))">@ticket.Status</span></td>
   <td>@GetTimeAgo(ticket.Created)</td>
   <td>
     <button class="action-btn edit" title="Edit" @onclick="() => ShowEditTicketModal(ticket)">
       <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
         <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" fill="#2563eb" />
         <path d="M20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="#2563eb" />
       </svg>
     </button>
     <button class="action-btn delete" title="Delete" @onclick="() => DeleteTicketAsync(ticket.Id)">
       <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
         <path d="M3 6h18" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
         <path d="M8 6v12a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
         <path d="M10 11v6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
         <path d="M14 11v6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
         <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
       </svg>
     </button>
   </td>
 </tr>
 }
 }
 </tbody>
 </table>
 </section>

 @* New Ticket modal with dim backdrop *@
 @if (showNewTicketModal)
 {
 <div class="modal-bg" @onclick="CloseNewTicketModal">
 <div @onclick:stopPropagation class="modal-card">
   <button class="modal-close" @onclick="CloseNewTicketModal" aria-label="Close">✕</button>
   <div class="modal-header">
     <div>
       <h3>New Ticket</h3>
       <div class="modal-desc">Create a ticket and assign to a customer account. Select account from the list or type a customer name.</div>
     </div>
   </div>
   <div style="margin-top:8px;">
   <div class="form-group">
   <label>Account (search or scroll)</label>
   <input class="form-input" @bind="newAccountSearch" @oninput="OnNewAccountSearch" placeholder="Search account number or customer name..." autofocus />
   <div style="max-height:220px;overflow:auto;border:1px solid #eef2f7;border-radius:8px;margin-top:8px;padding:6px;">
   @if(filteredAccounts != null && filteredAccounts.Any())
   {
   <ul class="dropdown-list" style="max-height:200px;overflow:auto;">
   @foreach(var a in filteredAccounts)
   {
   <li style="display:flex;justify-content:space-between;align-items:center;padding:8px 10px;" @onclick="() => SelectAccount(a)">
   <div>
   <div style="font-weight:700">@a.AccountNumber</div>
   <div style="font-size:0.9rem;color:#64748b">@GetCustomerName(a.CustomerId) � @a.ServicePlan</div>
   </div>
   <div style="color:#2563eb;font-weight:700">Select</div>
   </li>
   }
   </ul>
   }
   else
   {
   <div style="padding:10px;color:#64748b">No accounts match the search.</div>
   }
   </div>

   @if (!string.IsNullOrEmpty(newTicketAccountNumber))
   {
   <div class="selected-customer">Selected: @newTicketAccountNumber � @newTicketCustomerName</div>
   }
   </div>

   <div class="form-group">
   <label>Title</label>
   <input class="form-input" @bind="newTicketTitle" placeholder="Enter ticket title" />
   </div>

   <div class="form-group">
   <label>Priority</label>
   <select class="form-input" @bind="newTicketPriority">
   <option value="Low">Low</option>
   <option value="Medium">Medium</option>
   <option value="High">High</option>
   <option value="Critical">Critical</option>
   </select>
   </div>

   <div class="form-group">
   <label>Status</label>
   <select class="form-input" @bind="newTicketStatus">
   <option value="Open">Open</option>
   <option value="In Progress">In Progress</option>
   <option value="Resolved">Resolved</option>
   <option value="Closed">Closed</option>
   </select>
   </div>

   <div class="modal-actions">
   <button class="btn" @onclick="CloseNewTicketModal">Cancel</button>
   <button class="btn primary" @onclick="OnCreateNewTicketClicked">Create</button>
   </div>
   @if (!string.IsNullOrEmpty(serviceError))
   {
   <p style="color:#dc2626;font-size:0.85rem;margin-top:8px;">@serviceError</p>
   }
   </div>
 </div>
 </div>
 }

 @* Edit Ticket modal with dim backdrop *@
 @if (showEditTicketModal && editingTicket != null)
 {
 <div class="modal-bg" @onclick="CloseEditTicketModal">
 <div @onclick:stopPropagation class="modal-card">
   <button class="modal-close" @onclick="CloseEditTicketModal" aria-label="Close">✕</button>
   <div class="modal-header">
     <div>
       <h3>Edit Ticket</h3>
       <div class="modal-desc">Change ticket details and save updates.</div>
     </div>
   </div>
   <div class="form-group">
   <label>Ticket ID</label>
   <input class="form-input" value="@editingTicket.Id" disabled />
   </div>
   <div class="form-group">
   <label>Title</label>
   <input class="form-input" @bind="editingTicket.Title" placeholder="Enter ticket title" />
   </div>
   <div class="form-group">
   <label>Customer</label>
   <select class="form-input" @bind="editingTicket.Customer">
   <option value="">Select customer</option>
   @if (customers != null)
   {
   @foreach (var c in customers)
   {
   <option value="@c.Name">@c.Name</option>
   }
   }
   </select>
   </div>
   <div class="form-group">
   <label>Priority</label>
   <select class="form-input" @bind="editingTicket.Priority">
   <option value="Low">Low</option>
   <option value="Medium">Medium</option>
   <option value="High">High</option>
   <option value="Critical">Critical</option>
   </select>
   </div>
   <div class="form-group">
   <label>Status</label>
   <select class="form-input" @bind="editingTicket.Status">
   <option value="Open">Open</option>
   <option value="In Progress">In Progress</option>
   <option value="Resolved">Resolved</option>
   <option value="Closed">Closed</option>
   </select>
   </div>
   <div class="form-group">
   <label>Created</label>
   <input class="form-input" value="@editingTicket.Created.ToString("yyyy-MM-dd HH:mm")" disabled />
   </div>
   <div class="modal-actions">
   <button class="btn" @onclick="CloseEditTicketModal">Cancel</button>
   <button class="btn primary" @onclick="UpdateTicketAsync">Update</button>
   </div>
 </div>
 </div>
 }

 <Toast Message="@ticketToast" />
@if (!string.IsNullOrEmpty(ticketToast))
{
 <div class="toast">@ticketToast</div>
}
</div>

@code {
 private List<Ticket>? tickets;
 private List<Customer>? customers;
 private string ticketSearch = string.Empty;

 // New Ticket Modal
 private bool showNewTicketModal = false;
 private string newTicketTitle = "";
 private string newTicketCustomer = ""; // will store customer id
 private string newTicketCustomerName = ""; // display name
 private string newTicketAccountNumber = ""; // selected account number
 private string newTicketPriority = "Medium";
 private string newTicketStatus = "Open";

 // Account search helpers
 private string newAccountSearch = string.Empty;
 private List<Account>? accounts;
 private List<Account>? filteredAccounts;

 // Edit Ticket Modal
 private bool showEditTicketModal = false;
 private Ticket? editingTicket = null;

 private string ticketToast = string.Empty;
 private string serviceError = string.Empty;
 
 protected override async Task OnInitializedAsync()
 {
 // Check if user is authenticated
 if (!AuthService.IsAuthenticated)
 {
 Navigation.NavigateTo("/login", true);
 return;
 }

 await LoadDataAsync();
 }

 private async Task LoadDataAsync()
 {
 tickets = await AdminService.GetTicketsAsync();
 customers = await AdminService.GetCustomersAsync();
 StateHasChanged();
 }

 // New Ticket Methods
 private void ShowNewTicketModal()
 {
 System.Diagnostics.Debug.WriteLine("ShowNewTicketModal clicked");
 newTicketTitle = "";
 newTicketCustomer = "";
 newTicketCustomerName = "";
 newTicketAccountNumber = "";
 newTicketPriority = "Medium";
 newTicketStatus = "Open";
 newAccountSearch = string.Empty;
 // build accounts if not loaded (synthesise from customers)
 if (accounts == null)
 {
 accounts = new List<Account>();
 if (customers != null)
 {
 int i = 1;
 foreach (var c in customers)
 {
 accounts.Add(new Account { Id = i, AccountNumber = "ACCT-" + (i+1).ToString("000000"), CustomerId = c.Id, Customer = c, ServicePlan = c.Plan, IsActive = true });
 i++;
 }
 }
 }
 filteredAccounts = accounts;
 showNewTicketModal = true;
 StateHasChanged();
 }

 private void CloseNewTicketModal()
 {
 System.Diagnostics.Debug.WriteLine("CloseNewTicketModal called");
 showNewTicketModal = false;
 // reset search and selection when closing
 newAccountSearch = string.Empty;
 newTicketAccountNumber = string.Empty;
 newTicketCustomer = string.Empty;
 newTicketCustomerName = string.Empty;
 StateHasChanged();
 }

 private async Task OnCreateNewTicketClicked()
 {
 System.Diagnostics.Debug.WriteLine($"CreateNewTicketAsync called, customer='{newTicketCustomer}', title='{newTicketTitle}'");
 // If user typed a customer name but didn't pick from dropdown, use that as customer
 // require account or customer
 if (string.IsNullOrWhiteSpace(newTicketAccountNumber) && string.IsNullOrWhiteSpace(newTicketCustomer))
 {
 ticketToast = "Title and Customer are required.";
 StateHasChanged();
 await Task.Delay(2000);
 ticketToast = string.Empty;
 StateHasChanged();
 return;
 }

 if (string.IsNullOrWhiteSpace(newTicketTitle))
 {
 ticketToast = "Title is required.";
 StateHasChanged();
 await Task.Delay(2000);
 ticketToast = string.Empty;
 StateHasChanged();
 return;
 }

 var ticket = new Ticket
 {
 Title = newTicketTitle,
 Customer = newTicketCustomer,
 CustomerName = newTicketCustomerName, // capture display name for immediate UI use
 Priority = newTicketPriority,
 Status = newTicketStatus,
 Created = DateTime.UtcNow
 };

 // If account number selected, try to attach AccountId (if your Ticket model supports it)
 if (!string.IsNullOrWhiteSpace(newTicketAccountNumber) && accounts != null)
 {
 var acct = accounts.FirstOrDefault(a => string.Equals(a.AccountNumber, newTicketAccountNumber, StringComparison.OrdinalIgnoreCase));
 if (acct != null)
 {
 ticket.AccountId = acct.Id;
 // ensure customer fields match
 ticket.Customer = acct.CustomerId;
 ticket.CustomerName = acct.Customer?.Name ?? ticket.CustomerName;
 }
 }

 var ok = await AdminService.CreateTicketAsync(ticket);
 if (ok)
 {
 serviceError = string.Empty;
 ticketToast = "Ticket created.";
 await LoadDataAsync();
 CloseNewTicketModal();
 }
 else
 {
 serviceError = AdminService.LastError ?? "Unknown error";
 ticketToast = "Failed to create ticket. Check logs.";
 }
 StateHasChanged();
 await Task.Delay(2000);
 ticketToast = string.Empty;
 StateHasChanged();
 }

 private void OnNewAccountSearch(ChangeEventArgs e)
 {
 newAccountSearch = e.Value?.ToString() ?? string.Empty;
 if (accounts == null) { filteredAccounts = new List<Account>(); return; }
 if (string.IsNullOrWhiteSpace(newAccountSearch)) filteredAccounts = accounts;
 else filteredAccounts = accounts.Where(a => (!string.IsNullOrEmpty(a.AccountNumber) && a.AccountNumber.Contains(newAccountSearch, StringComparison.OrdinalIgnoreCase)) || (a.Customer != null && !string.IsNullOrEmpty(a.Customer.Name) && a.Customer.Name.Contains(newAccountSearch, StringComparison.OrdinalIgnoreCase))).ToList();
 }

 private void SelectAccount(Account a)
 {
 if (a == null) return;
 newTicketAccountNumber = a.AccountNumber;
 newTicketCustomer = a.CustomerId;
 newTicketCustomerName = a.Customer?.Name ?? string.Empty;
 filteredAccounts = new List<Account>();
 StateHasChanged();
 }

 // Edit Ticket Methods
 private void ShowEditTicketModal(Ticket ticket)
 {
 // Create a copy to avoid modifying the original until save
 editingTicket = new Ticket
 {
 Id = ticket.Id,
 Title = ticket.Title,
 Customer = ticket.Customer,
 Priority = ticket.Priority,
 Status = ticket.Status,
 Created = ticket.Created
 };
 showEditTicketModal = true;
 StateHasChanged();
 }

 private void CloseEditTicketModal()
 {
 showEditTicketModal = false;
 editingTicket = null;
 StateHasChanged();
 }

 private async Task UpdateTicketAsync()
 {
 if (editingTicket == null || string.IsNullOrWhiteSpace(editingTicket.Title) || string.IsNullOrWhiteSpace(editingTicket.Customer))
 {
 return;
 }

 await AdminService.UpdateTicketAsync(editingTicket);
 await LoadDataAsync();
 CloseEditTicketModal();
 }

 // Delete Ticket Method
 private async Task DeleteTicketAsync(int id)
 {
 if (id <=0) return;
 await AdminService.DeleteTicketAsync(id);
 await LoadDataAsync();
 }

 private async void ExportTickets()
 {
   var rows = tickets ?? new List<Ticket>();
   var csv = new System.Text.StringBuilder();
   csv.AppendLine("Id,Title,Customer,Priority,Status,Created");
   foreach(var t in rows)
     csv.AppendLine($"{t.Id},{Escape(t.Title)},{Escape(GetCustomerDisplay(t.Customer))},{t.Priority},{t.Status},{t.Created:yyyy-MM-dd HH:mm}");
   await JS.InvokeAsync<bool>("FiberExport.saveFile", "tickets.csv", csv.ToString());
   ticketToast = "Tickets exported"; StateHasChanged();
   _ = ClearToastAfterDelay();
 }

 private async Task ClearToastAfterDelay()
 {
   await Task.Delay(2200);
   ticketToast = string.Empty; StateHasChanged();
 }

 private string Escape(string? s) => string.IsNullOrEmpty(s) ? "" : s!.Replace("\"","\"\"");

 // Helper Methods
 private string GetTimeAgo(DateTime createdUtc)
 {
 // Treat incoming as UTC (DB stores SYSUTCDATETIME / code uses DateTime.UtcNow)
 var utc = DateTime.SpecifyKind(createdUtc, DateTimeKind.Utc);
 var span = DateTime.UtcNow - utc;
 if (span.TotalMinutes <1) return "just now";
 if (span.TotalMinutes <60) return $"{(int)span.TotalMinutes} mins ago";
 if (span.TotalHours <24) return $"{(int)span.TotalHours} hrs ago";
 return $"{(int)span.TotalDays} days ago";
 }

 private string GetCustomerDisplay(string customerField)
 {
 if (string.IsNullOrEmpty(customerField)) return "";
 // if customers list is loaded, try to resolve id -> name
 if (customers != null)
 {
 var byId = customers.FirstOrDefault(c => c.Id == customerField);
 if (byId != null) return byId.Name ?? customerField;

 var byName = customers.FirstOrDefault(c => string.Equals(c.Name, customerField, StringComparison.OrdinalIgnoreCase));
 if (byName != null) return byName.Name;
 }
 return customerField;
 }

 private string GetCustomerName(string id)
 {
 if (string.IsNullOrEmpty(id)) return string.Empty;
 if (customers == null) return id;
 var c = customers.FirstOrDefault(x => x.Id == id);
 return c?.Name ?? id;
 }

 // Optional: show explicit customer name if stored in ticket
 private string GetTicketCustomerLabel(Ticket t)
 {
 if (t == null) return string.Empty;
 if (!string.IsNullOrWhiteSpace(t.CustomerName)) return t.CustomerName;
 return GetCustomerDisplay(t.Customer);
 }

 // Optional: helper if you want to show exact local timestamp somewhere
 private string FormatLocal(DateTime createdUtc) => DateTime.SpecifyKind(createdUtc, DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-dd HH:mm");
 
 private IEnumerable<Ticket>? FilteredTickets => string.IsNullOrWhiteSpace(ticketSearch)
   ? tickets
   : tickets?.Where(t => (t.Id.ToString()).Contains(ticketSearch, StringComparison.OrdinalIgnoreCase)
                     || (t.Title ?? "").Contains(ticketSearch, StringComparison.OrdinalIgnoreCase)
                     || GetCustomerDisplay(t.Customer).Contains(ticketSearch, StringComparison.OrdinalIgnoreCase));

 private string GetPriorityBadge(string? pr)
 {
   if(string.IsNullOrWhiteSpace(pr)) return "badge-prio-low";
   return pr.ToLowerInvariant() switch {
     "low" => "badge-prio-low",
     "medium" => "badge-prio-medium",
     "high" => "badge-prio-high",
     "critical" => "badge-prio-critical",
     _ => "badge-prio-low"
   };
 }

 private string GetStatusBadge(string? st)
 {
   if(string.IsNullOrWhiteSpace(st)) return "badge-status-open";
   var s = st.ToLowerInvariant();
   if(s=="in progress") s="inprogress";
   return s switch {
     "open" => "badge-status-open",
     "inprogress" => "badge-status-inprogress",
     "resolved" => "badge-status-resolved",
     "closed" => "badge-status-closed",
     _ => "badge-status-open"
   };
 }
 
 private string GetRoleLabel()
 {
 var role = AuthService?.Role;
 if (string.IsNullOrWhiteSpace(role)) return "ADMIN VIEW"; // fallback for older installs
 return role.ToUpperInvariant();
 }
}
