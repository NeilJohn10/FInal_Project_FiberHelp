@page "/admin/agents"
@using FiberHelp.Models
@inject FiberHelp.Services.AdminService AdminService
@inject FiberHelp.Services.AuthService AuthService

<link href="css/dashboard.css" rel="stylesheet" />
<style>
.req-list{font-size:12px;margin-bottom:12px;display:flex;flex-direction:column;gap:4px}
.req{padding:4px8px;border:1px solid #e2e8f0;border-radius:6px;background:#f8fafc;display:flex;align-items:center;gap:6px}
.req.ok{border-color:#16a34a;background:#ecfdf5;color:#065f46}
.req.bad{border-color:#dc2626;background:#fef2f2;color:#991b1b}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center;z-index:10000}
.modal-card{background:#fff;border-radius:14px;padding:24px;width:100%;max-width:560px;box-shadow:012px40px rgba(0,0,0,.25);border:1px solid #e2e8f0}
</style>

@if(!AuthService.IsAuthenticated || !string.Equals(AuthService.Role,"Administrator",StringComparison.OrdinalIgnoreCase))
{
 <div class="panel"><strong>Access denied.</strong></div>
}
else
{
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN</p>
 <h1 class="page-title">Agents</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary" style="background:#2563eb;color:#fff;font-weight:700" @onclick="OpenModal">+ Register Agent</button>
 </div>
 </header>

 <section class="panel">
 <table class="data-table">
 <thead><tr><th>Email</th><th>Name</th><th>Role</th><th>Active</th><th></th></tr></thead>
 <tbody>
 @if(agents?.Count>0){
 @foreach(var a in agents){
 <tr>
 <td>@a.Email</td><td>@a.FullName</td><td>@a.Role</td><td>@(a.IsActive?"Yes":"No")</td>
 <td><button class="btn danger" @onclick="()=>DeleteAgent(a.Id)">Delete</button></td>
 </tr>
 }
 } else { <tr><td colspan="5">No agents found.</td></tr> }
 </tbody>
 </table>
 </section>

 @if(!string.IsNullOrEmpty(notification))
 { <div class="panel" style="margin-top:12px">@notification</div> }

 @if(showModal){
 <div class="modal-bg" @onclick="CloseModal">
 <div class="modal-card" @onclick:stopPropagation>
 <h3 style="margin:0018px0;font-size:22px;font-weight:800">Register Agent</h3>
 @if(!string.IsNullOrEmpty(errorMessage)) { <div class="error-message" style="margin-bottom:14px">@errorMessage</div> }
 <div class="form-group">
 <label>Email <span style="font-weight:400;color:#64748b">(work address)</span></label>
 <input class="form-input" @bind="newEmail" placeholder="agent@domain.com" />
 </div>
 <div class="form-group">
 <label>Full Name</label>
 <input class="form-input" @bind="newFullName" placeholder="Full name" />
 </div>
 <div class="form-group">
 <label>Department</label>
 <input class="form-input" @bind="newDept" placeholder="e.g. Support" />
 </div>
 <div class="form-group">
 <label>Phone</label>
 <input class="form-input" @bind="newPhone" placeholder="+639123456789" />
 </div>
 <div class="form-group" style="display:flex;align-items:center;gap:8px;margin-top:4px;">
 <input type="checkbox" @bind="newActive" style="width:18px;height:18px" /> <label style="margin:0">Active</label>
 </div>
 <div class="form-group">
 <label>Password <span style="font-weight:400;color:#64748b">(initial)</span></label>
 <input type="password" class="form-input" @bind="newPassword" @bind:event="oninput" placeholder="Initial password" />
 </div>
 @if(attempted && !IsValidPassword()){
 <div class="req-list" style="margin-top:4px;">
 <div class="req @(LenOk?"ok":"bad")">@(LenOk?"✔":"✖") Minimum12 characters</div>
 <div class="req @(UpperOk?"ok":"bad")">@(UpperOk?"✔":"✖") Uppercase letter</div>
 <div class="req @(DigitOk?"ok":"bad")">@(DigitOk?"✔":"✖") Digit</div>
 <div class="req @(SpecialOk?"ok":"bad")">@(SpecialOk?"✔":"✖") Special character</div>
 </div>
 }
 <div style="display:flex;justify-content:flex-end;gap:12px;margin-top:18px;">
 <button class="btn" @onclick="CloseModal">Cancel</button>
 <button class="btn primary" @onclick="CreateAgent">Create Agent</button>
 </div>
 </div>
 </div>
 }
}

@code {
 List<User>? agents;
 bool showModal=false;
 string newEmail=""; string newFullName=""; string newPassword="";
 string errorMessage=""; string notification=""; bool attempted=false;
 bool LenOk=>newPassword.Length>=12; bool UpperOk=>newPassword.Any(char.IsUpper); bool DigitOk=>newPassword.Any(char.IsDigit); bool SpecialOk=>newPassword.Any(c=>!char.IsLetterOrDigit(c));
 bool IsValidPassword()=>LenOk&&UpperOk&&DigitOk&&SpecialOk&& !string.IsNullOrWhiteSpace(newEmail);
 protected override async Task OnInitializedAsync(){ if(!AuthService.IsAuthenticated || !string.Equals(AuthService.Role,"Administrator",StringComparison.OrdinalIgnoreCase)) return; agents=await AdminService.GetAgentsAsync(); }
 void OpenModal(){ showModal=true; errorMessage=""; notification=""; newEmail=newFullName=newPassword=""; attempted=false; }
 void CloseModal(){ showModal=false; errorMessage=""; newEmail=newFullName=newPassword=""; attempted=false; }
 string newDept=""; string newPhone=""; bool newActive=true;
 async Task CreateAgent(){ attempted=true; errorMessage=""; notification=""; if(!IsValidPassword()){ errorMessage="Fill required fields & meet password rules."; return; } var u=new User{ Email=newEmail.Trim().ToLowerInvariant(), FullName=newFullName, Role="Agent", IsActive=newActive }; var ok=await AdminService.CreateAgentAsync(u,newPassword); if(ok){ notification="Agent created."; agents=await AdminService.GetAgentsAsync(); CloseModal(); } else { errorMessage=AdminService.LastError??"Create failed."; } }
 async Task DeleteAgent(string id){ if(string.IsNullOrEmpty(id)) return; if(await AdminService.DeleteUserAsync(id)){ notification="Agent deleted."; agents=await AdminService.GetAgentsAsync(); } }
}
