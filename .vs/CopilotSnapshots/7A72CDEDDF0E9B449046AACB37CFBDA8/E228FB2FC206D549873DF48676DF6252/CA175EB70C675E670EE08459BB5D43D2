     System.Diagnostics.Debug.WriteLine($"[Clients] OnCreateCustomerClicked error: {ex}");
     StateHasChanged();
     await Task.Delay(3000);
     toastMessage = string.Empty;
     StateHasChanged();
   }
 }

 private void DeleteCustomer(string id)
 {
   try
   {
     if ((AuthService.Role ?? "").Equals("Agent", StringComparison.OrdinalIgnoreCase))
     {
       toastMessage = "⚠️ Agents cannot delete clients";
       StateHasChanged();
       return;
     }
     
     if (string.IsNullOrEmpty(id))
     {
       toastMessage = "⚠️ Invalid client ID";
       StateHasChanged();
       return;
     }
     
     var customer = customers?.FirstOrDefault(c => c.Id == id);
     if (customer == null)
     {
       toastMessage = "🔍 Client not found";
       StateHasChanged();
       return;
     }
     
     deleteTargetId = id;
     deleteTargetName = customer.Name ?? $"Client {id}";
     showDeleteConfirm = true;
     StateHasChanged();
   }
   catch (Exception ex)
   {
     toastMessage = $"⚠️ Error: {ex.Message}";
     System.Diagnostics.Debug.WriteLine($"[Clients] DeleteCustomer error: {ex}");
     StateHasChanged();
   }
 }

 private async Task ConfirmDelete()
 {
   showDeleteConfirm = false;
   
   try
   {
     if (string.IsNullOrEmpty(deleteTargetId)) return;
     
     await AdminService.DeleteCustomerAsync(deleteTargetId);
     
     if (!string.IsNullOrEmpty(AdminService.LastError))
     {
       toastMessage = $"❌ Delete failed: {AdminService.LastError}";
     }
     else
     {
       toastMessage = "✅ Client deleted successfully";
     }
     
     await LoadCustomersAsync();
     
     deleteTargetId = string.Empty;
     deleteTargetName = string.Empty;
     
     StateHasChanged();
     await Task.Delay(2000);
     toastMessage = string.Empty;
     StateHasChanged();
   }
   catch (Exception ex)
   {
     toastMessage = $"❌ Delete error: {ex.Message}";
     System.Diagnostics.Debug.WriteLine($"[Clients] ConfirmDelete error: {ex}");
     StateHasChanged();
     await Task.Delay(3000);
     toastMessage = string.Empty;
     StateHasChanged();
   }
 }

