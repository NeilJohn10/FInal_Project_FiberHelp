@using Microsoft.AspNetCore.Components
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="app-shell">
    <aside class="sidebar">
        <div class="brand">
            <img src="css/bootstrap/Logo.png" alt="FiberHelp" class="brand-logo" />
            <span>FIBERHELP</span>
        </div>

        <div class="sidebar-group">
            <button class="sidebar-btn" @onclick="() => NavigationManager.NavigateTo("")">
                <span class="icon">🏠</span>
                <span>Dashboard</span>
            </button>
            <button class="sidebar-btn" @onclick="() => NavigationManager.NavigateTo("tickets")">
                <span class="icon">🎫</span>
                <span>Tickets</span>
            </button>
            <button class="sidebar-btn" @onclick="() => NavigationManager.NavigateTo("customers")">
                <span class="icon">👥</span>
                <span>Customers</span>
            </button>
            <button class="sidebar-btn" @onclick="() => NavigationManager.NavigateTo("billing")">
                <span class="icon">💳</span>
                <span>Billing</span>
            </button>
            <button class="sidebar-btn" @onclick="() => NavigationManager.NavigateTo("reports")">
                <span class="icon">📊</span>
                <span>Reports</span>
            </button>
        </div>

        <div class="sidebar-group muted">
            <button class="sidebar-btn" @onclick="() => NavigationManager.NavigateTo("settings")">
                <span class="icon">⚙️</span>
                <span>Settings</span>
            </button>
            <button class="sidebar-btn danger" @onclick="() => NavigationManager.NavigateTo("/logout")">
                <span class="icon">↩️</span>
                <span>Logout</span>
            </button>
        </div>
    </aside>

    <main class="main">
        <div class="main-inner">
            @Body
        </div>
    </main>
</div>

<style>
    .app-shell { display:flex; }
    .sidebar { width:250px; background-color:#f8fafc; padding:1rem; display:flex; flex-direction:column; }
    .brand { display:flex; align-items:center; gap:0.5rem; margin-bottom:2rem; }
    .brand-logo { height:40px; width:auto; }
    .sidebar-group { flex-grow:1; }
    .sidebar-btn { 
        display:flex; 
        align-items:center; 
        padding:0.75rem 1rem; 
        border-radius:0.375rem; 
        font-size:0.875rem; 
        color:#334155; 
        gap:0.75rem; 
        width:100%; 
        background:transparent; 
        border:none;
        cursor:pointer;
        transition:background 0.2s;
    }
    .sidebar-btn:hover { background:#e2e8f0; }
    .icon { font-size:1.25rem; }
    .muted { opacity:0.6; }
    .danger { color:#e53e3e; }
    .main { flex-grow:1; padding:1rem; }
</style>