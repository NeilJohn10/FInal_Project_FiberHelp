<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 480" width="400" height="480">
  <defs>
 <style>
      .wifi-stroke { stroke: #001f3f; stroke-width: 6; fill: none; stroke-linecap: round; stroke-linejoin: round; }
    .person-filled { fill: #001f3f; }
      .person-outline { stroke: #001f3f; stroke-width: 4; fill: none; stroke-linecap: round; stroke-linejoin: round; }
      .circle-outline { stroke: #001f3f; stroke-width: 4; fill: none; }
      .text { font-family: 'Arial', 'Helvetica', sans-serif; font-size: 56px; font-weight: 900; text-anchor: middle; fill: #001f3f; letter-spacing: 2px; }
    </style>
</defs>

  <!-- WiFi Arcs - Right Side -->
  <path class="wifi-stroke" d="M 200 80 Q 260 80 300 120"/>
  <path class="wifi-stroke" d="M 200 120 Q 250 120 280 150"/>
  <path class="wifi-stroke" d="M 200 160 Q 240 160 265 185"/>

  <!-- WiFi Arcs - Left Side -->
  <path class="wifi-stroke" d="M 200 80 Q 140 80 100 120"/>
  <path class="wifi-stroke" d="M 200 120 Q 150 120 120 150"/>
  <path class="wifi-stroke" d="M 200 160 Q 160 160 135 185"/>

  <!-- Center WiFi Dot -->
  <circle cx="200" cy="200" r="8" class="person-filled"/>

  <!-- Center Dot (outline) -->
  <circle cx="200" cy="200" r="14" class="circle-outline"/>

  <!-- Left Person (Filled - Support Agent) -->
  <g>
    <!-- Head -->
    <circle cx="140" cy="230" r="18" class="person-filled"/>
    <!-- Body -->
    <path d="M 130 260 L 130 320 Q 130 330 140 330 L 150 330 Q 160 330 160 320 L 160 260 Z" class="person-filled"/>
    <!-- Left Arm -->
    <rect x="100" y="270" width="30" height="14" rx="7" class="person-filled"/>
    <!-- Right Arm -->
    <rect x="160" y="270" width="30" height="14" rx="7" class="person-filled"/>
  </g>

  <!-- Right Person (Outline - Customer) -->
  <g>
    <!-- Head -->
    <circle cx="260" cy="230" r="18" class="person-outline"/>
    <!-- Body -->
    <path d="M 250 260 L 250 320 Q 250 330 260 330 L 270 330 Q 280 330 280 320 L 280 260 Z" class="person-outline"/>
    <!-- Left Arm -->
    <line x1="220" y1="275" x2="250" y2="275" class="person-outline" stroke-width="4"/>
    <!-- Right Arm -->
    <line x1="270" y1="275" x2="300" y2="275" class="person-outline" stroke-width="4"/>
  </g>

  <!-- Smile curve (connecting people) -->
  <path d="M 170 265 Q 200 285 230 265" class="person-outline" stroke-width="4"/>

  <!-- Text: FIBERHELP -->
  <text class="text" x="200" y="420">FIBERHELP</text>
</svg>