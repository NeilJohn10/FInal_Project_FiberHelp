using Microsoft.EntityFrameworkCore;
using FiberHelp.Models;
using System;
using System.Linq;

namespace FiberHelp.Data
{
 public class AppDbContext : DbContext
 {
 public AppDbContext(DbContextOptions<AppDbContext> options) : base(options) { }

 public DbSet<Ticket> Tickets { get; set; }
 public DbSet<Customer> Customers { get; set; }
 public DbSet<User> Users { get; set; }
 public DbSet<Invoice> Invoices { get; set; }
 public DbSet<Agent> Agents { get; set; } // new Agents table mapping
 public DbSet<Account> Accounts { get; set; }

 protected override void OnModelCreating(ModelBuilder modelBuilder)
 {
 base.OnModelCreating(modelBuilder);

 modelBuilder.Entity<Ticket>(entity =>
 {
 entity.HasKey(t => t.Id);
 entity.Property(t => t.Id).HasColumnName("TicketId");
 entity.Property(t => t.Title).HasColumnName("Subject").HasMaxLength(500);
 entity.Property(t => t.Status).HasMaxLength(50);
 entity.Property(t => t.Priority).HasMaxLength(50);
 entity.Property(t => t.Created).HasColumnName("CreatedAt");
 entity.Property(t => t.Customer).HasColumnName("Customer").HasMaxLength(256);
 entity.Property(t => t.CustomerName).HasColumnName("CustomerName").HasMaxLength(256);
 entity.Property(t => t.AccountId).HasColumnName("AccountId");
 });

 modelBuilder.Entity<Customer>(entity =>
 {
 entity.HasKey(c => c.Id);
 entity.Property(c => c.Name).HasMaxLength(200);
 entity.Property(c => c.Email).HasMaxLength(200);
 entity.Property(c => c.Plan).HasMaxLength(100);
 // FK to Account (nullable to allow staged creation but should be set in UI flow)
 entity.Property(c => c.AccountId).HasColumnName("AccountId");
 entity.HasOne(c => c.Account).WithMany(a => a.Customers).HasForeignKey(c => c.AccountId).OnDelete(DeleteBehavior.Restrict);
 });

 modelBuilder.Entity<User>(entity =>
 {
 entity.HasKey(u => u.Id);
 entity.Property(u => u.Email).HasMaxLength(256).IsRequired();
 entity.HasIndex(u => u.Email).IsUnique();
 entity.Property(u => u.Role).HasMaxLength(50);
 entity.Property(u => u.FullName).HasMaxLength(200);
 });

 modelBuilder.Entity<Invoice>(entity =>
 {
 entity.HasKey(i => i.Id);
 entity.Property(i => i.Id).HasColumnName("InvoiceId");
 entity.Property(i => i.AccountId).HasColumnName("AccountId");
 entity.Property(i => i.AmountDue).HasColumnName("AmountDue").HasColumnType("decimal(18,2)");
 entity.Property(i => i.Status).HasColumnName("Status").HasMaxLength(50);
 entity.Property(i => i.IssueDate).HasColumnName("IssueDate");
 });

 modelBuilder.Entity<Agent>(entity =>
 {
 entity.HasKey(a => a.Id);
 entity.Property(a => a.Email).HasMaxLength(256).IsRequired();
 entity.HasIndex(a => a.Email).IsUnique();
 entity.Property(a => a.FullName).HasMaxLength(256);
 entity.Property(a => a.Department).HasMaxLength(100);
 entity.Property(a => a.Phone).HasMaxLength(50);
 entity.Property(a => a.CreatedAt).HasColumnName("CreatedAt");
 });

 modelBuilder.Entity<Account>(entity =>
 {
 entity.HasKey(a => a.Id);
 entity.Property(a => a.Id).HasColumnName("AccountId");
 entity.Property(a => a.Name).HasColumnName("Name").HasMaxLength(256);
 entity.Property(a => a.Type).HasColumnName("Type").HasMaxLength(100);
 entity.Property(a => a.AccountNumber).HasMaxLength(100);
 entity.HasIndex(a => a.AccountNumber).IsUnique().HasFilter("[AccountNumber] IS NOT NULL");
 entity.Property(a => a.ServicePlan).HasMaxLength(100).HasColumnName("ServicePlan");
 entity.Property(a => a.CreatedAt).HasColumnName("CreatedAt");
 entity.Property(a => a.ContactName).HasMaxLength(200).HasColumnName("ContactName");
 entity.Property(a => a.ContactEmail).HasMaxLength(256).HasColumnName("ContactEmail");
 entity.Property(a => a.ContactPhone).HasMaxLength(50).HasColumnName("ContactPhone");
 entity.Property(a => a.BillingAddress).HasMaxLength(400).HasColumnName("BillingAddress");
 entity.Property(a => a.ServiceStatus).HasMaxLength(50).HasColumnName("Status");
 entity.Property(a => a.IsActive).HasColumnName("IsActive"); // corrected mapping
 });
 }

 public override int SaveChanges()
 {
 AutoFillAccountNumbers();
 return base.SaveChanges();
 }
 public override System.Threading.Tasks.Task<int> SaveChangesAsync(System.Threading.CancellationToken cancellationToken = default)
 {
 AutoFillAccountNumbers();
 return base.SaveChangesAsync(cancellationToken);
 }
 private void AutoFillAccountNumbers()
 {
 // For newly added accounts without AccountNumber, generate ACCT-YYYYNNNN style
 var newAccounts = ChangeTracker.Entries<Account>().Where(e => e.State == EntityState.Added && string.IsNullOrWhiteSpace(e.Entity.AccountNumber)).Select(e => e.Entity).ToList();
 if (newAccounts.Count == 0) return;
 // simple sequence based on current max Id; adjust pattern as needed
 var max = Accounts.Any() ? Accounts.Max(a => a.Id) : 0;
 foreach (var acct in newAccounts)
 {
 max++;
 acct.AccountNumber = $"ACCT-{DateTime.UtcNow:yyyy}{max:0000}"; // e.g. ACCT-20250001
 }
 }
 }
}
