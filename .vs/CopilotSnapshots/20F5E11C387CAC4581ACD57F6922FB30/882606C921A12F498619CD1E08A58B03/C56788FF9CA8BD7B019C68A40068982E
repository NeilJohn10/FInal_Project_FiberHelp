@page "/billing"
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.BillingService BillingService
@inject NavigationManager Nav
@inject Microsoft.JSInterop.IJSRuntime JS

@if (!(AuthService.Role ?? "").Equals("Administrator", StringComparison.OrdinalIgnoreCase))
{
    <p>Redirecting...</p>
}
else
{
    <div>
        <header class="topbar agents-header">
            <div>
                <p class="eyebrow">FIBERHELP · ADMINISTRATOR</p>
                <h1 class="page-title">Billing & Accounting</h1>
            </div>
            <div class="agents-controls top-actions">
                <button class="btn-primary" @onclick="() => ShowCreateInvoiceModal()">+ New Invoice</button>
                <button class="btn-secondary" @onclick="() => ShowCreateExpenseModal()">+ Add Expense</button>
                <select class="filter-select" @onchange="OnPeriodChanged">
                    <option value="1">Last Month</option>
                    <option value="3">Last 3 Months</option>
                    <option value="6" selected>Last 6 Months</option>
                    <option value="12">Last 12 Months</option>
                    <option value="0">All Time</option>
                </select>
                <button class="btn subtle" @onclick="ExportAccountingData">Export Report</button>
            </div>
        </header>

        <style>
            .billing-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:18px; margin-bottom:28px }
            .kpi-card { background:#fff; padding:18px 20px; border-radius:16px; box-shadow:0 12px 28px rgba(2,6,23,0.08); position:relative; overflow:hidden; }
            .kpi-card:before { content:""; position:absolute; inset:0; background:linear-gradient(135deg,rgba(37,99,235,0.08),rgba(99,102,241,0.08)); opacity:0.6; pointer-events:none }
            .kpi-value { font-size:34px; font-weight:700; line-height:1; margin-bottom:6px; position:relative; z-index:1 }
            .kpi-label { font-size:13px; text-transform:uppercase; letter-spacing:.08em; font-weight:600; color:#64748b; position:relative; z-index:1 }
            .kpi-sub { font-size:11px; color:#64748b; margin-top:4px; position:relative; z-index:1 }
            .section-card { background:#fff; padding:24px; border-radius:16px; box-shadow:0 12px 28px rgba(2,6,23,0.08); margin-bottom:24px }
            .section-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; border-bottom:2px solid #e5e7eb; padding-bottom:12px }
            .section-title { font-size:20px; font-weight:700; margin:0; color:#1e293b }
            .filter-select { padding:8px 12px; border-radius:10px; border:1px solid #e2e8f0; background:#fff; font-size:14px }
            .data-table { width:100%; border-collapse:separate; border-spacing:0 8px }
            .data-table thead th { text-align:left; font-size:13px; font-weight:700; padding:12px; color:#475569; background:#f8fafc; border-bottom:2px solid #e2e8f0 }
            .data-table tbody td { background:#f9fafb; padding:14px 12px; font-size:14px; border-top:1px solid #edf2f7; border-bottom:1px solid #edf2f7 }
            .data-table tbody tr td:first-child { border-left:1px solid #edf2f7; border-top-left-radius:10px; border-bottom-left-radius:10px }
            .data-table tbody tr td:last-child { border-right:1px solid #edf2f7; border-top-right-radius:10px; border-bottom-right-radius:10px }
            .data-table tbody tr:hover td { background:#f1f5f9 }
            .status-badge { padding:6px 12px; border-radius:999px; font-size:12px; font-weight:700; display:inline-block }
            .status-paid { background:#dcfce7; color:#065f46; border:1px solid #bbf7d0 }
            .status-pending { background:#fef9c3; color:#92400e; border:1px solid #fde68a }
            .status-overdue { background:#fee2e2; color:#991b1b; border:1px solid #fecaca }
            .aging-list { list-style:none; padding:0; margin:0 }
            .aging-list li { padding:12px 16px; background:#f9fafb; border-radius:10px; margin-bottom:8px; display:flex; justify-content:space-between; align-items:center; border:1px solid #e5e7eb }
            .aging-label { font-weight:600; color:#475569 }
            .aging-value { font-weight:700; color:#1e293b; font-size:16px }
            .shimmer-row { animation: shimmer 1.2s linear infinite; background:linear-gradient(90deg,#f1f5f9 0%,#e2e8f0 50%,#f1f5f9 100%); background-size:400% 100%; height:54px; border-radius:12px }
            @@keyframes shimmer { 0%{background-position:0% 0}100%{background-position:100% 0} }
            .empty-state { text-align:center; padding:40px 20px; color:#64748b; font-size:14px }
            .grid-2 { display:grid; grid-template-columns:repeat(2,1fr); gap:24px; margin-bottom:24px }
            .amount-positive { color:#16a34a; font-weight:700 }
            .amount-negative { color:#dc2626; font-weight:700 }
            
            /* Action buttons */
            .btn-action { padding:6px 10px; border:none; border-radius:6px; cursor:pointer; margin-right:4px; font-size:14px; transition:all 0.2s }
            .btn-action:hover { transform:scale(1.1) }
            .btn-success { background:#dcfce7; color:#16a34a }
            .btn-success:hover { background:#bbf7d0 }
            .btn-warning { background:#fef3c7; color:#d97706 }
            .btn-warning:hover { background:#fde68a }
            .btn-info { background:#e0f2fe; color:#0284c7 }
            .btn-info:hover { background:#bae6fd }
            .btn-danger { background:#fee2e2; color:#dc2626 }
            .btn-danger:hover { background:#fecaca }
            .btn-primary { background:#2563eb; color:white; padding:10px 20px; border:none; border-radius:8px; cursor:pointer; font-weight:600 }
            .btn-primary:hover { background:#1d4ed8 }
            .btn-secondary { background:#e2e8f0; color:#475569; padding:10px 20px; border:none; border-radius:8px; cursor:pointer; font-weight:600 }
            .btn-secondary:hover { background:#cbd5e1 }
            
            /* Modal styles */
            .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000 }
            .modal-content { background:white; padding:28px; border-radius:16px; width:100%; max-width:500px; max-height:90vh; overflow-y:auto }
            .modal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding-bottom:12px; border-bottom:2px solid #e5e7eb }
            .modal-title { font-size:20px; font-weight:700; color:#1e293b; margin:0 }
            .modal-close { background:none; border:none; font-size:24px; cursor:pointer; color:#64748b }
            .form-group { margin-bottom:16px }
            .form-label { display:block; font-weight:600; margin-bottom:6px; color:#475569; font-size:14px }
            .form-input { width:100%; padding:10px 14px; border:1px solid #e2e8f0; border-radius:8px; font-size:14px }
            .form-input:focus { outline:none; border-color:#2563eb; box-shadow:0 0 0 3px rgba(37,99,235,0.1) }
            .form-actions { display:flex; gap:12px; justify-content:flex-end; margin-top:24px }
        </style>

        <section class="panel">
            @if (_error != null)
            {
                <div style="padding:20px;background:#fee2e2;border:1px solid #fecaca;border-radius:12px;color:#991b1b;margin-bottom:24px">
                    <strong>Error:</strong> @_error
                    <button @onclick="async () => await LoadDataAsync()" style="margin-left:16px;padding:8px 16px;background:#dc2626;color:white;border:none;border-radius:6px;cursor:pointer">Retry</button>
                </div>
            }

            @if (_loading && _summary == null)
            {
                <div class="shimmer-row" style="margin-bottom:24px"></div>
            }
            else if (_summary != null)
            {
                <div class="billing-grid">
                    <div class="kpi-card">
                        <div class="kpi-value">@_summary.TotalInvoices</div>
                        <div class="kpi-label">Total Invoices</div>
                        <div class="kpi-sub">@_summary.TotalAmount.ToString("C")</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-value">@_summary.PaidCount</div>
                        <div class="kpi-label">Paid</div>
                        <div class="kpi-sub">@_summary.PaidAmount.ToString("C")</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-value">@_summary.PendingCount</div>
                        <div class="kpi-label">Pending</div>
                        <div class="kpi-sub">@_summary.PendingAmount.ToString("C")</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-value">@_summary.OverdueCount</div>
                        <div class="kpi-label">Overdue</div>
                        <div class="kpi-sub">@_summary.OverdueAmount.ToString("C")</div>
                    </div>
                    <div class="kpi-card">
                        <div class="kpi-value" style="color:#16a34a">@((_summary.TotalAmount - _summary.PendingAmount).ToString("C"))</div>
                        <div class="kpi-label">Revenue Collected</div>
                        <div class="kpi-sub">Lifetime</div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Accounts Receivable Aging</h3>
                    </div>
                    <ul class="aging-list">
                        @foreach (var kv in _summary.AgingBuckets)
                        {
                            <li>
                                <span class="aging-label">@GetAgingLabel(kv.Key)</span>
                                <span class="aging-value">@kv.Value invoices</span>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="grid-2">
                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Recent Invoices</h3>
                    </div>
                    @if (_invoices == null)
                    {
                        <div class="shimmer-row"></div>
                    }
                    else if (_invoices.Count == 0)
                    {
                        <div class="empty-state">No invoices found</div>
                    }
                    else
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Account</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Due Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inv in _invoices.Take(10))
                                {
                                    <tr>
                                        <td style="font-weight:600">#@inv.Id</td>
                                        <td>@(inv.AccountName ?? inv.AccountId?.ToString() ?? "N/A")</td>
                                        <td style="font-weight:600">@inv.AmountDue.ToString("C")</td>
                                        <td><span class="status-badge @GetStatusClass(inv.Status)">@inv.Status</span></td>
                                        <td>@((inv.DueDate ?? inv.IssueDate.AddDays(30)).ToString("yyyy-MM-dd"))</td>
                                        <td>
                                            @if (!string.Equals(inv.Status, "Paid", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button class="btn-action btn-success" @onclick="() => MarkInvoicePaid(inv.Id)" title="Mark as Paid">
                                                    <span>💰</span>
                                                </button>
                                                <button class="btn-action btn-warning" @onclick="() => SendReminder(inv.Id)" title="Send Reminder">
                                                    <span>📧</span>
                                                </button>
                                            }
                                            <button class="btn-action btn-info" @onclick="() => ViewInvoiceDetails(inv)" title="View Details">
                                                <span>👁️</span>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="section-card">
                    <div class="section-header">
                        <h3 class="section-title">Recent Expenses</h3>
                    </div>
                    @if (_expenses == null)
                    {
                        <div class="shimmer-row"></div>
                    }
                    else if (_expenses.Count == 0)
                    {
                        <div class="empty-state">No expenses recorded</div>
                    }
                    else
                    {
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Category</th>
                                    <th>Description</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var exp in _expenses.Take(10))
                                {
                                    <tr>
                                        <td>@exp.Date.ToString("yyyy-MM-dd")</td>
                                        <td style="font-weight:600">@exp.Category</td>
                                        <td>@exp.Description</td>
                                        <td class="amount-negative">-@exp.Amount.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <div class="section-card">
                <div class="section-header">
                    <h3 class="section-title">Cash Flow Summary (Last @_monthsFilter Month@(_monthsFilter != 1 ? "s" : ""))</h3>
                </div>
                @if (_cashFlow == null)
                {
                    <div class="shimmer-row"></div>
                }
                else
                {
                    <div class="billing-grid" style="margin-bottom:20px">
                        <div class="kpi-card">
                            <div class="kpi-value" style="color:#16a34a">@_cashFlow.Inflows.ToString("C")</div>
                            <div class="kpi-label">Total Inflows</div>
                            <div class="kpi-sub">Paid invoices</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value" style="color:#dc2626">@_cashFlow.Outflows.ToString("C")</div>
                            <div class="kpi-label">Total Outflows</div>
                            <div class="kpi-sub">Expenses</div>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-value" style="color:@(_cashFlow.Net >= 0 ? "#16a34a" : "#dc2626")">@_cashFlow.Net.ToString("C")</div>
                            <div class="kpi-label">Net Cash Flow</div>
                            <div class="kpi-sub">@(_cashFlow.Net >= 0 ? "Positive" : "Negative")</div>
                        </div>
                    </div>

                    <div class="grid-2">
                        <div>
                            <h4 style="font-size:16px;font-weight:700;margin-bottom:12px;color:#1e293b">Monthly Inflows</h4>
                            <ul class="aging-list">
                                @foreach (var kv in _cashFlow.InflowsByMonth)
                                {
                                    <li>
                                        <span class="aging-label">@kv.Key</span>
                                        <span class="aging-value amount-positive">@kv.Value.ToString("C")</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div>
                            <h4 style="font-size:16px;font-weight:700;margin-bottom:12px;color:#1e293b">Monthly Outflows</h4>
                            <ul class="aging-list">
                                @foreach (var kv in _cashFlow.OutflowsByMonth)
                                {
                                    <li>
                                        <span class="aging-label">@kv.Key</span>
                                        <span class="aging-value amount-negative">-@kv.Value.ToString("C")</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>

            <div class="section-card">
                <div class="section-header">
                    <h3 class="section-title">Complete Ledger</h3>
                </div>
                @if (_invoices == null || _expenses == null)
                {
                    <div class="shimmer-row"></div>
                }
                else
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Type</th>
                                <th>Reference</th>
                                <th>Description</th>
                                <th>Debit</th>
                                <th>Credit</th>
                                <th>Balance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var balance = 0m;
                                var ledgerEntries = GetLedgerEntries();
                                @foreach (var entry in ledgerEntries)
                                {
                                    balance += entry.Amount;
                                    <tr>
                                        <td>@entry.Date.ToString("yyyy-MM-dd")</td>
                                        <td style="font-weight:600">@entry.Type</td>
                                        <td>@entry.Reference</td>
                                        <td>@entry.Description</td>
                                        <td>@(entry.Amount > 0 ? entry.Amount.ToString("C") : "")</td>
                                        <td>@(entry.Amount < 0 ? Math.Abs(entry.Amount).ToString("C") : "")</td>
                                        <td style="font-weight:700;color:@(balance >= 0 ? "#16a34a" : "#dc2626")">@balance.ToString("C")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                }
            </div>
        </section>

        <Toast Message="@_toast" />
    </div>
}

@code {
    private FiberHelp.Services.BillingService.AccountingSummary? _summary;
    private FiberHelp.Services.BillingService.CashFlowSummary? _cashFlow;
    private List<FiberHelp.Models.Invoice>? _invoices;
    private List<FiberHelp.Models.Expense>? _expenses;
    private string _toast = string.Empty;
    private int _monthsFilter = 6;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (!(AuthService.Role ?? "").Equals("Administrator", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/tickets", true);
            return;
        }
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _loading = true;
            _error = null;
            StateHasChanged();

            _summary = await BillingService.GetSummaryAsync();
            _cashFlow = await BillingService.GetCashFlowAsync(_monthsFilter);
            _invoices = await BillingService.GetInvoicesAsync();
            _expenses = await BillingService.GetExpensesAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading billing data: {ex.Message}");
            _error = $"Failed to load billing data: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task OnPeriodChanged(ChangeEventArgs e)
    {
        try
        {
            if (int.TryParse(e.Value?.ToString(), out var months))
            {
                _monthsFilter = months == 0 ? 12 : months;
            }
            else
            {
                _monthsFilter = 6;
            }
            _cashFlow = await BillingService.GetCashFlowAsync(_monthsFilter);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error updating cash flow: {ex.Message}");
            _error = $"Failed to update cash flow: {ex.Message}";
            StateHasChanged();
        }
    }

    private string GetStatusClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return "status-pending";
        return status.ToLowerInvariant() switch
        {
            "paid" => "status-paid",
            "pending" => "status-pending",
            "overdue" => "status-overdue",
            _ => "status-pending"
        };
    }

    private string GetAgingLabel(string key)
    {
        return key switch
        {
            "Current" => "Current (Not Due)",
            "1-30" => "1-30 Days Past Due",
            "31-60" => "31-60 Days Past Due",
            "61-90" => "61-90 Days Past Due",
            ">90" => "Over 90 Days Past Due",
            _ => key
        };
    }

    private record LedgerEntry(DateTime Date, string Type, string Reference, string Description, decimal Amount);

    private List<LedgerEntry> GetLedgerEntries()
    {
        var entries = new List<LedgerEntry>();

        if (_invoices != null)
        {
            foreach (var inv in _invoices.Where(i => i.Status == "Paid"))
            {
                entries.Add(new LedgerEntry(
                    inv.PaidDate ?? inv.IssueDate,
                    "Invoice",
                    $"INV-{inv.Id}",
                    $"{inv.AccountName ?? inv.AccountId?.ToString() ?? "N/A"} - {inv.PaymentRef ?? "N/A"}",
                    inv.AmountDue
                ));
            }
        }

        if (_expenses != null)
        {
            foreach (var exp in _expenses)
            {
                entries.Add(new LedgerEntry(
                    exp.Date,
                    "Expense",
                    exp.Reference ?? $"EXP-{exp.Id}",
                    $"{exp.Category} - {exp.Description}",
                    -exp.Amount
                ));
            }
        }

        return entries.OrderBy(e => e.Date).ToList();
    }

    private async Task ExportAccountingData()
    {
        try
        {
            var csv = new System.Text.StringBuilder();
            csv.AppendLine("=== ACCOUNTING SUMMARY ===");
            csv.AppendLine($"Generated: {DateTime.Now:yyyy-MM-dd HH:mm}");
            csv.AppendLine();
            
            csv.AppendLine("=== INVOICE SUMMARY ===");
            csv.AppendLine($"Total Invoices,{_summary?.TotalInvoices}");
            csv.AppendLine($"Total Amount,{_summary?.TotalAmount:C}");
            csv.AppendLine($"Paid Count,{_summary?.PaidCount}");
            csv.AppendLine($"Paid Amount,{_summary?.PaidAmount:C}");
            csv.AppendLine($"Pending Count,{_summary?.PendingCount}");
            csv.AppendLine($"Pending Amount,{_summary?.PendingAmount:C}");
            csv.AppendLine($"Overdue Count,{_summary?.OverdueCount}");
            csv.AppendLine($"Overdue Amount,{_summary?.OverdueAmount:C}");
            csv.AppendLine();

            csv.AppendLine("=== CASH FLOW ===");
            csv.AppendLine($"Inflows,{_cashFlow?.Inflows:C}");
            csv.AppendLine($"Outflows,{_cashFlow?.Outflows:C}");
            csv.AppendLine($"Net,{_cashFlow?.Net:C}");
            csv.AppendLine();

            csv.AppendLine("=== COMPLETE LEDGER ===");
            csv.AppendLine("Date,Type,Reference,Description,Debit,Credit,Balance");
            var balance = 0m;
            foreach (var entry in GetLedgerEntries())
            {
                balance += entry.Amount;
                csv.AppendLine($"{entry.Date:yyyy-MM-dd},{entry.Type},{Escape(entry.Reference)},{Escape(entry.Description)},{(entry.Amount > 0 ? entry.Amount.ToString("F2") : "")},{(entry.Amount < 0 ? Math.Abs(entry.Amount).ToString("F2") : "")},{balance:F2}");
            }

            await JS.InvokeAsync<bool>("FiberExport.saveFile", $"accounting_report_{DateTime.Now:yyyyMMdd}.csv", csv.ToString());
            _toast = "Accounting report exported successfully";
            StateHasChanged();
            await Task.Delay(2000);
            _toast = string.Empty;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error exporting data: {ex.Message}");
            _toast = $"Export failed: {ex.Message}";
            StateHasChanged();
            await Task.Delay(3000);
            _toast = string.Empty;
            StateHasChanged();
        }
    }

    private string Escape(string? s)
    {
        if (string.IsNullOrEmpty(s)) return string.Empty;
        return "\"" + s.Replace("\"", "\"\"") + "\"";
    }

    private async Task MarkInvoicePaid(int invoiceId)
    {
        try
        {
            // Call the service to mark the invoice as paid
            await BillingService.MarkInvoiceAsPaidAsync(invoiceId);

            // Optionally, reload the data to refresh the view
            await LoadDataAsync();

            _toast = "Invoice marked as paid";
        }
        catch (Exception ex)
        {
            _toast = $"Error marking invoice as paid: {ex.Message}";
        }
    }

    private async Task SendReminder(int invoiceId)
    {
        try
        {
            // Call the service to send a reminder for the invoice
            await BillingService.SendInvoiceReminderAsync(invoiceId);

            _toast = "Reminder sent";
        }
        catch (Exception ex)
        {
            _toast = $"Error sending reminder: {ex.Message}";
        }
    }

    private void ViewInvoiceDetails(FiberHelp.Models.Invoice invoice)
    {
        // Navigate to the invoice details page
        Nav.NavigateTo($"/invoices/{invoice.Id}");
    }

    private async Task ShowCreateInvoiceModal()
    {
        // Logic to show the create invoice modal
        _ = JS.InvokeVoidAsync("alert", "Show create invoice modal (not implemented)");
    }

    private async Task ShowCreateExpenseModal()
    {
        // Logic to show the create expense modal
        _ = JS.InvokeVoidAsync("alert", "Show create expense modal (not implemented)");
    }
}