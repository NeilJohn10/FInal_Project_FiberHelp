public async Task<bool> UpdateAgentRecordAsync(Agent agent, string? plainPassword)
{
 try
 {
 LastError = null;
 if (agent == null || string.IsNullOrWhiteSpace(agent.Id)) { LastError = "Invalid agent"; return false; }
 var existing = await _db.Agents.FindAsync(agent.Id);
 if (existing == null) { LastError = "Agent not found"; return false; }
 if (!string.Equals(existing.Email, agent.Email, StringComparison.OrdinalIgnoreCase))
 {
 var lower = agent.Email?.Trim().ToLowerInvariant() ?? string.Empty;
 if (await _db.Agents.AnyAsync(a => a.Email.ToLower() == lower && a.Id != agent.Id))
 {
 LastError = "Email already exists";
 return false;
 }
 existing.Email = agent.Email;
 }
 existing.FullName = agent.FullName;
 existing.Department = agent.Department;
 existing.Phone = agent.Phone;
 existing.IsActive = agent.IsActive;
 existing.UpdatedAt = DateTime.UtcNow;
 if (!string.IsNullOrWhiteSpace(plainPassword))
 {
 existing.PasswordHash = HashPassword(plainPassword);
 existing.PasswordChangedAt = DateTime.UtcNow;
 }
 _db.Agents.Update(existing);
 var rows = await _db.SaveChangesAsync();
 return rows > 0;
 }
 catch (Exception ex)
 {
 LastError = ex.Message;
 System.Diagnostics.Debug.WriteLine($"AdminService.UpdateAgentRecordAsync error: {ex}");
 return false;
 }
}

