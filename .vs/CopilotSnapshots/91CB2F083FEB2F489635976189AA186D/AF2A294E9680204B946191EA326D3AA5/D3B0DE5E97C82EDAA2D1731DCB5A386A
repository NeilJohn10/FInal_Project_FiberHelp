private string GenerateAccountNumber()
{
  // Find current max Id to produce sequential piece
  var maxId = _db.Accounts.Any() ? _db.Accounts.Max(a => a.Id) : 0;
  var next = maxId + 1;
  return $"ACCT-{DateTime.UtcNow:yyyy}{next:0000}"; // ACCT-YYYYNNNN
}

public async Task<bool> CreateAccountAsync(Account a)
{
  try
  {
    LastError = null;
    if (a == null) { LastError = "Account is null"; return false; }
    if (string.IsNullOrWhiteSpace(a.AccountNumber)) a.AccountNumber = GenerateAccountNumber();
    if (a.CreatedAt == default) a.CreatedAt = DateTime.UtcNow;
    // ensure unique AccountNumber
    var lower = a.AccountNumber.Trim().ToLowerInvariant();
    if (await _db.Accounts.AnyAsync(x => x.AccountNumber.ToLower() == lower)) { LastError = "Account number already exists"; return false; }
    _db.Accounts.Add(a);
    var rows = await _db.SaveChangesAsync();
    return rows > 0;
  }
  catch (Exception ex) { LastError = ex.Message; System.Diagnostics.Debug.WriteLine($"AdminService.CreateAccountAsync error: {ex}"); return false; }
}

public async Task<bool> UpdateAccountAsync(Account a)
{
  try
  {
    LastError = null;
    if (a == null || a.Id <= 0) { LastError = "Invalid account"; return false; }
    var existing = await _db.Accounts.FindAsync(a.Id);
    if (existing == null) { LastError = "Account not found"; return false; }
    // if number changed validate uniqueness
    if (!string.Equals(existing.AccountNumber, a.AccountNumber, StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(a.AccountNumber))
    {
      var lower = a.AccountNumber.Trim().ToLowerInvariant();
      if (await _db.Accounts.AnyAsync(x => x.AccountNumber.ToLower() == lower && x.Id != a.Id)) { LastError = "Account number already exists"; return false; }
      existing.AccountNumber = a.AccountNumber;
    }
    existing.ServicePlan = a.ServicePlan;
    existing.IsActive = a.IsActive;
    existing.ContactName = a.ContactName;
    existing.ContactEmail = a.ContactEmail;
    existing.ContactPhone = a.ContactPhone;
    existing.BillingAddress = a.BillingAddress;
    existing.ServiceStatus = a.ServiceStatus;
    _db.Accounts.Update(existing);
    var rows = await _db.SaveChangesAsync();
    return rows > 0;
  }
  catch (Exception ex) { LastError = ex.Message; System.Diagnostics.Debug.WriteLine($"AdminService.UpdateAccountAsync error: {ex}"); return false; }
}

public async Task<bool> DeleteAccountAsync(int id)
{
  try
  {
    LastError = null;
    var a = await _db.Accounts.Include(x => x.Customers).FirstOrDefaultAsync(x => x.Id == id);
    if (a == null) { LastError = "Account not found"; return false; }
    if (a.Customers != null && a.Customers.Any()) { LastError = "Cannot delete account with customers."; return false; }
    _db.Accounts.Remove(a);
    var rows = await _db.SaveChangesAsync();
    return rows > 0;
  }
  catch (Exception ex) { LastError = ex.Message; System.Diagnostics.Debug.WriteLine($"AdminService.DeleteAccountAsync error: {ex}"); return false; }
}

