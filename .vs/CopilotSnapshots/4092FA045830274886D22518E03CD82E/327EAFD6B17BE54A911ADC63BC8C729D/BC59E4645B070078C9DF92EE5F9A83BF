@page "/tickets"
@using FiberHelp.Models
@using Microsoft.AspNetCore.Components.Web
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.AdminService AdminService
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JS

<style>
  .tickets-header{display:flex;align-items:center;justify-content:space-between;padding-bottom:20px;margin-bottom:22px;border-bottom:1px solid #e5e7eb}
  .tickets-header .page-title{font-size:42px;line-height:1.1;margin:0 0 4px}
  .tickets-controls{display:flex;gap:14px;align-items:center}
  .tickets-search{width:360px;padding:12px 18px;border-radius:14px;border:1px solid #e5e7eb;background:#fff;box-shadow:0 8px 22px rgba(2,6,23,0.08);font-size:15px}
  .tickets-controls .btn.subtle{background:#fff;color:#0f172a;border:1px solid #e5e7eb;border-radius:14px;padding:10px 22px;box-shadow:0 4px 10px rgba(2,6,23,0.04)}
  .tickets-controls .btn.primary{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;border:none;border-radius:14px;padding:10px 26px;box-shadow:0 14px 32px rgba(29,78,216,0.30);font-weight:600}
  .tickets-table{width:100%;border-collapse:separate;border-spacing:0 10px}
  .tickets-table thead th{font-size:13px;font-weight:700;padding:10px 12px;color:#475569;text-align:left;border-bottom:1px solid #e5e7eb}
  .tickets-table tbody td{background:#f9fafb;padding:14px 12px;font-size:14px;border-top:1px solid #edf2f7;border-bottom:1px solid #edf2f7}
  .tickets-table tbody tr td:first-child{border-left:1px solid #edf2f7;border-top-left-radius:12px;border-bottom-left-radius:12px}
  .tickets-table tbody tr td:last-child{border-right:1px solid #edf2f7;border-top-right-radius:12px;border-bottom-right-radius:12px}
  .cust-cell{display:flex;align-items:center;gap:12px}
  .cust-avatar{width:40px;height:40px;border-radius:999px;background:linear-gradient(135deg,#6366f1,#0ea5e9);display:grid;place-items:center;font-weight:800;color:#fff;font-size:14px;box-shadow:0 8px 18px rgba(99,102,241,0.25)}
  .cust-name{font-weight:600}
  .cust-email{font-size:11px;color:#64748b}
  .badge{display:inline-block;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:700}
  .badge-prio-low{background:#e0f2fe;color:#075985;border:1px solid #bae6fd}
  .badge-prio-medium{background:#fef9c3;color:#92400e;border:1px solid #fde68a}
  .badge-prio-high{background:#fee2e2;color:#7f1d1d;border:1px solid #fecaca}
  .badge-prio-critical{background:#ffe4e6;color:#881337;border:1px solid #fecdd3}
  .badge-status-open{background:#e0f2fe;color:#075985;border:1px solid #bae6fd}
  .badge-status-inprogress{background:#dbeafe;color:#1e3a8a;border:1px solid #bfdbfe}
  .badge-status-resolved{background:#dcfce7;color:#065f46;border:1px solid #bbf7d0}
  .badge-status-closed{background:#e2e8f0;color:#475569;border:1px solid #cbd5e1}
  .action-btn{border:none;background:transparent;padding:6px 8px;border-radius:10px;cursor:pointer}
  .action-btn:hover{background:#eef2ff}
  .modal-bg { position:fixed; inset:0; background:rgba(2,6,23,0.28); display:grid; place-items:center; z-index:60000; }
  .modal-card { width:calc(100% - 160px); max-width:960px; background:#ffffff; border-radius:14px; padding:28px; box-shadow:0 40px 80px rgba(2,6,23,0.25); position:relative; }
  .modal-header { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:8px }
  .modal-header h3 { margin:0; font-size:22px }
  .modal-desc { margin:6px 0 0; color:#64748b; font-size:0.95rem }
  .modal-close { position:absolute; right:14px; top:12px; border:none; background:transparent; cursor:pointer; font-size:18px; color:#64748b; padding:6px; border-radius:8px }
  .modal-close:hover { background:rgba(2,6,23,0.06); color:#111827 }
  .form-group { display:flex; flex-direction:column; gap:6px; margin-top:10px }
  .form-input { padding:10px 12px; border:1px solid #e6edf3; border-radius:8px; font-size:14px; background:#fff }
  .form-input:focus { outline:3px solid rgba(37,99,235,0.12); box-shadow:0 6px 18px rgba(37,99,235,0.06) }
  .client-panel { border:1px solid #eef2f7; border-radius:8px; padding:8px; background:#fff; max-height:340px; overflow:auto; margin-top:10px }
  .dropdown-item { display:flex; justify-content:space-between; align-items:center; padding:12px; cursor:pointer; border-radius:6px }
  .dropdown-item:hover { background:#f8fafc }
  .dropdown-item.selected { background:linear-gradient(90deg, rgba(37,99,235,0.06), rgba(37,99,235,0.02)); border-left:3px solid #2563eb }
  .two-col { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
  .modal-actions { display:flex; justify-content:flex-end; gap:10px; margin-top:16px }
  @@media (max-width:900px){ .modal-card{width:92vw;padding:20px} .two-col{grid-template-columns:1fr} }
</style>

<div>
 <header class="tickets-header">
   <div>
     <p class="eyebrow">FIBERHELP · @GetRoleLabel()</p>
     <h1 class="page-title">Tickets</h1>
   </div>
   <div class="tickets-controls">
     <input class="tickets-search" placeholder="Search tickets by id, title or client" @bind="ticketSearch" @oninput="_ => StateHasChanged()" />
     <button class="btn subtle" @onclick="ExportTickets">Export</button>
     <button class="btn primary" @onclick="ShowNewTicketModal">+ New Ticket</button>
   </div>
 </header>

 <section class="panel">
 <table class="tickets-table">
 <thead>
 <tr>
 <th>Ticket ID</th>
 <th>Title</th>
 <th>Client</th>
 <th>Priority</th>
 <th>Status</th>
 <th>Created</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @if (FilteredTickets != null)
 {
 @foreach (var ticket in FilteredTickets)
 {
 <tr>
   <td>@ticket.Id</td>
   <td style="font-weight:600">@ticket.Title</td>
   <td>
     <div class="cust-cell">
       <div class="cust-avatar">@GetInitial(ticket)</div>
       <div>
         <div class="cust-name">@GetClientLabel(ticket)</div>
         <div class="cust-email">@FormatLocal(ticket.Created)</div>
       </div>
     </div>
   </td>
   <td><span class="badge @(GetPriorityBadge(ticket.Priority))">@ticket.Priority</span></td>
   <td><span class="badge @(GetStatusBadge(ticket.Status))">@ticket.Status</span></td>
   <td>@GetTimeAgo(ticket.Created)</td>
   <td>
     <button class="action-btn edit" title="Edit" @onclick="() => ShowEditTicketModal(ticket)">
       <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
         <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" fill="#2563eb" />
         <path d="M20.71 7.04a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" fill="#2563eb" />
       </svg>
     </button>
     <button class="action-btn delete" title="Delete" @onclick="() => DeleteTicketAsync(ticket.Id)">
       <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
         <path d="M3 6h18" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
         <path d="M8 6v12a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
         <path d="M10 11v6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
         <path d="M14 11v6" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" />
         <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
       </svg>
     </button>
   </td>
 </tr>
 }
 }
 </tbody>
 </table>
 </section>

 @* New Ticket modal with dim backdrop *@
 @if (showNewTicketModal)
 {
 <div class="modal-bg" @onclick="CloseNewTicketModal">
 <div @onclick:stopPropagation class="modal-card" role="dialog" aria-modal="true" aria-labelledby="newTicketTitle">
   <button class="modal-close" @onclick="CloseNewTicketModal" aria-label="Close">
     <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M18.3 5.7a1 1 0 0 0-1.4 0L12 10.6 7.1 5.7a1 1 0 1 0-1.4 1.4L10.6 12l-4.9 4.9a1 1 0 1 0 1.4 1.4L12 13.4l4.9 4.9a1 1 0 0 0 1.4-1.4L13.4 12l4.9-4.9a1 1 0 0 0 0-1.4z" fill="#64748b"/></svg>
   </button>
   <div class="modal-header">
     <div>
       <h3 id="newTicketTitle">New Ticket</h3>
       <div class="modal-desc">Select an account (type to search) then enter ticket details. Client auto-links from account.</div>
     </div>
   </div>
   <div class="form-group">
     <label>Account</label>
     <input class="form-input" placeholder="Type to search account (id, name, or email)" list="accountList" @bind="accountText" @bind:event="oninput" @bind:after="OnAccountTextChanged" />
     <datalist id="accountList">
       @if(accounts != null)
       {
         foreach(var a in accounts)
         {
           <option value="@a.Id">@a.Id - @(string.IsNullOrWhiteSpace(a.Name)?"(no name)":a.Name) (@(a.ContactEmail ?? "no email"))</option>
         }
       }
     </datalist>
     @if(selectedAccount != null)
     {
       <div class="selected-customer" style="margin-top:6px">Plan: @selectedAccount.ServicePlan · Status: @(selectedAccount.ServiceStatus ?? "Active")</div>
     }
     @if(!string.IsNullOrEmpty(newTicketClientName))
     {
       <div class="selected-customer" style="margin-top:4px">Client: @newTicketClientName (@newTicketClientId)</div>
     }
   </div>
   <div class="two-col">
     <div class="form-group">
       <label for="ticketTitle">Title</label>
       <input id="ticketTitle" class="form-input" @bind="newTicketTitle" placeholder="Enter ticket title" list="complaintList" />
       <datalist id="complaintList">
         <option value="No internet" />
         <option value="Slow internet" />
         <option value="Intermittent connection" />
         <option value="High latency" />
         <option value="Frequent disconnections" />
         <option value="Router not working" />
         <option value="Cable cut" />
         <option value="Billing issue" />
         <option value="Account suspended" />
         <option value="Wrong credentials" />
         <option value="Cannot access website/app" />
         <option value="Service outage in area" />
       </datalist>
     </div>
     <div class="form-group">
       <label>Priority</label>
       <select class="form-input" @bind="newTicketPriority">
         <option value="Low">Low</option>
         <option value="Medium">Medium</option>
         <option value="High">High</option>
         <option value="Critical">Critical</option>
       </select>
     </div>
   </div>
   <div class="two-col">
     <div class="form-group">
       <label>Status</label>
       <select class="form-input" @bind="newTicketStatus">
         <option value="Open">Open</option>
         <option value="In Progress">In Progress</option>
         <option value="Resolved">Resolved</option>
         <option value="Closed">Closed</option>
       </select>
     </div>
     <div class="form-group">
       <label>Account Id (auto)</label>
       <input class="form-input" value="@(newTicketAccountId?.ToString() ?? "(none)")" disabled />
     </div>
   </div>
   <div class="modal-actions">
     <button class="btn subtle" @onclick="CloseNewTicketModal">Cancel</button>
     <button class="btn primary" @onclick="OnCreateNewTicketClicked">Create</button>
   </div>
   @if (!string.IsNullOrEmpty(serviceError)) { <p style="color:#dc2626;font-size:0.85rem;margin-top:8px">@serviceError</p> }
 </div>
 </div>
 }

 @* Edit Ticket modal with dim backdrop *@
 @if (showEditTicketModal && editingTicket != null)
 {
 <div class="modal-bg" @onclick="CloseEditTicketModal">
 <div @onclick:stopPropagation class="modal-card">
   <button class="modal-close" @onclick="CloseEditTicketModal" aria-label="Close">
     <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M18.3 5.7a1 1 0 0 0-1.4 0L12 10.6 7.1 5.7a1 1 0 1 0-1.4 1.4L10.6 12l-4.9 4.9a1 1 0 1 0 1.4 1.4L12 13.4l4.9 4.9a1 1 0 0 0 1.4-1.4L13.4 12l4.9-4.9a1 1 0 0 0 0-1.4z" fill="#64748b"/></svg>
   </button>
   <div class="modal-header">
     <div>
       <h3>Edit Ticket</h3>
       <div class="modal-desc">Change ticket details and save updates.</div>
     </div>
   </div>
   <div class="form-group">
   <label>Ticket ID</label>
   <input class="form-input" value="@editingTicket.Id" disabled />
   </div>
   <div class="form-group">
   <label>Title</label>
   <input class="form-input" @bind="editingTicket.Title" placeholder="Enter ticket title" />
   </div>
   <div class="form-group">
   <label>Client</label>
   <select class="form-input" @bind="editingTicket.ClientId" disabled>
   <option value="">Select client</option>
   @if (customers != null)
   {
   @foreach (var c in customers)
   {
   <option value="@c.Id">@c.Name</option>
   }
   }
   </select>
   </div>
   <div class="form-group">
   <label>Priority</label>
   <select class="form-input" @bind="editingTicket.Priority">
   <option value="Low">Low</option>
   <option value="Medium">Medium</option>
   <option value="High">High</option>
   <option value="Critical">Critical</option>
   </select>
   </div>
   <div class="form-group">
   <label>Status</label>
   <select class="form-input" @bind="editingTicket.Status">
   <option value="Open">Open</option>
   <option value="In Progress">In Progress</option>
   <option value="Resolved">Resolved</option>
   <option value="Closed">Closed</option>
   </select>
   </div>
   <div class="form-group">
   <label>Created</label>
   <input class="form-input" value="@editingTicket.Created.ToString("yyyy-MM-dd HH:mm")" disabled />
   </div>
   <div class="modal-actions">
   <button class="btn" @onclick="CloseEditTicketModal">Cancel</button>
   <button class="btn primary" @onclick="UpdateTicketAsync">Update</button>
   </div>
 </div>
 </div>
 }

 <Toast Message="@ticketToast" />
@if (!string.IsNullOrEmpty(ticketToast))
{
 <div class="toast">@ticketToast</div>
}
</div>

@code {
 private List<Ticket>? tickets; private List<Client>? customers; private List<Account>? accounts; private string ticketSearch="";
 private bool showNewTicketModal=false; private string newTicketTitle=""; private int? newTicketAccountId=null; private string newTicketClientId=""; private string newTicketClientName=""; private string newTicketPriority="Medium"; private string newTicketStatus="Open";
 private string accountText=""; private Account? selectedAccount=null;
 private bool showEditTicketModal=false; private Ticket? editingTicket=null; private string ticketToast=""; private string serviceError="";
 private string fallbackClientName = string.Empty;
 private bool isCreating = false;
 protected override async Task OnInitializedAsync(){ if(!AuthService.IsAuthenticated){ Navigation.NavigateTo("/login",true); return; } await LoadDataAsync(); accounts = await AdminService.GetAccountsAsync(); }
 private async Task LoadDataAsync(){ tickets = await AdminService.GetTicketsAsync(); customers = await AdminService.GetCustomersAsync(); StateHasChanged(); }
 private void ShowNewTicketModal(){ newTicketTitle=""; newTicketAccountId=null; newTicketClientId=""; newTicketClientName=""; newTicketPriority="Medium"; newTicketStatus="Open"; accountText=""; selectedAccount=null; showNewTicketModal=true; }
 private void CloseNewTicketModal(){ showNewTicketModal=false; newTicketAccountId=null; newTicketClientId=""; newTicketClientName=""; accountText=""; selectedAccount=null; fallbackClientName=""; }
 private void OnAccountTextChanged(){ var idPart = accountText.Split('-').FirstOrDefault()?.Trim(); if(int.TryParse(idPart, out var parsed)){ var acc = accounts?.FirstOrDefault(a => a.Id==parsed); if(acc!=null){ selectedAccount = acc; newTicketAccountId = acc.Id; var linked = customers?.Where(c => c.AccountId == acc.Id).ToList() ?? new List<Client>(); if(linked.Count>0){ var cust = linked[0]; newTicketClientId = cust.Id; newTicketClientName = cust.Name; fallbackClientName = string.Empty; } else { newTicketClientId=""; newTicketClientName=""; } } } StateHasChanged(); }
 private async Task OnCreateNewTicketClicked(){
   if(isCreating) return;
   serviceError = string.Empty;
   if(newTicketAccountId==null){
     serviceError = "Account is required.";
     ticketToast="Account required"; StateHasChanged(); await Task.Delay(1600); ticketToast=""; return;
   }
   if(string.IsNullOrWhiteSpace(newTicketTitle)){
     serviceError = "Title is required.";
     ticketToast="Title required"; StateHasChanged(); await Task.Delay(1600); ticketToast=""; return;
   }
   // enforce client dependency on account: require linked client
   if (string.IsNullOrWhiteSpace(newTicketClientId))
   {
     serviceError = "No linked client found for the selected account. Please link a client to this account first.";
     ticketToast = "Linked client required";
     StateHasChanged();
     await Task.Delay(1600);
     ticketToast = "";
     return;
   }
   try
   {
     isCreating = true;
     var t=new Ticket{ Title=newTicketTitle, AccountId=newTicketAccountId, ClientId=newTicketClientId, ClientName=newTicketClientName, Priority=newTicketPriority, Status=newTicketStatus, Created=DateTime.UtcNow };
     var ok=await AdminService.CreateTicketAsync(t);
     if(!ok)
     {
       serviceError = AdminService.LastError ?? "Failed to create ticket. Please try again.";
       ticketToast = "Failed";
       StateHasChanged();
       await Task.Delay(2000);
       ticketToast="";
       return;
     }
     ticketToast = "Ticket created";
     await LoadDataAsync();
     CloseNewTicketModal();
     StateHasChanged();
     await Task.Delay(2000);
     ticketToast="";
   }
   catch (Exception ex)
   {
     serviceError = $"Unexpected error: {ex.Message}";
     ticketToast = "Error";
     StateHasChanged();
     await Task.Delay(2000);
     ticketToast="";
   }
   finally
   {
     isCreating = false;
     StateHasChanged();
   }
 }
 // Edit modal
 private void ShowEditTicketModal(Ticket ticket){ editingTicket = new Ticket{ Id=ticket.Id, Title=ticket.Title, ClientId=ticket.ClientId, Priority=ticket.Priority, Status=ticket.Status, Created=ticket.Created }; showEditTicketModal=true; }
 private void CloseEditTicketModal(){ showEditTicketModal=false; editingTicket=null; }
 private async Task UpdateTicketAsync(){ if(editingTicket==null || string.IsNullOrWhiteSpace(editingTicket.Title)) return; await AdminService.UpdateTicketAsync(editingTicket); await LoadDataAsync(); CloseEditTicketModal(); }
 private async Task DeleteTicketAsync(int id){ if(id<=0) return; await AdminService.DeleteTicketAsync(id); await LoadDataAsync(); }
 private async void ExportTickets(){ var rows = tickets ?? new List<Ticket>(); var sb=new System.Text.StringBuilder(); sb.AppendLine("Id,Title,Client,Priority,Status,Created"); foreach(var r in rows) sb.AppendLine($"{r.Id},{Escape(r.Title)},{Escape(GetClientLabel(r))},{r.Priority},{r.Status},{r.Created:yyyy-MM-dd HH:mm}"); await JS.InvokeAsync<bool>("FiberExport.saveFile","tickets.csv",sb.ToString()); ticketToast="Tickets exported"; StateHasChanged(); _=ClearToastAfterDelay(); }
 private async Task ClearToastAfterDelay(){ await Task.Delay(2200); ticketToast=""; StateHasChanged(); }
 private string Escape(string? s)=> string.IsNullOrEmpty(s)?"":s.Replace("\"","\"\"");
 private string GetTimeAgo(DateTime createdUtc){ var utc=DateTime.SpecifyKind(createdUtc,DateTimeKind.Utc); var span=DateTime.UtcNow-utc; if(span.TotalMinutes<1) return "just now"; if(span.TotalMinutes<60) return $"{(int)span.TotalMinutes} mins ago"; if(span.TotalHours<24) return $"{(int)span.TotalHours} hrs ago"; return $"{(int)span.TotalDays} days ago"; }
 private string GetCustomerDisplay(string id){ if(string.IsNullOrEmpty(id)||customers==null) return ""; var c=customers.FirstOrDefault(x=>x.Id==id); return c?.Name ?? id; }
 private IEnumerable<Ticket>? FilteredTickets => string.IsNullOrWhiteSpace(ticketSearch)?tickets: tickets?.Where(t => t.Id.ToString().Contains(ticketSearch,StringComparison.OrdinalIgnoreCase) || (t.Title??"").Contains(ticketSearch,StringComparison.OrdinalIgnoreCase) || GetCustomerDisplay(t.ClientId??"").Contains(ticketSearch,StringComparison.OrdinalIgnoreCase));
 private string GetPriorityBadge(string? p){ if(string.IsNullOrWhiteSpace(p)) return "badge-prio-low"; return p.ToLowerInvariant() switch {"low"=>"badge-prio-low","medium"=>"badge-prio-medium","high"=>"badge-prio-high","critical"=>"badge-prio-critical", _=>"badge-prio-low"}; }
 private string GetStatusBadge(string? s){ if(string.IsNullOrWhiteSpace(s)) return "badge-status-open"; var v=s.ToLowerInvariant(); if(v=="in progress") v="inprogress"; return v switch{"open"=>"badge-status-open","inprogress"=>"badge-status-inprogress","resolved"=>"badge-status-resolved","closed"=>"badge-status-closed", _=>"badge-status-open"}; }
 private string GetRoleLabel(){ var role=AuthService?.Role; return string.IsNullOrWhiteSpace(role)?"ADMIN VIEW":role.ToUpperInvariant(); }
 private string GetInitial(Ticket t){ var label= GetClientLabel(t); if(string.IsNullOrWhiteSpace(label)) label=t.Title ?? "T"; label=label.Trim(); return label.Length==0?"T":label.Substring(0,1).ToUpperInvariant(); }
 private string FormatLocal(DateTime createdUtc)=> DateTime.SpecifyKind(createdUtc,DateTimeKind.Utc).ToLocalTime().ToString("yyyy-MM-dd HH:mm");
 private string GetClientLabel(Ticket t)
 {
   if (t == null) return string.Empty;
   if (!string.IsNullOrWhiteSpace(t.ClientName)) return t.ClientName;
   return GetCustomerDisplay(t.ClientId ?? "");
 }
}
