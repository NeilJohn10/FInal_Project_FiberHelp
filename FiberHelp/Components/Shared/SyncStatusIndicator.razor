@* SyncStatusIndicator.razor - Shows sync status in the UI *@
@inject FiberHelp.Services.DataSyncService SyncService
@implements IDisposable

<div class="sync-indicator @GetStatusClass()" title="@GetStatusTitle()">
    <div class="sync-dot"></div>
    <span class="sync-label">@GetStatusLabel()</span>
    @if (_isSyncing)
    {
        <svg class="sync-spinner" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/>
        </svg>
    }
</div>

<style>
    .sync-indicator {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    .sync-indicator.online {
        background: rgba(16, 185, 129, 0.15);
        color: #059669;
    }
    
    .sync-indicator.offline {
        background: rgba(239, 68, 68, 0.15);
        color: #dc2626;
    }
    
    .sync-indicator.syncing {
        background: rgba(59, 130, 246, 0.15);
        color: #2563eb;
    }
    
    .sync-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: currentColor;
        animation: pulse 2s infinite;
    }
    
    .sync-indicator.offline .sync-dot {
        animation: none;
    }
    
    .sync-label {
        white-space: nowrap;
    }
    
    .sync-spinner {
        animation: spin 1s linear infinite;
    }
    
    @@keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.2); }
    }
    
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
</style>

@code {
    private bool _isOnline = true;
    private bool _isSyncing = false;
    private DateTime? _lastSyncTime;
    private System.Threading.Timer? _checkTimer;

    protected override void OnInitialized()
    {
        // Check connectivity every 5 seconds
        _checkTimer = new System.Threading.Timer(async _ => await CheckConnectivity(), null, 
            TimeSpan.Zero, TimeSpan.FromSeconds(5));
    }

    private async Task CheckConnectivity()
    {
        try
        {
            // Simple connectivity check - you can enhance this
            using var httpClient = new HttpClient { Timeout = TimeSpan.FromSeconds(3) };
            var response = await httpClient.GetAsync("https://www.google.com/generate_204");
            _isOnline = response.IsSuccessStatusCode;
        }
        catch
        {
            _isOnline = false;
        }
        
        await InvokeAsync(StateHasChanged);
    }

    private string GetStatusClass()
    {
        if (_isSyncing) return "syncing";
        return _isOnline ? "online" : "offline";
    }

    private string GetStatusLabel()
    {
        if (_isSyncing) return "Syncing...";
        return _isOnline ? "Online" : "Offline";
    }

    private string GetStatusTitle()
    {
        if (_isSyncing) return "Synchronizing data with cloud...";
        if (_isOnline)
        {
            return _lastSyncTime.HasValue 
                ? $"Connected. Last sync: {_lastSyncTime.Value:HH:mm:ss}" 
                : "Connected to cloud database";
        }
        return "Working offline. Changes will sync when connected.";
    }

    public void Dispose()
    {
        _checkTimer?.Dispose();
    }
}
