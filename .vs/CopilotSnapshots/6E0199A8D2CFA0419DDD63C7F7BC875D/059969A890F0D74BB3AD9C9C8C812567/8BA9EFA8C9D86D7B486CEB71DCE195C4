@page "/diag"
@using FiberHelp.Models
@using FiberHelp.Data
@using Microsoft.EntityFrameworkCore
@inject FiberHelp.Data.AppDbContext Db
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.DataSyncService SyncService

<PageTitle>Diagnostic - FiberHelp</PageTitle>

<h3>Database Diagnostic</h3>
<p>Connection: <code>@(Db.Database.GetDbConnection().DataSource)</code> / Database: <code>@(Db.Database.GetDbConnection().Database)</code></p>

<div style="margin:12px 0;">
    <button class="btn btn-primary" @onclick="DoSyncNow">Sync cloud ? local now</button>
    @if (!string.IsNullOrWhiteSpace(syncMsg))
    {
        <span style="margin-left:10px;">@syncMsg</span>
    }
</div>

@if (error != null)
{
 <div style="color:darkred">Error: @error</div>
}
else
{
 <h4>Users (@(users?.Count ??0))</h4>
 <table class="data-table">
 <thead><tr><th>Email</th><th>Role</th><th>PasswordHash</th></tr></thead>
 <tbody>
 @if (users != null)
 {
 foreach (var u in users)
 {
 <tr>
 <td>@u.Email</td>
 <td>@u.Role</td>
 <td style="font-family:monospace">@u.PasswordHash</td>
 </tr>
 }
 }
 </tbody>
 </table>

 <h4>Clients (@(clients?.Count ??0))</h4>
 <ul>
 @if (clients != null)
 {
 foreach (var c in clients) { <li>@c.Name (@c.Email)</li>; }
 }
 </ul>

 <h4>Tickets (@(tickets?.Count ??0))</h4>
 <ul>
 @if (tickets != null)
 {
 foreach (var t in tickets) { <li>@t.Title - @(t.ClientName ?? t.ClientId) (@t.Status)</li>; }
 }
 </ul>
}

@code {
 private List<User>? users;
 private List<Client>? clients;
 private List<Ticket>? tickets;
 private string? error;
 private string? syncMsg;

 protected override async Task OnInitializedAsync()
 {
 try
 {
 // Ensure DB created and seeded
 Db.Database.EnsureCreated();
 if (!await Db.Users.AnyAsync()) FiberHelp.Data.DbInitializer.Initialize(Db);

 users = await Db.Users.AsNoTracking().ToListAsync();
 clients = await Db.Clients.AsNoTracking().ToListAsync();
 tickets = await Db.Tickets.AsNoTracking().ToListAsync();
 }
 catch (Exception ex)
 {
 error = ex.Message;
 }
 }

 private async Task DoSyncNow()
 {
     try
     {
         syncMsg = "Running sync...";
         StateHasChanged();
         await SyncService.SyncCloudToLocalAsync();
         syncMsg = "Sync complete.";
     }
     catch (Exception ex)
     {
         syncMsg = $"Sync failed: {ex.Message}";
     }
 }
}
