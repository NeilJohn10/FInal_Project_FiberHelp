@page "/feedback-management"
@using FiberHelp.Models
@using FiberHelp.Services
@inject TransactionService TransactionService
@inject AuthService AuthService
@inject ErrorHandlingService ErrorService
@inject NavigationManager Navigation
@inject Microsoft.JSInterop.IJSRuntime JS

<style>
    .feedback-mgmt-header { display: flex; align-items: center; justify-content: space-between; padding-bottom: 20px; margin-bottom: 22px; border-bottom: 1px solid #e5e7eb; }
    .feedback-mgmt-header .page-title { font-size: 42px; line-height: 1.1; margin: 0 0 4px; }
    .feedback-mgmt-controls { display: flex; gap: 14px; align-items: center; }
    .filter-select { padding: 10px 16px; border-radius: 10px; border: 1px solid #e5e7eb; background: #fff; font-size: 14px; }
    
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 20px; margin-bottom: 28px; }
    .stat-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
    .stat-card .stat-value { font-size: 32px; font-weight: 700; color: #1e293b; }
    .stat-card .stat-label { font-size: 13px; color: #64748b; margin-top: 4px; }
    .stat-card.highlight { background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); }
    .stat-card.highlight .stat-value, .stat-card.highlight .stat-label { color: #fff; }
    
    .rating-display { display: flex; align-items: center; gap: 4px; }
    .rating-display .stars { color: #f59e0b; font-size: 16px; }
    .rating-display .value { font-weight: 600; color: #1e293b; margin-left: 4px; }
    
    .feedback-table { width: 100%; border-collapse: separate; border-spacing: 0 8px; }
    .feedback-table thead th { font-size: 12px; font-weight: 700; padding: 10px 12px; color: #475569; text-align: left; text-transform: uppercase; }
    .feedback-table tbody td { background: #f9fafb; padding: 16px 12px; font-size: 14px; border-top: 1px solid #edf2f7; border-bottom: 1px solid #edf2f7; }
    .feedback-table tbody tr td:first-child { border-left: 1px solid #edf2f7; border-top-left-radius: 10px; border-bottom-left-radius: 10px; }
    .feedback-table tbody tr td:last-child { border-right: 1px solid #edf2f7; border-top-right-radius: 10px; border-bottom-right-radius: 10px; }
    .feedback-table tbody tr:hover td { background: #f1f5f9; }
    
    .badge { display: inline-block; padding: 5px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
    .badge-pending { background: #fef3c7; color: #92400e; }
    .badge-reviewed { background: #dbeafe; color: #1e40af; }
    .badge-action { background: #fee2e2; color: #991b1b; }
    .badge-resolved { background: #dcfce7; color: #166534; }
    
    .client-info { display: flex; flex-direction: column; gap: 2px; }
    .client-info .name { font-weight: 600; color: #1e293b; }
    .client-info .id { font-size: 11px; color: #64748b; font-family: monospace; }
    
    .comments-preview { max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #475569; }
    
    .action-btn { border: none; background: transparent; padding: 6px 8px; border-radius: 8px; cursor: pointer; transition: all 0.15s; }
    .action-btn:hover { background: #eef2ff; }
    
    .modal-bg { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: grid; place-items: center; z-index: 60000; }
    .modal-card { width: calc(100% - 80px); max-width: 700px; background: #fff; border-radius: 16px; padding: 28px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
    .modal-header h3 { margin: 0; font-size: 22px; color: #1e293b; }
    .modal-close { border: none; background: transparent; cursor: pointer; padding: 8px; border-radius: 8px; }
    .modal-close:hover { background: #f1f5f9; }
    
    .detail-section { margin-bottom: 24px; }
    .detail-section h4 { font-size: 14px; font-weight: 600; color: #64748b; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 0.5px; }
    .detail-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .detail-item { background: #f8fafc; padding: 12px 16px; border-radius: 10px; }
    .detail-item .label { font-size: 12px; color: #64748b; margin-bottom: 4px; }
    .detail-item .value { font-weight: 600; color: #1e293b; }
    
    .star-display { color: #f59e0b; font-size: 20px; letter-spacing: 2px; }
    .star-empty { color: #e5e7eb; }
    
    .comments-box { background: #f8fafc; padding: 16px; border-radius: 10px; font-size: 14px; color: #475569; line-height: 1.6; white-space: pre-wrap; }
    
    .review-form { background: #f0f9ff; border: 1px solid #bae6fd; border-radius: 12px; padding: 20px; margin-top: 20px; }
    .review-form h4 { margin: 0 0 16px; color: #0c4a6e; }
    .review-form textarea { width: 100%; min-height: 80px; padding: 12px; border: 1px solid #e5e7eb; border-radius: 8px; font-size: 14px; resize: vertical; }
    .review-form .checkbox-group { display: flex; align-items: center; gap: 8px; margin: 12px 0; }
    .review-form .checkbox-group input { width: 18px; height: 18px; }
    
    .modal-actions { display: flex; justify-content: flex-end; gap: 12px; margin-top: 24px; padding-top: 20px; border-top: 1px solid #e5e7eb; }
    .btn { padding: 10px 24px; border-radius: 10px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.2s; }
    .btn-primary { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; border: none; }
    .btn-secondary { background: #fff; color: #475569; border: 1px solid #e5e7eb; }
    .btn-success { background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff; border: none; }
    
    .empty-state { text-align: center; padding: 60px 20px; color: #64748b; }
    .empty-state h3 { color: #475569; margin-bottom: 8px; }
    
    .performance-section { margin-top: 32px; }
    .performance-section h3 { font-size: 20px; margin-bottom: 16px; color: #1e293b; }
    .performance-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .performance-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 20px; }
    .performance-card .staff-name { font-weight: 600; font-size: 16px; color: #1e293b; margin-bottom: 12px; }
    .performance-card .metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; text-align: center; }
    .performance-card .metric { background: #f8fafc; padding: 10px; border-radius: 8px; }
    .performance-card .metric .value { font-size: 20px; font-weight: 700; color: #2563eb; }
    .performance-card .metric .label { font-size: 11px; color: #64748b; }
</style>

<div>
    <header class="feedback-mgmt-header">
        <div>
            <p class="eyebrow">FIBERHELP · CUSTOMER EXPERIENCE</p>
            <h1 class="page-title">Feedback Management</h1>
        </div>
        <div class="feedback-mgmt-controls">
            <select class="filter-select" @bind="statusFilter" @bind:after="LoadFeedbackAsync">
                <option value="">All Feedback</option>
                <option value="Pending">Pending Review</option>
                <option value="ActionRequired">Action Required</option>
                <option value="Reviewed">Reviewed</option>
                <option value="Resolved">Resolved</option>
            </select>
            <button class="btn btn-secondary" @onclick="ExportFeedback">Export CSV</button>
        </div>
    </header>

    <!-- Statistics Cards -->
    <div class="stats-grid">
        <div class="stat-card highlight">
            <div class="stat-value">@stats.AverageRating.ToString("0.0")</div>
            <div class="stat-label">Average Rating</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@stats.TotalCount</div>
            <div class="stat-label">Total Feedback</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@stats.PendingCount</div>
            <div class="stat-label">Pending Review</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@stats.RequiresFollowUpCount</div>
            <div class="stat-label">Needs Follow-up</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@stats.WouldRecommendPercentage.ToString("0")%</div>
            <div class="stat-label">Would Recommend</div>
        </div>
    </div>

    <!-- Feedback Table -->
    <section class="panel" style="background:#fff;border-radius:16px;padding:24px;box-shadow:0 2px 12px rgba(0,0,0,0.04);">
        <table class="feedback-table">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Rating</th>
                    <th>Category</th>
                    <th>Comments</th>
                    <th>Submitted</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (feedbackList != null && feedbackList.Any())
                {
                    @foreach (var fb in feedbackList)
                    {
                        <tr>
                            <td>
                                <div class="client-info">
                                    <span class="name">@(fb.ClientName ?? "Unknown")</span>
                                    <span class="id">@fb.ClientId</span>
                                </div>
                            </td>
                            <td>
                                <div class="rating-display">
                                    <span class="stars">@(new string('?', fb.Rating))@(new string('?', 5 - fb.Rating))</span>
                                    <span class="value">@fb.Rating/5</span>
                                </div>
                            </td>
                            <td>@fb.FeedbackCategory</td>
                            <td>
                                <div class="comments-preview" title="@fb.Comments">
                                    @(string.IsNullOrEmpty(fb.Comments) ? "-" : fb.Comments)
                                </div>
                            </td>
                            <td>@GetTimeAgo(fb.SubmittedAt)</td>
                            <td>
                                <span class="badge @GetStatusBadgeClass(fb.Status)">@fb.Status</span>
                            </td>
                            <td>
                                <button class="action-btn" title="View Details" @onclick="() => ShowFeedbackDetails(fb)">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2">
                                        <circle cx="12" cy="12" r="3"/>
                                        <path d="M2 12s4-8 10-8 10 8 10 8-4 8-10 8-10-8-10-8z"/>
                                    </svg>
                                </button>
                                @if (!fb.IsReviewed)
                                {
                                    <button class="action-btn" title="Mark as Reviewed" @onclick="() => QuickReview(fb.Id)">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2">
                                            <polyline points="20 6 9 17 4 12"/>
                                        </svg>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <h3>No Feedback Found</h3>
                                <p>No feedback matches the current filter criteria.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <!-- Staff Performance Section -->
    @if (staffPerformance != null && staffPerformance.Any())
    {
        <section class="performance-section">
            <h3>Staff Performance (Based on Feedback)</h3>
            <div class="performance-grid">
                @foreach (var staff in staffPerformance.Take(6))
                {
                    <div class="performance-card">
                        <div class="staff-name">@staff.StaffName</div>
                        <div class="metrics">
                            <div class="metric">
                                <div class="value">@staff.AverageRating.ToString("0.0")</div>
                                <div class="label">Avg Rating</div>
                            </div>
                            <div class="metric">
                                <div class="value">@staff.FeedbackCount</div>
                                <div class="label">Reviews</div>
                            </div>
                            <div class="metric">
                                <div class="value" style="color:#22c55e">@staff.PositiveFeedbackCount</div>
                                <div class="label">Positive</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Feedback Details Modal -->
    @if (showDetailsModal && selectedFeedback != null)
    {
        <div class="modal-bg" @onclick="CloseDetailsModal">
            <div class="modal-card" @onclick:stopPropagation>
                <div class="modal-header">
                    <h3>Feedback Details</h3>
                    <button class="modal-close" @onclick="CloseDetailsModal">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2">
                            <line x1="18" y1="6" x2="6" y2="18"/>
                            <line x1="6" y1="6" x2="18" y2="18"/>
                        </svg>
                    </button>
                </div>

                <div class="detail-section">
                    <h4>Client Information</h4>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="label">Client Name</div>
                            <div class="value">@(selectedFeedback.ClientName ?? "Unknown")</div>
                        </div>
                        <div class="detail-item">
                            <div class="label">Client ID</div>
                            <div class="value" style="font-family:monospace">@selectedFeedback.ClientId</div>
                        </div>
                        @if (selectedFeedback.TicketId.HasValue)
                        {
                            <div class="detail-item">
                                <div class="label">Related Ticket</div>
                                <div class="value">#@selectedFeedback.TicketId</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(selectedFeedback.HandledByName))
                        {
                            <div class="detail-item">
                                <div class="label">Handled By</div>
                                <div class="value">@selectedFeedback.HandledByName</div>
                            </div>
                        }
                    </div>
                </div>

                <div class="detail-section">
                    <h4>Ratings</h4>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="label">Overall Rating</div>
                            <div class="star-display">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= selectedFeedback.Rating ? "" : "star-empty")">?</span>
                                }
                            </div>
                        </div>
                        @if (selectedFeedback.ServiceQualityRating.HasValue)
                        {
                            <div class="detail-item">
                                <div class="label">Service Quality</div>
                                <div class="value">@selectedFeedback.ServiceQualityRating/5</div>
                            </div>
                        }
                        @if (selectedFeedback.ResponseTimeRating.HasValue)
                        {
                            <div class="detail-item">
                                <div class="label">Response Time</div>
                                <div class="value">@selectedFeedback.ResponseTimeRating/5</div>
                            </div>
                        }
                        @if (selectedFeedback.ProfessionalismRating.HasValue)
                        {
                            <div class="detail-item">
                                <div class="label">Professionalism</div>
                                <div class="value">@selectedFeedback.ProfessionalismRating/5</div>
                            </div>
                        }
                        @if (selectedFeedback.CommunicationRating.HasValue)
                        {
                            <div class="detail-item">
                                <div class="label">Communication</div>
                                <div class="value">@selectedFeedback.CommunicationRating/5</div>
                            </div>
                        }
                        <div class="detail-item">
                            <div class="label">Would Recommend</div>
                            <div class="value">
                                @if (selectedFeedback.WouldRecommend == true)
                                {
                                    <span style="color:#22c55e">?? Yes</span>
                                }
                                else if (selectedFeedback.WouldRecommend == false)
                                {
                                    <span style="color:#ef4444">?? No</span>
                                }
                                else
                                {
                                    <span style="color:#64748b">Not specified</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(selectedFeedback.Comments))
                {
                    <div class="detail-section">
                        <h4>Customer Comments</h4>
                        <div class="comments-box">@selectedFeedback.Comments</div>
                    </div>
                }

                @if (!selectedFeedback.IsReviewed)
                {
                    <div class="review-form">
                        <h4>Review This Feedback</h4>
                        <textarea placeholder="Add review notes..." @bind="reviewNotes"></textarea>
                        <div class="checkbox-group">
                            <input type="checkbox" id="followUp" @bind="requiresFollowUp" />
                            <label for="followUp">Requires follow-up action</label>
                        </div>
                    </div>
                }
                else
                {
                    <div class="detail-section">
                        <h4>Review Information</h4>
                        <div class="detail-grid">
                            <div class="detail-item">
                                <div class="label">Reviewed At</div>
                                <div class="value">@(selectedFeedback.ReviewedAt?.ToLocalTime().ToString("MMM dd, yyyy h:mm tt") ?? "-")</div>
                            </div>
                            @if (!string.IsNullOrEmpty(selectedFeedback.ReviewNotes))
                            {
                                <div class="detail-item" style="grid-column: span 2">
                                    <div class="label">Review Notes</div>
                                    <div class="value">@selectedFeedback.ReviewNotes</div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="modal-actions">
                    <button class="btn btn-secondary" @onclick="CloseDetailsModal">Close</button>
                    @if (!selectedFeedback.IsReviewed)
                    {
                        <button class="btn btn-success" @onclick="SubmitReview">Mark as Reviewed</button>
                    }
                    else if (selectedFeedback.RequiresFollowUp && !selectedFeedback.FollowUpCompletedAt.HasValue)
                    {
                        <button class="btn btn-success" @onclick="CompleteFollowUp">Complete Follow-up</button>
                    }
                </div>
            </div>
        </div>
    }
</div>

<Toast Message="@toastMessage" />

@code {
    private List<ClientFeedback>? feedbackList;
    private List<TransactionService.StaffPerformance>? staffPerformance;
    private TransactionService.FeedbackStatistics stats = new(0, 0, 0, 0, 0, 0, 0, new Dictionary<int, int>());
    private string statusFilter = "";
    private bool showDetailsModal = false;
    private ClientFeedback? selectedFeedback;
    private string reviewNotes = "";
    private bool requiresFollowUp = false;
    private string toastMessage = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", true);
            return;
        }

        if (!AuthService.CanManageTickets)
        {
            Navigation.NavigateTo("/", true);
            return;
        }

        await LoadFeedbackAsync();
        await LoadStatsAsync();
        await LoadStaffPerformanceAsync();
    }

    private async Task LoadFeedbackAsync()
    {
        try
        {
            bool? onlyPending = null;
            if (statusFilter == "Pending") onlyPending = true;

            var all = await TransactionService.GetAllFeedbackAsync(onlyPending);
            
            if (!string.IsNullOrEmpty(statusFilter) && statusFilter != "Pending")
            {
                feedbackList = all.Where(f => f.Status == statusFilter).ToList();
            }
            else
            {
                feedbackList = all;
            }
        }
        catch (Exception ex)
        {
            toastMessage = ErrorService.GetContextualMessage(ex, "load", "feedback");
            feedbackList = new List<ClientFeedback>();
        }
    }

    private async Task LoadStatsAsync()
    {
        try
        {
            stats = await TransactionService.GetFeedbackStatisticsAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading stats: {ex.Message}");
        }
    }

    private async Task LoadStaffPerformanceAsync()
    {
        try
        {
            staffPerformance = await TransactionService.GetStaffPerformanceAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Error loading staff performance: {ex.Message}");
        }
    }

    private void ShowFeedbackDetails(ClientFeedback feedback)
    {
        selectedFeedback = feedback;
        reviewNotes = "";
        requiresFollowUp = false;
        showDetailsModal = true;
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedFeedback = null;
    }

    private async Task QuickReview(int feedbackId)
    {
        try
        {
            var success = await TransactionService.ReviewFeedbackAsync(feedbackId, AuthService.UserId ?? "system");
            if (success)
            {
                toastMessage = "Feedback marked as reviewed";
                await LoadFeedbackAsync();
                await LoadStatsAsync();
            }
            else
            {
                toastMessage = "Failed to review feedback";
            }
            StateHasChanged();
            await Task.Delay(2000);
            toastMessage = "";
        }
        catch (Exception ex)
        {
            toastMessage = ErrorService.GetContextualMessage(ex, "update", "feedback");
        }
    }

    private async Task SubmitReview()
    {
        if (selectedFeedback == null) return;

        try
        {
            var success = await TransactionService.ReviewFeedbackAsync(
                selectedFeedback.Id,
                AuthService.UserId ?? "system",
                reviewNotes,
                requiresFollowUp
            );

            if (success)
            {
                toastMessage = "Feedback reviewed successfully";
                CloseDetailsModal();
                await LoadFeedbackAsync();
                await LoadStatsAsync();
            }
            else
            {
                toastMessage = "Failed to submit review";
            }
            StateHasChanged();
            await Task.Delay(2000);
            toastMessage = "";
        }
        catch (Exception ex)
        {
            toastMessage = ErrorService.GetContextualMessage(ex, "update", "feedback");
        }
    }

    private async Task CompleteFollowUp()
    {
        if (selectedFeedback == null) return;

        try
        {
            var success = await TransactionService.CompleteFollowUpAsync(
                selectedFeedback.Id,
                "Follow-up completed"
            );

            if (success)
            {
                toastMessage = "Follow-up completed";
                CloseDetailsModal();
                await LoadFeedbackAsync();
                await LoadStatsAsync();
            }
            else
            {
                toastMessage = "Failed to complete follow-up";
            }
            StateHasChanged();
            await Task.Delay(2000);
            toastMessage = "";
        }
        catch (Exception ex)
        {
            toastMessage = ErrorService.GetContextualMessage(ex, "update", "follow-up");
        }
    }

    private async void ExportFeedback()
    {
        try
        {
            if (feedbackList == null || !feedbackList.Any())
            {
                toastMessage = "No feedback to export";
                StateHasChanged();
                return;
            }

            var sb = new System.Text.StringBuilder();
            sb.AppendLine("ID,Client,Rating,Category,Would Recommend,Status,Submitted,Comments");

            foreach (var fb in feedbackList)
            {
                sb.AppendLine($"{fb.Id},{Escape(fb.ClientName)},{fb.Rating},{fb.FeedbackCategory},{fb.WouldRecommend},{fb.Status},{fb.SubmittedAt:yyyy-MM-dd},{Escape(fb.Comments)}");
            }

            await JS.InvokeAsync<bool>("FiberExport.saveFile", "feedback_export.csv", sb.ToString());
            toastMessage = $"Exported {feedbackList.Count} feedback entries";
            StateHasChanged();
            await Task.Delay(2000);
            toastMessage = "";
        }
        catch (Exception ex)
        {
            toastMessage = ErrorService.GetContextualMessage(ex, "export", "feedback");
            StateHasChanged();
        }
    }

    private string Escape(string? s) => string.IsNullOrEmpty(s) ? "" : s.Replace("\"", "\"\"").Replace(",", ";");

    private string GetStatusBadgeClass(string status)
    {
        return status?.ToLower() switch
        {
            "pending" => "badge-pending",
            "reviewed" => "badge-reviewed",
            "actionrequired" => "badge-action",
            "resolved" => "badge-resolved",
            _ => "badge-pending"
        };
    }

    private string GetTimeAgo(DateTime date)
    {
        var span = DateTime.UtcNow - date;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return $"{(int)span.TotalDays}d ago";
        return date.ToLocalTime().ToString("MMM dd");
    }
}
