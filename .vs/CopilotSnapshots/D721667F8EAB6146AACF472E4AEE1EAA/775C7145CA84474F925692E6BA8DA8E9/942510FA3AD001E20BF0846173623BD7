public async Task<bool> CreateCustomerAsync(Client c) 
{ 
    try 
    { 
        LastError = null; 
        if (c == null) { LastError = "Client is null"; return false; } 
        
        // Generate user-friendly Client ID (CLT-0001 format)
        if (string.IsNullOrWhiteSpace(c.Id)) 
        {
            // Get the next sequence number
            var maxId = await _db.Clients
                .Where(x => x.Id.StartsWith("CLT-"))
                .Select(x => x.Id)
                .ToListAsync();
            
            int nextSeq = 1;
            if (maxId.Any())
            {
                var sequences = maxId
                    .Select(id => {
                        var parts = id.Split('-');
                        if (parts.Length == 2 && int.TryParse(parts[1], out var num))
                            return num;
                        return 0;
                    })
                    .Where(n => n > 0);
                
                if (sequences.Any())
                    nextSeq = sequences.Max() + 1;
            }
            
            c.Id = Client.GenerateClientId(nextSeq);
        }
        
        if (c.JoinDate == default) c.JoinDate = DateTime.UtcNow; 
        
        // Ensure navigation property is null before adding
        c.Account = null;
        
        _db.Clients.Add(c); 
        var rows = await _db.SaveChangesAsync(); 
        if (rows <= 0) LastError = "Client insert returned 0 rows"; 
        await MaybeSyncOrEnqueueAsync("Create", c, c.Id); 
        return rows > 0; 
    } 
    catch (Exception ex) 
    { 
        LastError = _errorService.GetContextualMessage(ex, "create", "client");
        System.Diagnostics.Debug.WriteLine($"AdminService.CreateCustomerAsync error: {ex}"); 
        return false; 
    } 
}

