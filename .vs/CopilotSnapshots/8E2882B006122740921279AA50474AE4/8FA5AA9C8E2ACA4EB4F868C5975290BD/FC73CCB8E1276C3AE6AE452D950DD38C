using Microsoft.AspNetCore.Components;
using FiberHelp.Models;
using FiberHelp.Services;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;

namespace FiberHelp.Components.Pages;

public partial class Agents : ComponentBase
{
 [Inject] private AdminService AdminService { get; set; } = default!;
 [Inject] private AuthService AuthService { get; set; } = default!;
 [Inject] private NavigationManager Navigation { get; set; } = default!;

 protected List<User>? agents;
 protected bool showNewAgent = false;
 protected string newEmail = string.Empty;
 protected string newFullName = string.Empty;
 private string newPasswordBacking = string.Empty;
 protected string errorMessage = string.Empty;
 protected string notification = string.Empty;

 protected bool hasMinLength;
 protected bool hasUpper;
 protected bool hasDigit;
 protected bool hasAtChar;

 protected string NewPassword
 {
 get => newPasswordBacking;
 set
 {
 newPasswordBacking = value ?? string.Empty;
 ValidatePassword();
 }
 }

 protected override async Task OnInitializedAsync()
 {
 if (!AuthService.IsAuthenticated || !(AuthService.Role ?? "").Equals("Administrator", System.StringComparison.OrdinalIgnoreCase))
 {
 Navigation.NavigateTo("/", true);
 return;
 }
 await LoadAgents();
 }

 protected async Task LoadAgents() => agents = await AdminService.GetAgentsAsync();

 protected void ShowNewAgent()
 {
 showNewAgent = true;
 errorMessage = string.Empty;
 notification = string.Empty;
 }

 protected void CloseNewAgent()
 {
 showNewAgent = false;
 newEmail = string.Empty;
 newFullName = string.Empty;
 NewPassword = string.Empty;
 errorMessage = string.Empty;
 ResetPasswordChecks();
 }

 private void ValidatePassword()
 {
 var pwd = NewPassword;
 hasMinLength = pwd.Length >=12;
 hasUpper = pwd.Any(char.IsUpper);
 hasDigit = pwd.Any(char.IsDigit);
 hasAtChar = pwd.Contains('@');
 }

 private void ResetPasswordChecks()
 {
 hasMinLength = hasUpper = hasDigit = hasAtChar = false;
 }

 protected string CheckMark(bool ok) => ok ? "✔" : "✖";
 protected string GetReqClass(bool ok) => $"req {(ok ? "valid" : "invalid")}";

 protected bool IsFormValid()
 {
 if (string.IsNullOrWhiteSpace(newEmail)) return false;
 if (string.IsNullOrWhiteSpace(NewPassword)) return false;
 return hasMinLength && hasUpper && hasDigit && hasAtChar;
 }

 protected async Task CreateAgent()
 {
 errorMessage = string.Empty;
 notification = string.Empty;
 if (!IsFormValid())
 {
 errorMessage = "Password does not meet requirements.";
 return;
 }
 var user = new User { Email = newEmail.Trim().ToLowerInvariant(), FullName = newFullName, Role = "Agent", IsActive = true };
 var ok = await AdminService.CreateAgentAsync(user, NewPassword);
 if (ok)
 {
 notification = "Agent created successfully.";
 await LoadAgents();
 CloseNewAgent();
 }
 else
 {
 errorMessage = AdminService.LastError ?? "Failed to create agent.";
 }
 }

 protected void EditAgent(string id)
 {
 // future implementation
 }

 protected async Task DeleteAgent(string id)
 {
 if (await AdminService.DeleteUserAsync(id))
 {
 await LoadAgents();
 }
 }
}
