@page "/"
@using FiberHelp.Models
@inject FiberHelp.Services.AuthService AuthService
@inject FiberHelp.Services.AdminService AdminService
@inject NavigationManager Navigation

<link href="css/dashboard.css" rel="stylesheet" />

@* If agent, show agent dashboard content; otherwise show admin dashboard *@
@if ((AuthService.Role ?? "").Equals("Agent", StringComparison.OrdinalIgnoreCase))
{
 <div>
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · AGENT VIEW</p>
 <h1 class="page-title">Agent Dashboard</h1>
 </div>
 <div class="top-actions">
 <div class="user-pill">
 <div class="avatar">AG</div>
 <div class="user-meta">
 <p class="user-email">@(AuthService.Email ?? "(not signed in)")</p>
 <p class="user-role">@(AuthService.Role ?? "Agent")</p>
 </div>
 </div>
 </div>
 </header>

 <section class="kpi-grid">
 <article class="kpi-card">
 <div class="kpi-header"><span>Your Open Tickets</span></div>
 <h2>@(tickets?.Count(t => t.Status == "Open") ??0)</h2>
 <p class="kpi-sub">Tickets requiring attention</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header"><span>Assigned to you (sample)</span></div>
 <h2>@(tickets?.Count ??0)</h2>
 <p class="kpi-sub">Total tickets visible</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header"><span>Avg response (est.)</span></div>
 <h2>~@((tickets?.Any() == true) ? Math.Max(1, tickets.Count/Math.Max(1, tickets.Count /3)) :0) hrs</h2>
 <p class="kpi-sub">Estimated avg turnaround</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header"><span>Resolved this week</span></div>
 <h2>@(tickets?.Count(t => t.Status == "Resolved" || t.Status == "Closed") ??0)</h2>
 <p class="kpi-sub">Resolution count</p>
 </article>
 </section>

 <section class="body-grid">
 <div class="panel">
 <h2>Ticket status distribution</h2>
 <div style="display:flex;gap:24px;align-items:center;">
 <div style="width:240px;height:240px;display:flex;align-items:center;justify-content:center;">
 @* Simple donut chart using SVG stroke-dasharray *@
 @if (tickets != null)
 {
 var statusCounts = tickets.GroupBy(t => (t.Status ?? "Unknown")).ToDictionary(g => g.Key, g => g.Count());
 var total = Math.Max(1, statusCounts.Values.Sum());
 var segments = statusCounts.Select(kv => new { Key = kv.Key, Count = kv.Value, Percent = (double)kv.Value / total }).ToList();
 <svg width="200" height="200" viewBox="004242" class="donut" role="img" aria-label="Ticket status distribution">
 <circle r="15.91549430918954" cx="21" cy="21" fill="#fff" stroke="#eee" stroke-width="6"></circle>
 @{
 double cumulative =0.0;
 foreach (var seg in segments)
 {
 var dashPercent = seg.Percent *100.0;
 var dashArray = $"{dashPercent} {100.0 - dashPercent}";
 <circle r="15.91549430918954" cx="21" cy="21" fill="transparent" stroke-width="6" stroke-linecap="butt"
 stroke="@GetColorForStatus(seg.Key)" stroke-dasharray="@dashArray" stroke-dashoffset="@(-cumulative)"></circle>;
 cumulative += dashPercent;
 }
 }
 </svg>
 }
 </div>
 <div style="flex:1">
 <ul style="list-style:none;padding:0;margin:0;">
 @if (tickets != null)
 {
 foreach (var kv in tickets.GroupBy(t => (t.Status ?? "Unknown")).OrderByDescending(g => g.Count()))
 {
 <li style="margin-bottom:8px;display:flex;align-items:center;gap:8px;">
 <span style="display:inline-block;width:12px;height:12px;background:@GetColorForStatus(kv.Key);"></span>
 <strong>@kv.Key</strong>
 <span style="margin-left:auto;color:#64748b;">@kv.Count()</span>
 </li>
 }
 }
 </ul>
 </div>
 </div>
 </div>

 <div class="panel">
 <h2>Priority distribution</h2>
 @if (tickets != null)
 {
 var pr = tickets.GroupBy(t => (t.Priority ?? "Medium")).ToDictionary(g => g.Key, g => g.Count());
 var max = pr.Values.DefaultIfEmpty(1).Max();
 <div style="display:flex;flex-direction:column;gap:8px;">
 @foreach (var kv in pr.OrderByDescending(x => x.Value))
 {
 var width = (int)( (kv.Value / (double)max) *100 );
 <div style="display:flex;align-items:center;gap:12px;">
 <div style="width:120px;color:#334155;">@kv.Key</div>
 <div style="flex:1;background:#f1f5f9;border-radius:6px;height:18px;overflow:hidden;">
 <div style="width:@width% ;height:100%;background:#2563eb;border-radius:6px;"></div>
 </div>
 <div style="width:48px;text-align:right;color:#64748b;">@kv.Value</div>
 </div>
 }
 </div>
 }
 </div>

 <div class="panel">
 <h2>7-day ticket trend</h2>
 @if (tickets != null)
 {
 var now = DateTime.UtcNow.Date;
 var days = Enumerable.Range(0,7).Select(i => now.AddDays(i -6)).ToArray();
 var counts = days.Select(d => tickets.Count(t => t.Created.Date == d)).ToArray();
 var maxc = counts.DefaultIfEmpty(1).Max();
 <svg width="100%" height="120" viewBox="00400120" preserveAspectRatio="none">
 @{ 
 int points = counts.Length;
 for (int i=0;i<points;i++)
 {
 var x =20 + i * (360.0/(points-1));
 var y =100 - (counts[i] / (double)maxc) *80;
 <circle cx="@x" cy="@y" r="3" fill="#2563eb" />;
 if (i>0)
 {
 var prevx =20 + (i-1) * (360.0/(points-1));
 var prevy =100 - (counts[i-1] / (double)maxc) *80;
 <line x1="@prevx" y1="@prevy" x2="@x" y2="@y" stroke="#60a5fa" stroke-width="2" />;
 }
 }
 }
 </svg>
 <div style="display:flex;justify-content:space-between;color:#64748b;font-size:13px;margin-top:6px;">
 @for (int i=0;i<7;i++) { <span>@now.AddDays(i-6).ToString("MM/dd")</span> }
 </div>
 }
 </div>
 </section>
 </div>
}
else
{
 @* existing admin dashboard markup preserved *@
 <div>
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN VIEW</p>
 <h1 class="page-title">Dashboard</h1>
 </div>
 <div class="top-actions">
 <button class="btn subtle" @onclick="ExportData">Export</button>
 <div class="user-pill">
 <div class="avatar">FH</div>
 <div class="user-meta">
 <p class="user-email">@(AuthService.Email ?? "(not signed in)")</p>
 <p class="user-role">@(AuthService.Role ?? "Guest")</p>
 </div>
 </div>
 </div>
 </header>

 <section class="kpi-grid">
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Total Customers</span>
 <span class="badge success">@((customers?.Count ??0) >0 ? "+" + ((customers.Count/10.0).ToString("0.0")) + "%" : "0%")</span>
 </div>
 <h2>@(customers?.Count ??0)</h2>
 <p class="kpi-sub">sample trend only</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Active Subscriptions</span>
 <span class="badge success">+2.1%</span>
 </div>
 <h2>94</h2>
 <p class="kpi-sub">active this month</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Open Tickets</span>
 <span class="badge warning">@((tickets?.Count(t => t.Status == "Open") ??0) + " high")</span>
 </div>
 <h2>@(tickets?.Count ??0)</h2>
 <p class="kpi-sub">need agent response</p>
 </article>
 <article class="kpi-card">
 <div class="kpi-header">
 <span>Pending Invoices</span>
 <span class="badge danger">follow up</span>
 </div>
 <h2>?30,000</h2>
 <p class="kpi-sub">unpaid amount</p>
 </article>
 </section>

 <section class="body-grid">
 <div class="panel">
 <div class="panel-head">
 <div>
 <h2>Latest Tickets</h2>
 <p class="muted-text">Most recent customer issues</p>
 </div>
 <div class="filter-pill">This week</div>
 </div>

 <table class="data-table">
 <thead>
 <tr>
 <th>Ticket #</th>
 <th>Account</th>
 <th>Subject</th>
 <th>Status</th>
 <th>Created</th>
 <th></th>
 </tr>
 </thead>
 <tbody>
 @if (tickets != null)
 {
 foreach (var t in tickets.Take(4))
 {
 <tr>
 <td>@t.Id</td>
 <td>@t.Customer</td>
 <td>@t.Title</td>
 <td>
 <span class="status-pill @t.Status.ToLower().Replace(" ", "")">@t.Status</span>
 </td>
 <td>@GetTimeAgo(t.Created)</td>
 <td>
 <button class="btn subtle" @onclick="NavigateToTickets">Open</button>
 </td>
 </tr>
 }
 }
 </tbody>
 </table>
 </div>

 <div class="panel">
 <div class="panel-head">
 <h2>Today's Activity</h2>
 <p class="muted-text">Recent actions</p>
 </div>
 <ul class="activity-list">
 <li class="activity success">
 <span class="dot"></span>
 Ticket #7004 assigned to <strong>CSR-01</strong>
 <span class="time">10 mins ago</span>
 </li>
 <li class="activity warning">
 <span class="dot"></span>
 New customer registered: <strong>Kisha Tan</strong>
 <span class="time">25 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
 Invoice reminder sent to <strong>Fiber Corp</strong>
 <span class="time">35 mins ago</span>
 </li>
 <li class="activity">
 <span class="dot"></span>
2 tickets waiting for update
 <span class="time">1 hr ago</span>
 </li>
 </ul>
 </div>
 </section>
 </div>
}

@code {
 private List<Ticket>? tickets;
 private List<Customer>? customers;

 protected override async Task OnInitializedAsync()
 {
 AuthService.AuthenticationStateChanged += OnAuthChanged;
 if (!AuthService.IsAuthenticated)
 {
 Navigation.NavigateTo("/login", true);
 return;
 }
 await LoadDataAsync();
 }

 private async void OnAuthChanged()
 {
 if (AuthService.IsAuthenticated)
 {
 await LoadDataAsync();
 }
 else
 {
 Navigation.NavigateTo("/login", true);
 }
 StateHasChanged();
 }

 private async Task LoadDataAsync()
 {
 tickets = await AdminService.GetTicketsAsync();
 customers = await AdminService.GetCustomersAsync();
 }

 private string GetTimeAgo(DateTime date)
 {
 var span = DateTime.Now - date;
 if (span.TotalMinutes <60) return $"{(int)span.TotalMinutes} mins ago";
 if (span.TotalHours <24) return $"{(int)span.TotalHours} hrs ago";
 return $"{(int)span.TotalDays} days ago";
 }

 private void ExportData() => Navigation.NavigateTo("/customers");
 private void NavigateToTickets() => Navigation.NavigateTo("/tickets");

 public void Dispose() => AuthService.AuthenticationStateChanged -= OnAuthChanged;
}
