public async Task<bool> CreateAgentAsync(User user, string plainPassword)
{
 try
 {
 LastError = null;
 if (user == null) { LastError = "User is null"; return false; }
 if (string.IsNullOrWhiteSpace(user.Email)) { LastError = "Email is required"; return false; }
 if (string.IsNullOrWhiteSpace(plainPassword)) { LastError = "Password is required"; return false; }
 var lower = user.Email.Trim().ToLowerInvariant();
 if (await _db.Users.AnyAsync(u => u.Email.ToLower() == lower)) { LastError = "Email already exists"; return false; }
 user.PasswordHash = HashPassword(plainPassword);
 if (string.IsNullOrWhiteSpace(user.Role)) user.Role = "Agent";
 if (string.IsNullOrWhiteSpace(user.Id)) user.Id = Guid.NewGuid().ToString();
 _db.Users.Add(user);
 var rows = await _db.SaveChangesAsync();
 return rows >0;
 }
 catch (Exception ex)
 {
 LastError = ex.Message;
 System.Diagnostics.Debug.WriteLine($"AdminService.CreateAgentAsync error: {ex}");
 return false;
 }
}

