public async Task<bool> AssignTechnicianToTicketAsync(int ticketId, string? technicianId)
{
    try
    {
        LastError = null;
        if (ticketId <= 0)
        {
            LastError = "Invalid ticket ID";
            return false;
        }
        
        var ticket = await _db.Tickets.FindAsync(ticketId);
        if (ticket == null)
        {
            LastError = "Ticket not found";
            return false;
        }
        
        if (string.IsNullOrWhiteSpace(technicianId))
        {
            // Unassign
            ticket.AssignedTechnicianId = null;
            ticket.AssignedTechnicianName = null;
            ticket.AssignedAt = null;
            if (ticket.Status == "Assigned") ticket.Status = "Open";
        }
        else
        {
            var tech = await _db.Technicians.FindAsync(technicianId);
            if (tech == null)
            {
                LastError = "Technician not found";
                return false;
            }
            
            if (!tech.IsActive)
            {
                LastError = "Cannot assign to inactive technician";
                return false;
            }
            
            ticket.AssignedTechnicianId = tech.Id;
            ticket.AssignedTechnicianName = tech.Name;
            ticket.AssignedAt = DateTime.UtcNow;
            
            if (ticket.Status == "Open")
            {
                ticket.Status = "Assigned";
            }
        }
        
        _db.Tickets.Update(ticket);
        var rows = await _db.SaveChangesAsync();
        
        if (rows > 0)
        {
            await MaybeSyncOrEnqueueAsync("Update", ticket, ticket.Id.ToString());
            return true;
        }
        
        LastError = "Assignment failed";
        return false;
    }
    catch (Exception ex)
    {
        LastError = _errorService.GetContextualMessage(ex, "assign", "technician");
        System.Diagnostics.Debug.WriteLine($"AdminService.AssignTechnicianToTicketAsync error: {ex}");
        return false;
    }
}

