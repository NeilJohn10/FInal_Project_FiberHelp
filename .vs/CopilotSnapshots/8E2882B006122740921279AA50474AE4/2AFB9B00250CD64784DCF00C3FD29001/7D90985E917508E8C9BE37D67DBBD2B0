@page "/admin/agents"
@using FiberHelp.Models
@inject FiberHelp.Services.AdminService AdminService
@inject FiberHelp.Services.AuthService AuthService
@inject NavigationManager Nav

<link href="css/dashboard.css" rel="stylesheet" />

@if (!AuthService.IsAuthenticated || !string.Equals(AuthService.Role, "Administrator", StringComparison.OrdinalIgnoreCase))
{
 <div class="panel"><strong>Access denied.</strong></div>
}
else
{
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN</p>
 <h1 class="page-title">Agents</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary" @onclick="OpenModal">+ Register Agent</button>
 </div>
 </header>

 <section class="panel">
 <table class="data-table">
 <thead>
 <tr><th>Email</th><th>Name</th><th>Role</th><th>Active</th><th></th></tr>
 </thead>
 <tbody>
 @if (agents != null && agents.Any())
 {
 @foreach (var a in agents)
 {
 <tr>
 <td>@a.Email</td>
 <td>@a.FullName</td>
 <td>@a.Role</td>
 <td>@(a.IsActive ? "Yes" : "No")</td>
 <td><button class="btn danger" @onclick="() => DeleteAgent(a.Id)">Delete</button></td>
 </tr>
 }
 }
 else
 {
 <tr><td colspan="5">No agents found.</td></tr>
 }
 </tbody>
 </table>
 </section>

 @if (!string.IsNullOrEmpty(note))
 {
 <div class="panel" style="margin-top:12px;">@note</div>
 }

 @if (showModal)
 {
 <div class="modal-backdrop" @onclick="CloseModal">
 <div class="modal" @onclick:stopPropagation>
 <h3>Register Agent</h3>
 @if (!string.IsNullOrEmpty(error)) { <div class="error-message">@error</div> }
 <div class="form-group">
 <label>Email</label>
 <input class="form-input" @bind="email" />
 </div>
 <div class="form-group">
 <label>Full Name</label>
 <input class="form-input" @bind="fullName" />
 </div>
 <div class="form-group">
 <label>Password</label>
 <input type="password" class="form-input" @bind="password" @bind:event="oninput" />
 </div>
 <ul style="list-style:none;padding:0;margin:0010px0;font-size:12px;">
 <li style="color:@(PwdOkLength ? "#16a34a" : "#dc2626")">@(PwdOkLength ? "✔" : "✖") Min12 chars</li>
 <li style="color:@(PwdOkUpper ? "#16a34a" : "#dc2626")">@(PwdOkUpper ? "✔" : "✖") Uppercase</li>
 <li style="color:@(PwdOkDigit ? "#16a34a" : "#dc2626")">@(PwdOkDigit ? "✔" : "✖") Digit</li>
 <li style="color:@(PwdOkAt ? "#16a34a" : "#dc2626")">@(PwdOkAt ? "✔" : "✖") Contains @("@")</li>
 </ul>
 <div style="display:flex;justify-content:flex-end;gap:8px;">
 <button class="btn" @onclick="CloseModal">Cancel</button>
 <button class="btn primary" @onclick="CreateAgent" disabled="@(!FormValid())">Create</button>
 </div>
 </div>
 </div>
 }
}

@code {
 List<User> agents = new();
 bool showModal = false;
 string email = string.Empty;
 string fullName = string.Empty;
 string password = string.Empty;
 string error = string.Empty;
 string note = string.Empty;

 bool PwdOkLength => password.Length >=12;
 bool PwdOkUpper => password.Any(char.IsUpper);
 bool PwdOkDigit => password.Any(char.IsDigit);
 bool PwdOkAt => password.Contains('@');

 protected override async Task OnInitializedAsync()
 {
 if (!AuthService.IsAuthenticated || !string.Equals(AuthService.Role, "Administrator", StringComparison.OrdinalIgnoreCase)) return;
 agents = await AdminService.GetAgentsAsync();
 }

 void OpenModal() { showModal = true; error = string.Empty; password = string.Empty; }
 void CloseModal() { showModal = false; email = fullName = password = string.Empty; error = string.Empty; }
 bool FormValid() => !string.IsNullOrWhiteSpace(email) && PwdOkLength && PwdOkUpper && PwdOkDigit && PwdOkAt;

 async Task CreateAgent()
 {
 error = string.Empty; note = string.Empty;
 if (!FormValid()) { error = "Fill fields & meet password rules."; return; }
 var user = new User { Email = email.Trim().ToLowerInvariant(), FullName = fullName, Role = "Agent", IsActive = true };
 if (await AdminService.CreateAgentAsync(user, password))
 {
 note = "Agent created";
 agents = await AdminService.GetAgentsAsync();
 CloseModal();
 }
 else
 {
 error = AdminService.LastError ?? "Failed";
 }
 }

 async Task DeleteAgent(string id)
 {
 if (string.IsNullOrEmpty(id)) return;
 if (await AdminService.DeleteUserAsync(id))
 {
 note = "Agent deleted";
 agents = await AdminService.GetAgentsAsync();
 }
 }
}
