@* Login.razor *@
@page "/"
@inject NavigationManager NavigationManager

<PageTitle>Login - FiberHelp</PageTitle>

<div class="login-wrapper">
    <div class="login-container">
        <!-- Login Form -->
        <div class="login-card @(!showRegister ? "show" : "")">
            <div class="login-header">
                <h1>FiberHelp</h1>
                <p>Internet Service Provider Customer Support System</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">
                    <span>⚠️ @errorMessage</span>
                </div>
            }

            <div class="login-form">
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email"
                           id="email"
                           class="form-input"
                           placeholder="Enter your email"
                           @bind="email"
                           required />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password"
                           id="password"
                           class="form-input"
                           placeholder="Enter your password"
                           @bind="password"
                           required />
                </div>

                <div class="form-options">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="rememberMe" />
                        <span>Remember me</span>
                    </label>
                    <a href="#" class="forgot-password">Forgot password?</a>
                </div>

                <button type="submit" class="btn-login" disabled="@isLoading" @onclick="HandleLogin">
                    @if (isLoading)
                    {
                        <span>Logging in...</span>
                    }
                    else
                    {
                        <span>Sign In</span>
                    }
                </button>

                <div class="register-link">
                    <p>Don't have an account? <a href="#" @onclick="ShowRegisterForm" @onclick:preventDefault>Register here</a></p>
                </div>
            </div>
        </div>

        <!-- Registration Form -->
        <div class="login-card @(showRegister ? "show" : "")">
            <div class="login-header">
                <h1>Create Account</h1>
                <p>Register for FiberHelp Support System</p>
            </div>

            @if (!string.IsNullOrEmpty(registerErrorMessage))
            {
                <div class="error-message">
                    <span>⚠️ @registerErrorMessage</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-message">
                    <span>✅ @successMessage</span>
                </div>
            }

            <div class="login-form">
                <div class="form-group">
                    <label for="reg-fullname">Full Name</label>
                    <input type="text"
                           id="reg-fullname"
                           class="form-input"
                           placeholder="Enter your full name"
                           @bind="registerFullName"
                           required />
                </div>

                <div class="form-group">
                    <label for="reg-email">Email Address</label>
                    <input type="email"
                           id="reg-email"
                           class="form-input"
                           placeholder="Enter your email"
                           @bind="registerEmail"
                           required />
                </div>

                <div class="form-group">
                    <label for="reg-phone">Phone Number</label>
                    <input type="tel"
                           id="reg-phone"
                           class="form-input"
                           placeholder="Enter your phone number"
                           @bind="registerPhone"
                           required />
                </div>

                <div class="form-group">
                    <label for="reg-company">Company/Organization (Optional)</label>
                    <input type="text"
                           id="reg-company"
                           class="form-input"
                           placeholder="Enter company name"
                           @bind="registerCompany" />
                </div>

                <div class="form-group">
                    <label for="reg-role">Role</label>
                    <select id="reg-role"
                            class="form-input"
                            @bind="registerRole"
                            required>
                        <option value="">Select a role</option>
                        <option value="Agent">Support Agent</option>
                        <option value="Manager">Manager</option>
                        <option value="Administrator">Administrator</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="reg-password">Password</label>
                    <input type="password"
                           id="reg-password"
                           class="form-input"
                           placeholder="Create a password (min 8 characters)"
                           @bind="registerPassword"
                           required />
                </div>

                <div class="form-group">
                    <label for="reg-confirm-password">Confirm Password</label>
                    <input type="password"
                           id="reg-confirm-password"
                           class="form-input"
                           placeholder="Confirm your password"
                           @bind="registerConfirmPassword"
                           required />
                </div>

                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="agreeToTerms" required />
                        <span>I agree to the Terms of Service and Privacy Policy</span>
                    </label>
                </div>

                <button type="submit" class="btn-login" disabled="@isRegistering" @onclick="HandleRegister">
                    @if (isRegistering)
                    {
                        <span>Creating Account...</span>
                    }
                    else
                    {
                        <span>Create Account</span>
                    }
                </button>

                <div class="register-link">
                    <p>Already have an account? <a href="#" @onclick="ShowLoginForm" @onclick:preventDefault>Sign in here</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private bool rememberMe = false;
    private bool isLoading = false;
    private string errorMessage = "";

    // Registration fields
    private bool showRegister = false;
    private string registerFullName = "";
    private string registerEmail = "";
    private string registerPhone = "";
    private string registerCompany = "";
    private string registerRole = "";
    private string registerPassword = "";
    private string registerConfirmPassword = "";
    private bool agreeToTerms = false;
    private bool isRegistering = false;
    private string registerErrorMessage = "";
    private string successMessage = "";

    // Sample user credentials (In production, use proper authentication service)
    private Dictionary<string, UserCredential> validUsers = new()
    {
        { "admin@fiberhelp.com", new UserCredential { Password = "admin123", Role = "Administrator" } },
        { "agent@fiberhelp.com", new UserCredential { Password = "agent123", Role = "Agent" } },
        { "manager@fiberhelp.com", new UserCredential { Password = "manager123", Role = "Manager" } }
    };

    private void ShowRegisterForm()
    {
        showRegister = true;
        errorMessage = "";
    }

    private void ShowLoginForm()
    {
        showRegister = false;
        registerErrorMessage = "";
        successMessage = "";
    }

    private async Task HandleRegister()
    {
        isRegistering = true;
        registerErrorMessage = "";
        successMessage = "";
        StateHasChanged();

        // Validate form
        if (string.IsNullOrWhiteSpace(registerFullName))
        {
            registerErrorMessage = "Full name is required.";
            isRegistering = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(registerEmail))
        {
            registerErrorMessage = "Email is required.";
            isRegistering = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(registerPhone))
        {
            registerErrorMessage = "Phone number is required.";
            isRegistering = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(registerRole))
        {
            registerErrorMessage = "Please select a role.";
            isRegistering = false;
            return;
        }

        if (registerPassword.Length < 8)
        {
            registerErrorMessage = "Password must be at least 8 characters long.";
            isRegistering = false;
            return;
        }

        if (registerPassword != registerConfirmPassword)
        {
            registerErrorMessage = "Passwords do not match.";
            isRegistering = false;
            return;
        }

        if (!agreeToTerms)
        {
            registerErrorMessage = "You must agree to the Terms of Service.";
            isRegistering = false;
            return;
        }

        // Check if email already exists
        if (validUsers.ContainsKey(registerEmail.ToLower()))
        {
            registerErrorMessage = "An account with this email already exists.";
            isRegistering = false;
            return;
        }

        // Simulate API call delay
        await Task.Delay(1500);

        // Add new user to the dictionary (In production, save to database)
        validUsers.Add(registerEmail.ToLower(), new UserCredential
        {
            Password = registerPassword,
            Role = registerRole,
            FullName = registerFullName,
            Phone = registerPhone,
            Company = registerCompany
        });

        // Show success message
        successMessage = "Account created successfully! Redirecting to login...";
        StateHasChanged();

        // Wait a bit then switch to login form
        await Task.Delay(2000);

        // Clear registration fields
        ClearRegisterForm();

        // Show login form
        showRegister = false;
        successMessage = "";

        isRegistering = false;
    }

    private void ClearRegisterForm()
    {
        registerFullName = "";
        registerEmail = "";
        registerPhone = "";
        registerCompany = "";
        registerRole = "";
        registerPassword = "";
        registerConfirmPassword = "";
        agreeToTerms = false;
    }

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = "";
        StateHasChanged();

        // Simulate API call delay
        await Task.Delay(1000);

        if (validUsers.TryGetValue(email.ToLower(), out var user))
        {
            if (user.Password == password)
            {
                // Successful login
                // In production, you would:
                // 1. Call your authentication API
                // 2. Store the authentication token
                // 3. Set user session/claims

                // For now, just navigate to dashboard
                NavigationManager.NavigateTo("/dashboard", true);
                return;
            }
        }

        // Login failed
        errorMessage = "Invalid email or password. Please try again.";
        isLoading = false;
        password = ""; // Clear password field
    }

    private class UserCredential
    {
        public string Password { get; set; } = "";
        public string Role { get; set; } = "";
        public string FullName { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Company { get; set; } = "";
    }
}

<style>
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        padding: 2rem;
        overflow-y: auto;
    }

    .login-container {
        width: 100%;
        max-width: 450px;
        position: relative;
        min-height: fit-content;
        margin: auto;
    }

    .login-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        padding: 2.5rem;
        width: 100%;
        max-height: 85vh;
        overflow-y: auto;
        display: none;
    }

        .login-card.show {
            display: block;
        }

    .login-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

        .login-header h1 {
            font-size: 2rem;
            font-weight: 700;
            color: #1e293b;
            margin: 0 0 0.5rem 0;
        }

        .login-header p {
            color: #64748b;
            margin: 0;
            font-size: 0.9rem;
        }

    .error-message {
        background: #fee2e2;
        color: #991b1b;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .success-message {
        background: #d1fae5;
        color: #065f46;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .login-form {
        margin-bottom: 1rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

        .form-group label {
            display: block;
            margin-bottom: 0.4rem;
            color: #334155;
            font-weight: 600;
            font-size: 0.875rem;
        }

    .form-input {
        width: 100%;
        padding: 0.75rem 0.875rem;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.2s;
        box-sizing: border-box;
    }

        .form-input:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

    select.form-input {
        cursor: pointer;
        background: white;
    }

    .form-options {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-size: 0.875rem;
        color: #64748b;
    }

        .checkbox-label input[type="checkbox"] {
            width: 1rem;
            height: 1rem;
            cursor: pointer;
        }

    .forgot-password {
        color: #667eea;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
    }

        .forgot-password:hover {
            color: #5568d3;
            text-decoration: underline;
        }

    .btn-login {
        width: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        padding: 0.875rem;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

        .btn-login:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }

        .btn-login:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

    .register-link {
        text-align: center;
        margin-top: 1.25rem;
    }

        .register-link p {
            color: #64748b;
            font-size: 0.875rem;
            margin: 0;
        }

        .register-link a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
        }

            .register-link a:hover {
                color: #5568d3;
                text-decoration: underline;
            }

    /* Responsive */
    @@media (max-width: 640px) {
        .login-card {
            padding: 2rem;
        }

        .login-header h1 {
            font-size: 1.75rem;
        }

        .login-wrapper {
            padding: 1rem;
        }
    }

    /* Scrollbar styling for registration form */
    .login-card::-webkit-scrollbar {
        width: 8px;
    }

    .login-card::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }

    .login-card::-webkit-scrollbar-thumb {
        background: #667eea;
        border-radius: 10px;
    }

        .login-card::-webkit-scrollbar-thumb:hover {
            background: #5568d3;
        }
</style>
