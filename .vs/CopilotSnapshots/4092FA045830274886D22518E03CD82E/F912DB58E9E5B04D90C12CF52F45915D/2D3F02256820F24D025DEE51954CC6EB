public async Task<bool> CreateTicketAsync(Ticket t)
{
try
{
LastError = null;
if (t == null) { LastError = "Ticket is null"; return false; }
if (t.Id !=0) t.Id =0;
if (t.Created == default) t.Created = DateTime.UtcNow;
if (string.IsNullOrWhiteSpace(t.ClientId)) t.ClientId = null;
if (!string.IsNullOrWhiteSpace(t.ClientId))
{
 var cust = await _db.Clients.FirstOrDefaultAsync(c => c.Id == t.ClientId || c.Name == t.ClientId);
 if (cust != null)
 {
 t.ClientName = cust.Name;
 t.ClientId = cust.Id;
 }
}
if (t.ClientId == null && t.AccountId.HasValue)
{
 var acctClient = await _db.Clients.FirstOrDefaultAsync(c => c.AccountId == t.AccountId.Value);
 if (acctClient != null)
 {
 t.ClientId = acctClient.Id;
 t.ClientName = acctClient.Name;
 }
 else
 {
 // No client linked: use account name/contact so UI shows a name
 var acct = await _db.Accounts.FirstOrDefaultAsync(a => a.Id == t.AccountId.Value);
 if (acct != null)
 {
 t.ClientName = !string.IsNullOrWhiteSpace(acct.ContactName) ? acct.ContactName : (acct.Name ?? string.Empty);
 }
 }
}
_db.Tickets.Add(t);
var rows = await _db.SaveChangesAsync();
return rows >0;
}
catch (Exception ex)
{
LastError = ex.InnerException?.Message ?? ex.Message;
System.Diagnostics.Debug.WriteLine($"AdminService.CreateTicketAsync error: {ex}\nInner: {ex.InnerException?.Message}");
return false;
}
}

public async Task UpdateTicketAsync(Ticket t)
{
try
{
LastError = null;
if (t == null || t.Id <=0) { LastError = "Invalid ticket for update"; return; }
var existing = await _db.Tickets.FindAsync(t.Id);
if (existing == null) { LastError = $"Ticket not found id={t.Id}"; return; }
existing.Title = t.Title;
existing.ClientId = string.IsNullOrWhiteSpace(t.ClientId) ? null : t.ClientId;
existing.Priority = t.Priority;
existing.Status = t.Status;
if (!string.IsNullOrWhiteSpace(existing.ClientId))
{
 var cust = await _db.Clients.FirstOrDefaultAsync(c => c.Id == existing.ClientId || c.Name == existing.ClientId);
 if (cust != null)
 {
 existing.ClientName = cust.Name;
 existing.ClientId = cust.Id;
 }
}
else if (existing.ClientId == null && existing.AccountId.HasValue)
{
 var acctClient = await _db.Clients.FirstOrDefaultAsync(c => c.AccountId == existing.AccountId.Value);
 if (acctClient != null)
 {
 existing.ClientId = acctClient.Id;
 existing.ClientName = acctClient.Name;
 }
 else
 {
 var acct = await _db.Accounts.FirstOrDefaultAsync(a => a.Id == existing.AccountId.Value);
 if (acct != null)
 {
 existing.ClientName = !string.IsNullOrWhiteSpace(acct.ContactName) ? acct.ContactName : (acct.Name ?? string.Empty);
 }
 }
}
_db.Tickets.Update(existing);
var rows = await _db.SaveChangesAsync();
if (rows <=0) LastError = "Update affected0 rows";
}
catch (Exception ex)
{
LastError = ex.InnerException?.Message ?? ex.Message;
System.Diagnostics.Debug.WriteLine($"AdminService.UpdateTicketAsync error: {ex}\nInner: {ex.InnerException?.Message}");
}
}

