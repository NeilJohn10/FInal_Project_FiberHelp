 }

 .brand {
 display: flex;
 align-items: center;
 gap: .5rem;
 font-weight:700;
 letter-spacing: .08em;
 margin-bottom: .5rem;
 text-transform: uppercase;
 color: #cfe8ff;
 }

 .brand-dot {
 width: .65rem;
 height: .65rem;
 border-radius:999px;
 background: #38bdf8;
 }

 .sidebar-group {
 display: flex;
 flex-direction: column;
 gap: .35rem;
 }

 .sidebar-group.muted {
