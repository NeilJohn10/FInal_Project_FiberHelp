 private void FilterAccounts()
 {
   try
   {
     if (string.IsNullOrWhiteSpace(accountSearch)) { filteredAccounts = accounts; return; }
     var term = accountSearch.Trim();
     filteredAccounts = accounts?.Where(a =>
       (!string.IsNullOrEmpty(a.Name) && a.Name.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
       (!string.IsNullOrEmpty(a.ContactEmail) && a.ContactEmail.Contains(term, StringComparison.OrdinalIgnoreCase))
     ).ToList();
     StateHasChanged();
   }
   catch (Exception ex)
   {
     System.Diagnostics.Debug.WriteLine($"[Clients] FilterAccounts error: {ex}");
   }
 }
 
