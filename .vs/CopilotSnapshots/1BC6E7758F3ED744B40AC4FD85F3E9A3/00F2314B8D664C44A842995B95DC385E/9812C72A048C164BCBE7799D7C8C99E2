            try
            {
                var entity = System.Text.Json.JsonSerializer.Deserialize<Technician>(msg.Payload);
                if (entity == null) { msg.ProcessedAt = DateTime.UtcNow; return; }

                // Normalize fields
                entity.Email = entity.Email?.Trim().ToLowerInvariant() ?? string.Empty;
                entity.FullName = entity.FullName?.Trim() ?? string.Empty;

                if (string.Equals(msg.Operation, "Delete", StringComparison.OrdinalIgnoreCase))
                {
                    // Check if technician has assigned tickets
                    var hasAssignedTickets = await online.Set<Ticket>().AnyAsync(t => t.AssignedTechnicianId == entity.Id);
                    if (hasAssignedTickets) 
                    { 
                        // Skip delete if has tickets - mark as processed to avoid retry loop
                        msg.ProcessedAt = DateTime.UtcNow; 
                        return; 
                    }
                    
                    var existing = await online.Set<Technician>().FindAsync(entity.Id);
                    if (existing != null)
                    {
                        online.Set<Technician>().Remove(existing);
                    }
                    else
                    {
                        msg.ProcessedAt = DateTime.UtcNow;
                        return;
                    }
                }
                else if (string.Equals(msg.Operation, "Create", StringComparison.OrdinalIgnoreCase))
                {
                    // Upsert: if exists, update; else add
                    var existing = await online.Set<Technician>().FindAsync(entity.Id);
                    if (existing != null)
