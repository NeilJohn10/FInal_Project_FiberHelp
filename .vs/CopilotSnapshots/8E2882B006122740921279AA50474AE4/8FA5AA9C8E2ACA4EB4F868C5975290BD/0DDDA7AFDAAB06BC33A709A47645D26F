@page "/admin/agents"
@using FiberHelp.Models
@inject FiberHelp.Services.AdminService AdminService
@inject FiberHelp.Services.AuthService AuthService
@inject NavigationManager Navigation

<link href="css/dashboard.css" rel="stylesheet" />

@if (!AuthService.IsAuthenticated || !(AuthService.Role ?? "").Equals("Administrator", StringComparison.OrdinalIgnoreCase))
{
 <div class="panel"><strong>Access denied.</strong></div>
}
else
{
 <header class="topbar">
 <div>
 <p class="eyebrow">FIBERHELP · ADMIN</p>
 <h1 class="page-title">Agents</h1>
 </div>
 <div class="top-actions">
 <button class="btn primary" @onclick="()=> showNewAgent = true">+ Add Agent</button>
 </div>
 </header>

 <section class="panel">
 <table class="data-table">
 <thead>
 <tr><th>Email</th><th>Name</th><th>Role</th><th>Active</th><th></th></tr>
 </thead>
 <tbody>
 @if (agents != null && agents.Any())
 {
 @foreach (var a in agents)
 {
 <tr>
 <td>@a.Email</td>
 <td>@a.FullName</td>
 <td>@a.Role</td>
 <td>@(a.IsActive ? "Yes" : "No")</td>
 <td><button class="btn danger" @onclick="() => DeleteAgent(a.Id)">Delete</button></td>
 </tr>
 }
 }
 else
 {
 <tr><td colspan="5">No agents found.</td></tr>
 }
 </tbody>
 </table>
 </section>

 @if (!string.IsNullOrEmpty(notification))
 {
 <div class="panel" style="margin-top:12px;">@notification</div>
 }

 @if (showNewAgent)
 {
 <div class="modal-backdrop" @onclick="CloseModal">
 <div class="modal" @onclick:stopPropagation>
 <h3>New Agent</h3>
 @if (!string.IsNullOrEmpty(errorMessage)) { <div class="error-message">@errorMessage</div> }
 <div class="form-group">
 <label>Email</label>
 <input class="form-input" @bind="newEmail" />
 </div>
 <div class="form-group">
 <label>Full Name</label>
 <input class="form-input" @bind="newFullName" />
 </div>
 <div class="form-group">
 <label>Password</label>
 <input type="password" class="form-input" @bind="newPassword" />
 </div>
 <div style="display:flex;justify-content:flex-end;gap:8px;">
 <button class="btn" @onclick="CloseModal">Cancel</button>
 <button class="btn primary" @onclick="CreateAgent" disabled="@(!FormReady())">Create</button>
 </div>
 </div>
 </div>
 }
}

@code {
 private List<User>? agents;
 private bool showNewAgent;
 private string newEmail = string.Empty;
 private string newFullName = string.Empty;
 private string newPassword = string.Empty;
 private string notification = string.Empty;
 private string errorMessage = string.Empty;

 protected override async Task OnInitializedAsync()
 {
 if (!AuthService.IsAuthenticated || !(AuthService.Role ?? "").Equals("Administrator", StringComparison.OrdinalIgnoreCase)) return;
 await LoadAgents();
 }

 private async Task LoadAgents() => agents = await AdminService.GetAgentsAsync();
 private bool FormReady() => !string.IsNullOrWhiteSpace(newEmail) && !string.IsNullOrWhiteSpace(newPassword);
 private void CloseModal() { showNewAgent = false; newEmail = newFullName = newPassword = string.Empty; errorMessage = string.Empty; }

 private async Task CreateAgent()
 {
 errorMessage = string.Empty; notification = string.Empty;
 if (!FormReady()) { errorMessage = "Email and password required"; return; }
 var user = new User { Email = newEmail.Trim().ToLowerInvariant(), FullName = newFullName, Role = "Agent", IsActive = true };
 var ok = await AdminService.CreateAgentAsync(user, newPassword);
 if (ok) { notification = "Agent created"; await LoadAgents(); CloseModal(); } else { errorMessage = AdminService.LastError ?? "Failed"; }
 }

 private async Task DeleteAgent(string id)
 {
 if (string.IsNullOrWhiteSpace(id)) return;
 if (await AdminService.DeleteUserAsync(id)) { notification = "Agent deleted"; await LoadAgents(); }
 }
}
