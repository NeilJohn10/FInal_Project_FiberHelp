 }

 .kpi-header {
 display: flex;
 justify-content: space-between;
 align-items: center;
 font-size: .75rem;
 color: #64748b;
 }

 .kpi-card h2 {
 font-size:1.6rem;
 margin-top: .6rem;
 color: #0f172a;
 }

 .kpi-sub {
 font-size: .75rem;
 color: #94a3b8;
 margin-top: .15rem;
 }

 .badge {
 padding: .2rem .5rem;
 border-radius:999px;
 font-size: .65rem;
 font-weight:600;
 }

 .badge.success { background: #ecfdf5; color: #059669; }
 .badge.warning { background: #fffbeb; color: #92400e; }
 .badge.danger { background: #fff1f2; color: #b91c1c; }

 .body-grid {
 padding:1rem000;
 display: grid;
 grid-template-columns:1.1fr .55fr;
 gap:1rem;
 align-items: flex-start;
 }

 .panel {
 background: #fff;
 border-radius:1rem;
 border:1px solid #edf1f5;
 padding:1rem;
 box-shadow:010px30px rgba(15,23,42,0.04);
 }

 .panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: .75rem; }
 .panel-head h2 { font-size:1rem; font-weight:600; }

 .muted-text { font-size: .8rem; color: #94a3b8; }

 .filter-pill { background: #fff; border:1px solid #e6eef8; border-radius: .75rem; font-size: .8rem; padding: .35rem .6rem; }

 .data-table { width:100%; border-collapse: collapse; font-size: .85rem; }
 .data-table th { text-align: left; padding: .65rem .6rem; color: #6b7280; font-weight:700; border-bottom:1px solid #f1f5f9; }
 .data-table td { padding: .65rem .6rem; border-bottom:1px solid #f8fafc; color: #374151; }

 .status-pill { display: inline-block; padding: .28rem .65rem; border-radius:999px; font-size: .75rem; font-weight:700; background: #eef2ff; color: #0f172a; }
 .status-pill.open { background: #fee7e7; color: #b91c1c; }
 .status-pill.resolved { background: #ecfdf5; color: #059669; }
 .status-pill.in-progress, .status-pill.inprogress { background: #fff7ed; color: #92400e; }

 .activity-list { list-style: none; padding:0; margin:0; display: flex; flex-direction: column; gap: .75rem; }
 .activity { background: #fff; border:1px solid #eef2f7; border-radius: .75rem; padding: .8rem .9rem; position: relative; font-size: .85rem; }
 .activity .dot { width: .5rem; height: .5rem; border-radius:999px; background: #0f172a; position: absolute; left: -1rem; top:1rem; }
 .activity.success .dot { background: #22c55e; }
 .activity.warning .dot { background: #f97316; }
 .activity .time { display: block; font-size: .75rem; color: #94a3b8; margin-top: .25rem; }

 @@media (max-width:1080px) {
 .body-grid { grid-template-columns:1fr; }
 .sidebar { display: none; }
 .kpi-grid { grid-template-columns: repeat(2,1fr); }
 .main-inner { padding:0.6rem; }
 }
</style>
